# Copy this file to ".env" and fill in your SMTP credentials.
# These power the contact form (/api/contact).

SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# Where contact form submissions are sent, and the From address.
CONTACT_TO=contact@resolveit.nl
CONTACT_FROM=website@resolveit.nl
