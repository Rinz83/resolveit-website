---
export interface Props {
  eyebrow: string;
  title: string;
  intro: string;
  icon: string;                       // inline SVG string
  dashboard: {
    title: string;
    kpis: { label: string; value: string; trend?: string }[];
    barLabel: string;
    bars: number[];                   // heights 0-100, last one is accented
    legend: { label: string; value: string; color: string }[];
    ring?: string;                    // e.g. "92%"
    ringLabel?: string;
  };
  painLine: string;
  painPoints: string[];               // day-to-day frustrations, in their language
  capabilities: { icon: string; title: string; text: string }[];
  metrics: { num: string; label: string }[];
  products?: { label: string; href: string; featured?: boolean }[];
}
const { eyebrow, title, intro, icon, dashboard, painLine, painPoints, capabilities, metrics, products = [], lang = 'nl' } = Astro.props;
const ringDash = dashboard.ring ? 157 - (157 * parseInt(dashboard.ring)) / 100 : 20;
const en = lang === 'en';
const T = {
  planGesprek: en ? 'Plan a consultancy call' : 'Plan een consultancygesprek',
  bekijkCases: en ? 'View cases' : 'Bekijk cases',
  herkenbaar: en ? 'Sound familiar?' : 'Herkenbaar?',
  herkenbaarIntro: en ? 'We speak with organisations in your sector every day. These are the challenges we hear time and again — and exactly what we are built for.' : 'Wij spreken dagelijks organisaties in uw sector. Dit zijn de uitdagingen die we steeds weer horen — en precies waar wij voor gebouwd hebben.',
  aanpak: en ? 'Our approach' : 'Onze aanpak',
  aanpakTitle: en ? 'What we set up for your sector' : 'Wat wij voor uw sector inrichten',
  aanpakIntro: en ? 'Salesforce, tailored to the processes that truly matter to you.' : 'Salesforce, op maat gemaakt voor de processen die er bij u écht toe doen.',
  resultaat: en ? 'Results' : 'Resultaat',
  resultaatTitle: en ? 'What it ultimately comes down to' : 'Waar het u uiteindelijk om gaat',
  relevant: en ? 'Relevant for your sector' : 'Relevant voor uw sector',
  consultancy: en ? 'Audit & Consultancy' : 'Audit & Consultancy',
  alleSectoren: en ? 'All industries' : 'Alle sectoren',
  ctaTitle: en ? 'Recognise these challenges?' : 'Herkent u deze uitdagingen?',
  ctaText: en ? 'Schedule a no-obligation consultancy call — we think along with you, with no strings attached.' : 'Plan een vrijblijvend consultancygesprek — we denken met u mee, zonder verplichtingen.',
  planKort: en ? 'Schedule a call' : 'Plan een gesprek',
  stelVraag: en ? 'Ask a question' : 'Stel een vraag',
  contact: en ? '/en/contact' : '/contact',
  cases: en ? '/en/cases' : '/cases',
  consultancyHref: en ? '/en/diensten/consultancy' : '/diensten/consultancy',
  voorwie: en ? '/en/voor-wie' : '/voor-wie',
};
---

<!-- HERO with industry dashboard -->
<section class="sec-hero">
  <div class="sec-aurora" aria-hidden="true"><span></span><span></span></div>
  <div class="container sec-hero-inner">
    <div class="sec-hero-copy">
      <span class="pp-badge"><span class="pp-badge-dot"></span> {eyebrow}</span>
      <h1>{title}</h1>
      <p>{intro}</p>
      <div class="sec-hero-actions">
        <a href={`${T.contact}#afspraak`} class="btn btn-primary">{T.planGesprek}</a>
        <a href={T.cases} class="btn btn-outline">{T.bekijkCases}</a>
      </div>
    </div>

    <div class="sec-visual">
      <span class="sec-float-ico" set:html={icon} />
      <div class="dash" role="img" aria-label={`${en ? 'Sample dashboard' : 'Voorbeelddashboard'}: ${dashboard.title}`}>
        <div class="dash-head">
          <span class="dash-dots"><i></i><i></i><i></i></span>
          <span class="dash-title">{dashboard.title}</span>
          <span class="dash-live"><span class="lv-dot"></span> Live</span>
        </div>
        <div class="dash-body">
          <div class="dash-kpis">
            {dashboard.kpis.map(k => (
              <div class="kpi">
                <span class="kpi-label">{k.label}</span>
                <span class="kpi-val">{k.value}</span>
                {k.trend && <span class="kpi-trend">{k.trend}</span>}
              </div>
            ))}
          </div>
          <div class="dash-chart">
            <div class="chart-head"><span>{dashboard.barLabel}</span><span class="chart-tag">{en ? 'YTD' : '2026'}</span></div>
            <div class="bars">
              {dashboard.bars.map((h, i) => (
                <span class={`bar ${i === dashboard.bars.length - 1 ? 'bar-accent' : ''}`} style={`--h:${h}%`}></span>
              ))}
            </div>
          </div>
          <div class="dash-foot">
            {dashboard.ring && (
              <div class="ring-wrap">
                <svg viewBox="0 0 60 60" class="ring">
                  <circle class="ring-bg" cx="30" cy="30" r="25" />
                  <circle class="ring-fg" cx="30" cy="30" r="25" style={`stroke-dashoffset:${ringDash}`} />
                </svg>
                <div class="ring-label"><strong>{dashboard.ring}</strong><small>{dashboard.ringLabel}</small></div>
              </div>
            )}
            <ul class="dash-legend">
              {dashboard.legend.map(l => (
                <li><span class="lg-dot" style={`background:${l.color}`}></span> {l.label} <b>{l.value}</b></li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- EMPATHY: we understand your day -->
<section class="section bg-off-white">
  <div class="container sec-empathy">
    <div class="reveal">
      <span class="eyebrow">{T.herkenbaar}</span>
      <h2>{painLine}</h2>
      <p class="text-muted" style="margin-top:0.75rem;">{T.herkenbaarIntro}</p>
    </div>
    <ul class="pain-list reveal">
      {painPoints.map(p => (
        <li><span class="pain-x" aria-hidden="true">✕</span>{p}</li>
      ))}
    </ul>
  </div>
</section>

<!-- CAPABILITIES: how Salesforce solves it -->
<section class="section">
  <div class="container">
    <div class="section-header reveal">
      <span class="eyebrow">{T.aanpak}</span>
      <h2>{T.aanpakTitle}</h2>
      <p>{T.aanpakIntro}</p>
    </div>
    <div class="grid-3">
      {capabilities.map((c, i) => (
        <div class="card cap-card reveal" style={`--reveal-delay:${(i % 3) * 0.08}s`}>
          <div class="cap-ico">{c.icon}</div>
          <h3>{c.title}</h3>
          <p class="text-muted">{c.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- METRICS band -->
<section class="section bg-dark sec-metrics">
  <div class="sec-metrics-glow" aria-hidden="true"></div>
  <div class="container" style="position:relative;z-index:1;">
    <div class="section-header reveal">
      <span class="eyebrow">{T.resultaat}</span>
      <h2 class="text-white">{T.resultaatTitle}</h2>
    </div>
    <div class="metrics-grid">
      {metrics.map((m, i) => (
        <div class="metric reveal" style={`--reveal-delay:${i * 0.08}s`}>
          <span class="metric-num">{m.num}</span>
          <span class="metric-label">{m.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CROSS LINKS -->
<section class="section-sm bg-off-white">
  <div class="container">
    <p class="sec-related-label">{T.relevant}</p>
    <div class="sec-related">
      {products.map(p => (
        <a href={p.href} class={p.featured ? 'sec-related-feat' : ''}>{p.featured ? '★ ' : ''}{p.label}</a>
      ))}
      <a href={T.consultancyHref}>{T.consultancy}</a>
      <a href={T.voorwie}>{T.alleSectoren}</a>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="pp-cta bg-dark">
  <div class="pp-cta-glow" aria-hidden="true"></div>
  <div class="container pp-cta-inner reveal">
    <div>
      <h2>{T.ctaTitle}</h2>
      <p>{T.ctaText}</p>
    </div>
    <div class="pp-cta-actions">
      <a href={`${T.contact}#afspraak`} class="btn btn-primary">{T.planKort}</a>
      <a href={T.contact} class="btn btn-outline">{T.stelVraag}</a>
    </div>
  </div>
</section>

<style>
.sec-hero { background: var(--color-dark); color: var(--color-white); padding: 6rem 0 5rem; position: relative; overflow: hidden; }
.sec-aurora { position: absolute; inset: 0; z-index: 0; }
.sec-aurora span { position: absolute; border-radius: 50%; filter: blur(80px); }
.sec-aurora span:nth-child(1) { width: 460px; height: 460px; background: rgba(109,183,87,0.4); top: -150px; left: -100px; animation: drift 20s ease-in-out infinite; }
.sec-aurora span:nth-child(2) { width: 400px; height: 400px; background: rgba(108,68,148,0.4); bottom: -150px; right: -80px; animation: drift 24s ease-in-out infinite reverse; }
.sec-hero-inner { position: relative; z-index: 1; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
.sec-hero-copy h1 { color: #fff; font-size: clamp(2.1rem, 4.6vw, 3.2rem); margin-bottom: 1.25rem; }
.sec-hero-copy p { color: rgba(255,255,255,0.8); font-size: 1.12rem; margin-bottom: 2rem; max-width: 540px; }
.sec-hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
@media (max-width: 860px) { .sec-hero-inner { grid-template-columns: 1fr; gap: 3rem; } .sec-hero { padding: 4.5rem 0; } }

.sec-visual { position: relative; }
.sec-float-ico { position: absolute; top: -42px; right: -10px; z-index: 3; width: 72px; height: 72px; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.16); border-radius: 18px; display: flex; align-items: center; justify-content: center; animation: float-y 6s ease-in-out infinite; }
.sec-float-ico :global(svg) { width: 40px; height: 40px; color: var(--color-green-soft); }
@media (max-width: 860px) { .sec-float-ico { display: none; } }

/* dashboard (shared look with homepage) */
.dash { background: #fff; border-radius: 18px; box-shadow: 0 30px 70px rgba(0,0,0,0.45); border: 1px solid rgba(255,255,255,0.12); overflow: hidden; animation: float-y 7s ease-in-out infinite; }
.dash-head { display: flex; align-items: center; gap: 0.75rem; padding: 0.85rem 1.1rem; background: var(--color-off-white); border-bottom: 1px solid var(--color-light); }
.dash-dots { display: flex; gap: 6px; }
.dash-dots i { width: 10px; height: 10px; border-radius: 50%; }
.dash-dots i:nth-child(1){background:#ff5f57}.dash-dots i:nth-child(2){background:#febc2e}.dash-dots i:nth-child(3){background:#28c840}
.dash-title { font-size: 0.82rem; font-weight: 600; color: var(--color-text); }
.dash-live { margin-left: auto; display: inline-flex; align-items: center; gap: 0.35rem; font-size: 0.72rem; font-weight: 600; color: var(--color-green-dark); }
.lv-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--color-green); animation: pulse-ring 2s ease-out infinite; }
.dash-body { padding: 1.25rem; display: flex; flex-direction: column; gap: 1.1rem; }
.dash-kpis { display: grid; grid-template-columns: 1fr 1fr; gap: 0.85rem; }
.kpi { background: var(--color-off-white); border: 1px solid var(--color-light); border-radius: 12px; padding: 0.85rem 1rem; display: flex; flex-direction: column; gap: 0.15rem; }
.kpi-label { font-size: 0.7rem; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em; }
.kpi-val { font-size: 1.45rem; font-weight: 800; color: var(--color-text); line-height: 1.1; }
.kpi-trend { font-size: 0.72rem; font-weight: 700; color: var(--color-green-dark); }
.dash-chart { display: flex; flex-direction: column; gap: 0.6rem; }
.chart-head { display: flex; justify-content: space-between; align-items: center; font-size: 0.72rem; color: var(--color-text-muted); }
.chart-tag { background: rgba(109,183,87,0.12); color: var(--color-green-dark); padding: 0.1rem 0.5rem; border-radius: 999px; font-weight: 700; }
.bars { display: flex; align-items: flex-end; gap: 0.5rem; height: 84px; }
.bar { flex: 1; height: var(--h); background: linear-gradient(180deg, #b9e0a8, var(--color-green)); border-radius: 6px 6px 3px 3px; transform-origin: bottom; animation: grow-bar 1s cubic-bezier(0.16,1,0.3,1) backwards; }
.bar-accent { background: linear-gradient(180deg, #a988d0, var(--color-purple)); }
.bar:nth-child(1){animation-delay:.1s}.bar:nth-child(2){animation-delay:.2s}.bar:nth-child(3){animation-delay:.3s}.bar:nth-child(4){animation-delay:.4s}.bar:nth-child(5){animation-delay:.5s}.bar:nth-child(6){animation-delay:.6s}
@keyframes grow-bar { from { transform: scaleY(0); opacity: 0; } to { transform: scaleY(1); opacity: 1; } }
.dash-foot { display: flex; align-items: center; gap: 1.25rem; border-top: 1px solid var(--color-light); padding-top: 1.1rem; }
.ring-wrap { position: relative; width: 78px; height: 78px; flex-shrink: 0; }
.ring { width: 78px; height: 78px; transform: rotate(-90deg); }
.ring-bg { fill: none; stroke: var(--color-light); stroke-width: 6; }
.ring-fg { fill: none; stroke: var(--color-green); stroke-width: 6; stroke-linecap: round; stroke-dasharray: 157; animation: draw-ring 1.6s cubic-bezier(0.16,1,0.3,1) 0.3s backwards; }
@keyframes draw-ring { from { stroke-dashoffset: 157; } }
.ring-label { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.ring-label strong { font-size: 1.05rem; color: var(--color-text); }
.ring-label small { font-size: 0.58rem; color: var(--color-text-muted); }
.dash-legend { list-style: none; display: flex; flex-direction: column; gap: 0.4rem; flex: 1; }
.dash-legend li { display: flex; align-items: center; gap: 0.5rem; font-size: 0.8rem; color: var(--color-text-muted); }
.dash-legend b { margin-left: auto; color: var(--color-text); font-weight: 700; }
.lg-dot { width: 9px; height: 9px; border-radius: 3px; flex-shrink: 0; }

/* empathy */
.sec-empathy { display: grid; grid-template-columns: 1fr 1fr; gap: 3.5rem; align-items: center; }
@media (max-width: 820px) { .sec-empathy { grid-template-columns: 1fr; gap: 2rem; } }
.pain-list { list-style: none; display: flex; flex-direction: column; gap: 0.85rem; }
.pain-list li { display: flex; align-items: flex-start; gap: 0.75rem; background: var(--color-white); border: 1px solid var(--color-light); border-radius: 12px; padding: 0.9rem 1.1rem; font-size: 0.95rem; color: var(--color-text); }
.pain-x { width: 22px; height: 22px; border-radius: 50%; background: rgba(108,68,148,0.12); color: var(--color-purple); display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: 700; flex-shrink: 0; margin-top: 0.05rem; }

/* capabilities */
.cap-card { display: flex; flex-direction: column; }
.cap-ico { width: 52px; height: 52px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; background: linear-gradient(135deg, rgba(109,183,87,0.15), rgba(108,68,148,0.12)); margin-bottom: 1rem; }
.cap-card h3 { font-size: 1.08rem; margin-bottom: 0.5rem; }

/* metrics */
.sec-metrics { position: relative; overflow: hidden; }
.sec-metrics-glow { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 700px; height: 700px; background: radial-gradient(circle, rgba(109,183,87,0.14), transparent 60%); animation: drift 22s ease-in-out infinite; }
.metrics-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
.metric { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: var(--radius-lg); padding: 1.75rem; text-align: center; }
.metric-num { display: block; font-size: 1.9rem; font-weight: 800; color: var(--color-green-soft); margin-bottom: 0.3rem; }
.metric-label { font-size: 0.85rem; color: rgba(255,255,255,0.7); }
@media (max-width: 820px) { .metrics-grid { grid-template-columns: 1fr 1fr; } }

/* related + cta */
.sec-related-label { text-align: center; font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--color-text-muted); margin-bottom: 1.25rem; }
.sec-related { display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center; }
.sec-related a { background: var(--color-white); border: 1px solid var(--color-light); border-radius: 999px; padding: 0.55rem 1.2rem; font-size: 0.88rem; font-weight: 600; color: var(--color-text); transition: all var(--transition); }
.sec-related a:hover { border-color: rgba(109,183,87,0.5); color: var(--color-green-dark); transform: translateY(-2px); }
.sec-related-feat { background: linear-gradient(100deg, var(--color-green), var(--color-green-dark)) !important; color: #fff !important; border-color: transparent !important; }
.sec-related-feat:hover { color: #fff !important; box-shadow: 0 8px 20px rgba(109,183,87,0.3); }

.pp-cta { padding: 4.5rem 0; position: relative; overflow: hidden; }
.pp-cta-glow { position: absolute; top: -50%; right: -10%; width: 500px; height: 500px; background: radial-gradient(circle, rgba(109,183,87,0.25), transparent 60%); animation: drift 18s ease-in-out infinite; }
.pp-cta-inner { display: flex; align-items: center; justify-content: space-between; gap: 3rem; flex-wrap: wrap; position: relative; z-index: 1; }
.pp-cta h2, .pp-cta p { color: #fff; }
.pp-cta p { color: rgba(255,255,255,0.75); margin-top: 0.5rem; }
.pp-cta-actions { display: flex; gap: 1rem; flex-shrink: 0; flex-wrap: wrap; }
</style>
