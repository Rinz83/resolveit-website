---
// Confirmation page shown after a Pardot form submits (its redirect target).
const { message, ctaHref = '/', ctaLabel = 'Back to home' } = Astro.props;
---
<section class="ty">
  <div class="ty-aurora" aria-hidden="true"><span></span><span></span></div>
  <div class="container ty-inner">
    <div class="ty-check" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
    </div>
    <h1>Thank you!</h1>
    <p>{message}</p>
    <div class="ty-actions">
      <a href={ctaHref} class="btn btn-primary">{ctaLabel}</a>
      <a href="/" class="btn btn-outline">Back to home</a>
    </div>
  </div>
</section>

<style>
.ty { background: var(--color-dark); color: #fff; min-height: 70vh; display: flex; align-items: center; position: relative; overflow: hidden; padding: 5rem 0; }
.ty-aurora { position: absolute; inset: 0; z-index: 0; }
.ty-aurora span { position: absolute; border-radius: 50%; filter: blur(80px); }
.ty-aurora span:nth-child(1) { width: 460px; height: 460px; background: rgba(109,183,87,0.4); top: -150px; left: -80px; animation: drift 20s ease-in-out infinite; }
.ty-aurora span:nth-child(2) { width: 400px; height: 400px; background: rgba(108,68,148,0.4); bottom: -150px; right: -80px; animation: drift 24s ease-in-out infinite reverse; }
.ty-inner { position: relative; z-index: 1; max-width: 620px; margin: 0 auto; text-align: center; }
.ty-check { width: 84px; height: 84px; margin: 0 auto 1.75rem; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; background: linear-gradient(135deg, var(--color-green), var(--color-green-dark)); box-shadow: 0 12px 30px rgba(109,183,87,0.4); }
.ty-check svg { width: 40px; height: 40px; }
.ty-inner h1 { color: #fff; font-size: clamp(2rem, 5vw, 3rem); margin-bottom: 1rem; }
.ty-inner p { color: rgba(255,255,255,0.8); font-size: 1.15rem; margin-bottom: 2rem; }
.ty-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
</style>
