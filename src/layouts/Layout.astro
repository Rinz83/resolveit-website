---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, translatedPaths } from '../i18n/ui.js';
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  transparentHeader?: boolean;
  noindex?: boolean;
  image?: string;
  ogType?: string;
  breadcrumbs?: { name: string; item: string }[];
}

// Default social-share image: purpose-built 1200x630 branded OG card.
const DEFAULT_OG_IMAGE = '/images/og-default.png';

const {
  title,
  description = 'Resolve IT helpt organisaties het volledige potentieel van Salesforce te benutten. Implementatie, integraties, training en consultancy.',
  transparentHeader = true,
  noindex = false,
  image = DEFAULT_OG_IMAGE,
  ogType = 'website',
  breadcrumbs,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://www.resolveit.nl');
const lang = Astro.url.pathname === '/en' || Astro.url.pathname.startsWith('/en/') ? 'en' : 'nl';
const ogImage = new URL(image, Astro.site ?? 'https://www.resolveit.nl').href;
const ogLocale = lang === 'en' ? 'en_GB' : 'nl_NL';

// hreflang alternates: emit NL/EN links only for pages that exist in both
// languages (the primary language flipped to NL at root, EN under /en/).
const siteBase = Astro.site ?? 'https://www.resolveit.nl';
const pn = Astro.url.pathname;
const nlClean = (getLangFromUrl(pn) === 'en' ? pn.replace(/^\/en/, '') : pn).replace(/\/$/, '') || '/';
const hasAlternate = translatedPaths.has(nlClean);
const nlHref = new URL(nlClean, siteBase).href;
const enHref = new URL(nlClean === '/' ? '/en' : `/en${nlClean}`, siteBase).href;

// Cookie-consent banner copy (bilingual).
const cc = lang === 'en'
  ? { text: 'We use cookies to analyse website traffic and improve your experience.',
      more: 'Cookie policy', link: '/en/cookiebeleid', accept: 'Accept', decline: 'Decline' }
  : { text: 'We gebruiken cookies om websiteverkeer te analyseren en onze site te verbeteren.',
      more: 'Cookiebeleid', link: '/cookiebeleid', accept: 'Accepteren', decline: 'Weigeren' };
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />

  <title>{title} | Resolve IT</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <link rel="canonical" href={canonicalURL} />

  {hasAlternate && (
    <>
      <link rel="alternate" hreflang="nl-NL" href={nlHref} />
      <link rel="alternate" hreflang="en" href={enHref} />
      <link rel="alternate" hreflang="x-default" href={nlHref} />
    </>
  )}

  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={`${title} | Resolve IT`} />
  <meta property="og:description" content={description} />
  <meta property="og:locale" content={ogLocale} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:alt" content={`${title} | Resolve IT`} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} | Resolve IT`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Organization + WebSite entity (site-wide) — helps Google's Knowledge
       Panel and AI engines identify and cite the brand. -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@graph': [
      {
        '@type': 'Organization',
        '@id': 'https://www.resolveit.nl/#organization',
        name: 'Resolve IT',
        url: 'https://www.resolveit.nl/',
        logo: 'https://www.resolveit.nl/images/Logo-colored.png',
        email: 'contact@resolveit.nl',
        telephone: '+31411799828',
        description: 'Salesforce Gold Partner: implementation, integrations, training and consultancy.',
        address: { '@type': 'PostalAddress', addressCountry: 'NL' },
        sameAs: ['https://www.linkedin.com/company/resolveitnow/'],
      },
      {
        '@type': 'WebSite',
        '@id': 'https://www.resolveit.nl/#website',
        url: 'https://www.resolveit.nl/',
        name: 'Resolve IT',
        publisher: { '@id': 'https://www.resolveit.nl/#organization' },
        inLanguage: lang === 'en' ? 'en' : 'nl-NL',
      },
    ],
  })} is:inline />

  {breadcrumbs && breadcrumbs.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: breadcrumbs.map((b, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: b.name,
        item: new URL(b.item, 'https://www.resolveit.nl').href,
      })),
    })} is:inline />
  )}

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Google Analytics 4 (gtag) with Consent Mode v2 — storage stays denied
       until the visitor accepts the cookie banner (AVG/GDPR compliant). -->
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){ dataLayer.push(arguments); }
    gtag('consent', 'default', {
      ad_storage: 'denied',
      ad_user_data: 'denied',
      ad_personalization: 'denied',
      analytics_storage: 'denied',
      wait_for_update: 500,
    });
    // Re-apply a stored choice from a previous visit before GA loads.
    try {
      if (localStorage.getItem('riy-consent') === 'granted') {
        gtag('consent', 'update', {
          ad_storage: 'granted', ad_user_data: 'granted',
          ad_personalization: 'granted', analytics_storage: 'granted',
        });
      }
    } catch (e) {}
    gtag('js', new Date());
    gtag('config', 'G-N45J4VLRC2');
  </script>
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-N45J4VLRC2" is:inline></script>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet"
  />

  <!-- Calendly popup widget (on-page overlay for booking links) -->
  <link rel="stylesheet" href="https://assets.calendly.com/assets/external/widget.css" />
  <script src="https://assets.calendly.com/assets/external/widget.js" async is:inline></script>
</head>
<body>
  <Nav transparent={transparentHeader} />
  <main id="main-content">
    <slot />
  </main>
  <Footer />

  <div id="cookie-consent" class="cc-banner" hidden>
    <p class="cc-text">
      {cc.text} <a href={cc.link}>{cc.more}</a>
    </p>
    <div class="cc-actions">
      <button type="button" class="cc-btn cc-decline">{cc.decline}</button>
      <button type="button" class="cc-btn cc-accept">{cc.accept}</button>
    </div>
  </div>

  <style>
    .cc-banner {
      position: fixed;
      left: 1rem;
      right: 1rem;
      bottom: 1rem;
      z-index: 9999;
      max-width: 640px;
      margin-inline: auto;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.75rem 1.25rem;
      padding: 1rem 1.25rem;
      background: #fff;
      border: 1px solid var(--color-light, #e6e8ec);
      border-radius: 14px;
      box-shadow: var(--shadow-lg, 0 16px 40px rgba(0,0,0,.16));
    }
    .cc-text {
      margin: 0;
      flex: 1 1 260px;
      font-size: 0.875rem;
      line-height: 1.5;
      color: var(--color-dark, #1a1d24);
    }
    .cc-text a { color: var(--color-primary, #2f9e44); text-decoration: underline; }
    .cc-actions { display: flex; gap: 0.6rem; flex: 0 0 auto; }
    .cc-btn {
      cursor: pointer;
      border-radius: 8px;
      padding: 0.55rem 1.1rem;
      font-size: 0.875rem;
      font-weight: 600;
      font-family: inherit;
      border: 1px solid var(--color-light, #e6e8ec);
    }
    .cc-decline { background: #fff; color: var(--color-dark, #1a1d24); }
    .cc-decline:hover { background: var(--color-bg, #f5f6f8); }
    .cc-accept { background: var(--color-primary, #2f9e44); color: #fff; border-color: var(--color-primary, #2f9e44); }
    .cc-accept:hover { filter: brightness(1.05); }
    @media (max-width: 480px) {
      .cc-actions { width: 100%; }
      .cc-btn { flex: 1; }
    }
  </style>

  <script is:inline>
    // Cookie consent: show the banner until a choice is stored, then update
    // Google Consent Mode v2 accordingly.
    (function () {
      var banner = document.getElementById('cookie-consent');
      if (!banner) return;
      var stored = null;
      try { stored = localStorage.getItem('riy-consent'); } catch (e) {}
      if (!stored) banner.hidden = false;
      function choose(choice) {
        try { localStorage.setItem('riy-consent', choice); } catch (e) {}
        var g = choice === 'granted' ? 'granted' : 'denied';
        if (typeof window.gtag === 'function') {
          window.gtag('consent', 'update', {
            ad_storage: g, ad_user_data: g, ad_personalization: g, analytics_storage: g,
          });
        }
        banner.hidden = true;
      }
      banner.querySelector('.cc-accept').addEventListener('click', function () { choose('granted'); });
      banner.querySelector('.cc-decline').addEventListener('click', function () { choose('denied'); });
    })();
  </script>

  <script>
    // Calendly: open booking links as an on-page overlay instead of a new tab.
    document.addEventListener('click', (e) => {
      const t = e.target;
      if (!(t instanceof Element)) return;
      const a = t.closest('a[href*="calendly.com"]');
      if (!a) return;
      // Track the intent to book (button click) — distinct from the completed
      // booking (schedule_appointment fired on calendly.event_scheduled).
      const gg = (window as any).gtag;
      if (typeof gg === 'function') gg('event', 'begin_appointment', { method: 'calendly' });
      const C = (window as any).Calendly;
      if (C && typeof C.initPopupWidget === 'function') {
        e.preventDefault();
        C.initPopupWidget({ url: (a as HTMLAnchorElement).href });
      }
    });

    // Fire a GA event helper (no-op until consent is granted / gtag exists).
    const track = (name, params) => {
      const g = (window as any).gtag;
      if (typeof g === 'function') g('event', name, params || {});
    };

    // Pardot form engagement: the form template posts a "form_start" event
    // when the visitor first focuses a field.
    window.addEventListener('message', (e) => {
      const ev = e.data && typeof e.data === 'object' ? (e.data as any).pardotEvent : null;
      if (ev === 'form_start') track('form_start', { method: 'pardot' });
    });

    // Calendly: fire a conversion when a booking is completed in the overlay.
    window.addEventListener('message', (e) => {
      const d = e.data;
      if (d && typeof d === 'object' && (d as any).event === 'calendly.event_scheduled') {
        track('schedule_appointment', { method: 'calendly' });
      }
    });

    // Auto-resize embedded Pardot form iframes to their content height
    // (the form layout template posts its height via postMessage).
    window.addEventListener('message', (e) => {
      const data = e.data;
      const h = data && typeof data === 'object' ? (data.pardotHeight || data.height) : null;
      if (typeof h !== 'number' || h < 80) return;
      const target = Math.min(Math.round(h), 1800);
      document.querySelectorAll('iframe.pardot-form').forEach((f) => {
        const frame = f as HTMLIFrameElement;
        if (frame.contentWindow !== e.source) return;
        const current = parseInt(frame.style.height) || 0;
        if (Math.abs(target - current) > 4) frame.style.height = target + 'px';
      });
    });

    // Scroll-reveal: reveal elements with .reveal as they enter the viewport.
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const els = document.querySelectorAll('.reveal');
    if (reduce || !('IntersectionObserver' in window)) {
      els.forEach((el) => el.classList.add('in'));
    } else {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('in');
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -60px 0px' });
      els.forEach((el) => io.observe(el));
    }

    // Count-up animation for [data-count] elements.
    const counters = document.querySelectorAll('[data-count]');
    if (counters.length && !reduce && 'IntersectionObserver' in window) {
      const cio = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target;
          const target = parseFloat(el.dataset.count);
          const suffix = el.dataset.suffix || '';
          const dur = 1400;
          const start = performance.now();
          const tick = (now) => {
            const p = Math.min((now - start) / dur, 1);
            const eased = 1 - Math.pow(1 - p, 3);
            el.textContent = Math.round(target * eased) + suffix;
            if (p < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
          cio.unobserve(el);
        });
      }, { threshold: 0.5 });
      counters.forEach((el) => cio.observe(el));
    }
  </script>
</body>
</html>
