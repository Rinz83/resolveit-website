---
import Layout from '../../layouts/Layout.astro';
import ServiceDetail from '../../components/ServiceDetail.astro';
---
<Layout title="Training & Best Practices" description="Gebruikerstraining en admin-certificering zodat uw team Salesforce zelfstandig en met vertrouwen beheert. De beste implementatie verdient de beste adoptie.">
  <ServiceDetail
    eyebrow="Dienst · Training & Best Practices"
    title="Een team dat Salesforce écht omarmt"
    intro="De beste implementatie levert niets op als niemand het systeem gebruikt. Daarom maken wij uw team zelfverzekerd en zelfstandig, van eindgebruiker tot beheerder. Zodat u de regie in eigen huis houdt en het maximale uit uw Salesforce-investering haalt."
    heroStats={[{ num: 'In-house', label: 'kennis & regie' }, { num: 'Op maat', label: 'per rol' }, { num: 'Hogere', label: 'adoptie' }]}
    image="/images/cases/case-5.jpg"
    whatTitle="Adoptie is geen sluitstuk, maar een investering"
    whatText={[
      'Mensen onthouden hoe ze hún werk doen, niet welke knop wat doet. Daarom trainen wij rond concrete dagelijkse taken in plaats van losse functies. Zo blijft de kennis hangen en gaat uw team het systeem echt gebruiken.',
      'Van gebruikerstraining tot geavanceerde admin-certificering: we bouwen kennis op die in uw organisatie blijft. U wordt niet afhankelijk van externen, maar houdt zelf de regie over uw Salesforce-omgeving.',
    ]}
    whatList={[
      'Training afgestemd op rollen en dagelijkse taken',
      'Admin-opleiding voor in-house beheer en certificering',
      'Best practices die fouten voorkomen',
      'Doorlopende coaching en kennisborging',
    ]}
    deliverablesTitle="Wat u krijgt"
    deliverables={[
      { icon: '🎓', title: 'Gebruikerstraining', text: 'Praktische trainingen op maat, zodat iedereen direct productief is.' },
      { icon: '🛠️', title: 'Admin-certificering', text: 'Opgeleide beheerders die Salesforce zelfstandig beheren en aanpassen.' },
      { icon: '📘', title: 'Best practices', text: 'Bewezen werkwijzen en heldere afspraken voor consistent gebruik.' },
      { icon: '🤝', title: 'Doorlopende coaching', text: 'Begeleiding die meegroeit, met documentatie en handleidingen.' },
    ]}
    steps={[
      { title: 'Nulmeting', text: 'We brengen in kaart hoe uw team werkt en waar de grootste kansen liggen om efficiënter te worden.' },
      { title: 'Training op maat', text: 'We trainen rond concrete taken, afgestemd op de rollen binnen uw organisatie.' },
      { title: 'Best practices', text: 'We delen bewezen werkwijzen en richten een gedeelde standaard in voor data en gebruik.' },
      { title: 'Borgen', text: 'Met key users, documentatie en doorlopende coaching blijft de kennis in huis.' },
    ]}
    why={[
      { icon: '🧠', title: 'Kennis die blijft', text: 'We maken u zelfstandig in plaats van afhankelijk. De regie blijft bij u.' },
      { icon: '🎯', title: 'Taakgericht', text: 'We trainen op het werk dat uw mensen écht doen, niet op losse features.' },
      { icon: '🌱', title: 'Blijvende adoptie', text: 'Met key users en periodieke sessies houden we het gebruik op peil.' },
    ]}
    faqs={[
      { q: 'Trainen jullie eindgebruikers én beheerders?', a: 'Ja. We verzorgen gebruikerstraining voor het dagelijks werk en geavanceerde admin-training tot certificering, zodat u Salesforce in-house kunt beheren.' },
      { q: 'Hoe zorgen jullie voor blijvende adoptie?', a: 'We betrekken gebruikers vroeg, trainen taakgericht en zetten key users in als ambassadeurs. Meer hierover in <a href="/blog/eindgebruikers-salesforce-laten-omarmen">eindgebruikers Salesforce laten omarmen</a>.' },
      { q: 'Kunnen jullie training combineren met implementatie?', a: 'Zeker. Training is een vast onderdeel van onze <a href="/diensten/implementatie">implementatie & onboarding</a>, maar ook los af te nemen voor een bestaande omgeving.' },
      { q: 'Wordt de training afgestemd op onze situatie?', a: 'Altijd. We sluiten aan op uw processen, rollen en doelen. <a href="/contact#afspraak">Plan een gesprek</a> om de mogelijkheden te bespreken.' },
    ]}
  />
</Layout>
