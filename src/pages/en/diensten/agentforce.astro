---
import Layout from '../../../layouts/Layout.astro';
import ServiceDetail from '../../../components/ServiceDetail.astro';
---
<Layout
  title="Agentforce Implementation: AI Agents for Salesforce"
  description="Resolve IT implements Salesforce Agentforce: autonomous AI agents that support your sales, service and marketing 24/7. Gold Partner with proven expertise."
  breadcrumbs={[{ name: 'Home', item: '/en' }, { name: 'Services', item: '/en/diensten' }, { name: 'Agentforce', item: '/en/diensten/agentforce' }]}
>
  <ServiceDetail
    lang="en"
    eyebrow="Service · Agentforce"
    title="AI agents that work while your team sleeps"
    intro="Salesforce Agentforce lets you deploy autonomous AI agents across sales, service, marketing and operations: without code, without delays, without human intervention for routine tasks. Resolve IT guides you from strategy to live production."
    heroStats={[{ num: 'AI', label: 'Gold Partner' }, { num: '24/7', label: 'agent availability' }, { num: '300+', label: 'projects' }]}
    image="/images/cases/case-3.jpg"
    whatTitle="Agentforce: far beyond a chatbot"
    whatText={[
      'Agentforce is Salesforce\'s platform for autonomous AI agents that independently complete tasks: handling cases, qualifying leads, drafting quotes and guiding customers, all based on your own business data in Salesforce and Data Cloud.',
      'As a Salesforce Gold Partner, we implement Agentforce tailored to your organisation. We configure the agents, connect your data sources and ensure the AI acts within boundaries you define.',
    ]}
    whatList={[
      'Autonomous agents for service, sales and marketing',
      'Built on your own Salesforce data: no black box',
      'Seamless escalation to a human when needed',
      'Visible and auditable: every action is traceable',
    ]}
    deliverablesTitle="What you get"
    deliverables={[
      { icon: '🤖', title: 'Custom agent design', text: 'We define together which tasks Agentforce takes over and design the agents around your processes.' },
      { icon: '🔗', title: 'Data integration', text: 'Connecting Agentforce to your Salesforce data, external systems and knowledge base.' },
      { icon: '🛡️', title: 'Guardrails & governance', text: 'Clear boundaries for the AI: what can the agent decide independently and when does it escalate?' },
      { icon: '📊', title: 'Monitoring & optimisation', text: 'Dashboard with agent performance, success rates and improvement areas after go-live.' },
    ]}
    steps={[
      { title: 'Use-case workshop', text: 'We identify which processes benefit most from AI automation and where the ROI is highest.' },
      { title: 'Agent configuration', text: 'We build and test the agents in your Salesforce environment, including connections and knowledge base.' },
      { title: 'Pilot & validation', text: 'Agents run in a controlled pilot first. We measure accuracy and adjust guardrails accordingly.' },
      { title: 'Go-live & adoption', text: 'Roll-out to production with team training and a monitoring plan for continuous improvement.' },
    ]}
    why={[
      { icon: '🏅', title: 'Certified Gold Partner', text: 'Resolve IT holds the Salesforce certifications and partner experience to implement Agentforce responsibly.' },
      { icon: '🔒', title: 'Safe and transparent', text: 'We configure only agents that operate on your own data: no unmanaged AI acting outside your control.' },
      { icon: '📈', title: 'Measurable ROI', text: 'We measure the baseline upfront and demonstrate after go-live how much time the agents save versus manual work.' },
    ]}
    faqs={[
      { q: 'What is the difference between Agentforce and Einstein?', a: 'Einstein adds AI insights to existing Salesforce screens (predictions, recommendations). Agentforce is a fully autonomous agent platform that independently performs tasks and makes decisions: a step beyond copilot.' },
      { q: 'Do we need Data Cloud for Agentforce?', a: 'Data Cloud is not mandatory, but strongly recommended. It gives agents access to a unified customer dataset, significantly improving decision quality.' },
      { q: 'Is Agentforce suitable for our mid-sized business?', a: 'Yes. Agentforce is scalable and available for mid-sized organisations too. The highest-ROI use cases are typically customer service automation and lead qualification.' },
      { q: 'How long does an Agentforce implementation take?', a: 'A first agent is typically live within 4–8 weeks. More complex setups with multiple agents and Data Cloud integration take 2–4 months. <a href="/en/contact#afspraak">Schedule a call</a> for a tailored estimate.' },
    ]}
  />
</Layout>
