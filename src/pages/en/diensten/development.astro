---
import Layout from '../../../layouts/Layout.astro';
import ServiceDetail from '../../../components/ServiceDetail.astro';
---
<Layout title="Development & Integrations" description="Custom Salesforce development and integrations with Exact Online, SharePoint, Stripe, DocuSign and more. Connect Salesforce to your entire landscape.">
  <ServiceDetail
    lang="en"
    eyebrow="Service · Development & Integrations"
    title="Connect Salesforce to your entire IT landscape"
    intro="Salesforce becomes truly powerful when it works with the tools you already use. We build custom solutions where standard functionality falls short, and connect your systems to Salesforce via API — robust, secure and often within a few weeks."
    heroStats={[{ num: '10+', label: 'ready-made connectors' }, { num: 'API', label: 'custom possible' }, { num: 'Weeks', label: 'not months' }]}
    image="/images/cases/case-6.jpg"
    whatTitle="One source of truth, no separate islands"
    whatText={[
      'Fragmented systems cost time, money and trust: duplicate data entry, data that diverges and reports no one trusts. We bring your systems together around Salesforce as the central source of truth.',
      'Whether it’s a proven connector to Exact Online, SharePoint or Stripe, or fully custom development for a unique process — we build integrations that are scalable and maintainable, and that grow with your organisation.',
    ]}
    whatList={[
      'Ready-made connectors for Exact Online, SharePoint, Stripe and more',
      'Custom development where standard falls short',
      'Robust error handling, logging and monitoring',
      'Built to be scalable and maintainable',
    ]}
    deliverables={[
      { icon: '🔗', title: 'Working connections', text: 'Integrations with your existing systems, tested and in production.' },
      { icon: '🧩', title: 'Custom functionality', text: 'Tailored solutions where standard Salesforce isn’t enough.' },
      { icon: '🛡️', title: 'Secure connections', text: 'OAuth authentication and encrypted data transfer.' },
      { icon: '📈', title: 'Maintainability', text: 'A setup that grows and stays easy to adjust.' },
    ]}
    steps={[
      { title: 'Analysis', text: 'We map your systems and data flows and determine the source of truth per data type.' },
      { title: 'Design', text: 'We choose the right approach — direct API, middleware or standard connector — and plan error handling and security.' },
      { title: 'Build & test', text: 'We build with proven patterns and test with representative data before go-live.' },
      { title: 'Manage', text: 'With monitoring and logging we keep the connection healthy, and we develop further where needed.' },
    ]}
    why={[
      { icon: '⚙️', title: 'Proven and custom', text: 'We combine ready-made connectors with custom work where your process calls for it.' },
      { icon: '🏆', title: 'Award-winning integrations', text: 'Our Exact connection won the Golden Luca at the highest level (Level 4).' },
      { icon: '🌱', title: 'Long-term partner', text: 'We don’t just build — we stay available for further development and maintenance.' },
    ]}
    faqs={[
      { q: 'Which systems do you connect to?', a: 'Among others Exact Online, SharePoint, OneDrive, Google Drive, Stripe, Aircall, SAP, DocuSign, ChatGPT and Microsoft Teams — and via the API virtually any other system.' },
      { q: 'How long does an integration take?', a: 'Proven connectors are often live within a few weeks. Larger custom integrations run in clear phases.' },
      { q: 'Ready-made or custom — which is better?', a: 'It depends on your situation. We often combine both: a proven connector as the base, with custom work where needed.' },
      { q: 'Is the connection secure?', a: 'Yes. We use OAuth authentication and encrypted connections, with robust error handling and logging. <a href="/en/contact">Get in touch</a> for the details.' },
    ]}
  />
</Layout>
