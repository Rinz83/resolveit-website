---
import Layout from '../../../layouts/Layout.astro';

const services = [
  {
    icon: '/images/Icon-1.svg',
    eyebrow: 'Implementation & Onboarding',
    title: 'A foundation aligned with your strategy',
    href: '/en/diensten/implementatie',
    description: 'Salesforce is hugely powerful, but only when it’s set up in line with your goals and embraced by your team. We guide you from strategy to go-live.',
    steps: [
      { n: 'Discover', t: 'We dive into your processes, goals and pain points, together with the people who work with them every day.' },
      { n: 'Design', t: 'Insight becomes a clear plan: designs, user stories and a roadmap your team can follow.' },
      { n: 'Build', t: 'We build in short sprints, with your organization at the table. Fast results, early adjustments.' },
      { n: 'Elevate', t: 'Go-live is the starting point: training and support mean your team moves forward on its own.' },
    ],
  },
  {
    icon: '/images/Icon-2.svg',
    eyebrow: 'Audit & Consultancy',
    title: 'Get more out of your existing Salesforce',
    href: '/en/diensten/consultancy',
    description: 'Is your Salesforce environment not performing as you hoped? With a free assessment we map opportunities and bottlenecks and set your roadmap to success.',
    steps: [
      { n: 'Quick wins', t: 'Low-effort, high-impact changes for immediate results.' },
      { n: 'Process improvement', t: 'We optimise workflows, automation and the efficiency of your system.' },
      { n: 'Roadmap', t: 'A prioritised plan of features, integrations and customisation that supports growth.' },
    ],
  },
  {
    icon: '/images/Icon-3.svg',
    eyebrow: 'Development & Integrations',
    title: 'Connect Salesforce to your entire landscape',
    href: '/en/diensten/development',
    description: 'Resolve IT helps you succeed with Salesforce, now and in the years ahead. We build custom solutions and connect your systems via API, often within weeks.',
    steps: [
      { n: 'Custom', t: 'Tailored functionality where standard Salesforce falls short.' },
      { n: 'Integrations', t: 'Connections to the tools you already use, robust and maintainable.' },
      { n: 'Evolution', t: 'A long-term partner that grows with your organisation.' },
    ],
  },
  {
    icon: '/images/Icon-4.svg',
    eyebrow: 'Training & Best Practices',
    title: 'A team that truly uses Salesforce',
    href: '/en/diensten/training',
    description: 'The best implementation fails without adoption. With user and admin training we make your team confident and self-reliant, so you keep control in-house.',
    steps: [
      { n: 'User training', t: 'Training around concrete daily tasks, not isolated buttons.' },
      { n: 'Admin training', t: 'We train your administrators to become certified admins.' },
      { n: 'Best practices', t: 'We share proven ways of working so you avoid common mistakes.' },
    ],
  },
];

const integrations = ['Stripe', 'Exact Online', 'SharePoint', 'OneDrive', 'Google Drive', 'Aircall', 'SAP', 'DocuSign', 'ChatGPT', 'Microsoft Teams'];
---

<Layout title="Our services" description="Salesforce implementation, audit & consultancy, development & integrations and training. From strategy to go-live and beyond: Resolve IT guides you every step of the way.">

  <section class="sv-hero">
    <div class="sv-aurora" aria-hidden="true"><span></span><span></span></div>
    <div class="container sv-hero-inner">
      <span class="pp-badge"><span class="pp-badge-dot"></span> Our services</span>
      <h1>Everything for lasting <span class="gradient-text">Salesforce success</span></h1>
      <p>From the first implementation to ongoing optimisation, customisation and training. We're your partner at every step: independent, practical and with proven results.</p>
      <div class="sv-hero-actions">
        <a href="/en/contact#afspraak" class="btn btn-primary">Schedule a call</a>
        <a href="/en/cases" class="btn btn-outline">View cases</a>
      </div>
      <div class="sv-hero-stats">
        <div><strong>300+</strong><span>projects</span></div>
        <div><strong>10+</strong><span>experts</span></div>
        <div><strong>5★</strong><span>AppExchange</span></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="sv-list">
        {services.map((s, i) => (
          <div class={`sv-row ${i % 2 === 1 ? 'reverse' : ''}`}>
            <div class="sv-text reveal">
              <img src={s.icon} alt="" class="sv-icon" width="80" height="61" />
              <span class="eyebrow">{s.eyebrow}</span>
              <h2>{s.title}</h2>
              <p class="text-muted">{s.description}</p>
              <a href={s.href} class="btn btn-outline-dark" style="margin-top:1.25rem;">Learn more</a>
            </div>
            <div class="sv-steps reveal">
              {s.steps.map((st, j) => (
                <div class="sv-step">
                  <span class="sv-step-n">{j + 1}</span>
                  <div><strong>{st.n}</strong><p class="text-muted">{st.t}</p></div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-dark sv-integrations">
    <div class="sv-int-glow" aria-hidden="true"></div>
    <div class="container" style="position:relative;z-index:1;">
      <div class="section-header reveal">
        <span class="eyebrow">Development & Integrations</span>
        <h2 class="text-white">Connect Salesforce to your favourite tools</h2>
        <p style="color:rgba(255,255,255,0.7)">We connect Salesforce to virtually any system, often within weeks, robust and maintainable.</p>
      </div>
      <div class="sv-int-grid reveal">
        {integrations.map(t => <span class="sv-int-chip">{t}</span>)}
      </div>
      <div style="text-align:center;margin-top:2.5rem;">
        <a href="/en/diensten/development" class="btn btn-primary">View development & integrations</a>
      </div>
    </div>
  </section>

  <section class="section bg-off-white">
    <div class="container sv-why">
      <div class="reveal">
        <span class="eyebrow">Our approach</span>
        <h2>Why organisations work with us</h2>
        <p class="text-muted">We combine deep Salesforce expertise with a practical, no-nonsense approach. You’ll notice it in every collaboration.</p>
      </div>
      <ul class="sv-why-grid reveal">
        {[
          { icon: '🎯', t: 'Independent advice', d: 'We advise in your interest, not to sell licences.' },
          { icon: '🧭', t: 'Practical approach', d: 'We think along as a partner and build in short cycles.' },
          { icon: '💬', t: 'Clear communication', d: 'No jargon: you always understand what we do and why.' },
          { icon: '🤝', t: 'Long-term relationship', d: 'We stay involved, also after go-live.' },
          { icon: '🏅', t: 'Certified experts', d: 'A team of certified consultants and developers.' },
          { icon: '🧩', t: 'Custom that fits', d: 'Solutions tailored to your specific situation.' },
        ].map(w => (
          <li class="sv-why-item"><span class="sv-why-ico">{w.icon}</span><div><strong>{w.t}</strong><p class="text-muted">{w.d}</p></div></li>
        ))}
      </ul>
    </div>
  </section>

  <section class="sv-cta bg-dark">
    <div class="sv-cta-glow" aria-hidden="true"></div>
    <div class="container sv-cta-inner reveal">
      <div><h2>Curious what we can do for you?</h2><p>Schedule a no-obligation call: we're happy to think along with you.</p></div>
      <div class="sv-cta-actions">
        <a href="/en/contact#afspraak" class="btn btn-primary">Schedule a call</a>
        <a href="/en/producten/billing-module" class="btn btn-outline">View Billing Platform</a>
      </div>
    </div>
  </section>

</Layout>

<style>
.sv-hero { background: var(--color-dark); color: #fff; padding: 6rem 0 4rem; position: relative; overflow: hidden; text-align: center; }
.sv-aurora { position: absolute; inset: 0; z-index: 0; }
.sv-aurora span { position: absolute; border-radius: 50%; filter: blur(80px); }
.sv-aurora span:nth-child(1) { width: 480px; height: 480px; background: rgba(109,183,87,0.35); top: -160px; left: 10%; animation: drift 20s ease-in-out infinite; }
.sv-aurora span:nth-child(2) { width: 420px; height: 420px; background: rgba(108,68,148,0.35); bottom: -160px; right: 10%; animation: drift 24s ease-in-out infinite reverse; }
.sv-hero-inner { position: relative; z-index: 1; max-width: 760px; margin: 0 auto; }
.sv-hero-inner h1 { color: #fff; font-size: clamp(2.2rem, 5.5vw, 3.6rem); margin-bottom: 1.25rem; }
.sv-hero-inner p { color: rgba(255,255,255,0.8); font-size: 1.15rem; margin-bottom: 2rem; }
.sv-hero-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-bottom: 2.5rem; }
.sv-hero-stats { display: flex; gap: 2.5rem; justify-content: center; }
.sv-hero-stats strong { display: block; font-size: 1.8rem; font-weight: 800; color: var(--color-green-soft); }
.sv-hero-stats span { font-size: 0.82rem; color: rgba(255,255,255,0.6); }
.sv-list { display: flex; flex-direction: column; gap: 5rem; }
.sv-row { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
.sv-row.reverse { direction: rtl; }
.sv-row.reverse > * { direction: ltr; }
@media (max-width: 820px) { .sv-row, .sv-row.reverse { grid-template-columns: 1fr; direction: ltr; gap: 2rem; } }
.sv-icon { height: 60px; width: auto; margin-bottom: 1rem; }
.sv-text h2 { margin-bottom: 0.75rem; }
.sv-steps { display: flex; flex-direction: column; gap: 1rem; }
.sv-step { display: flex; gap: 1rem; align-items: flex-start; background: var(--color-off-white); border: 1px solid var(--color-light); border-radius: var(--radius); padding: 1.1rem 1.35rem; transition: transform var(--transition), box-shadow var(--transition); }
.sv-step:hover { transform: translateX(4px); box-shadow: var(--shadow); }
.sv-step-n { flex-shrink: 0; width: 34px; height: 34px; border-radius: 9px; background: linear-gradient(135deg, var(--color-green), var(--color-green-dark)); color: #fff; font-weight: 800; display: flex; align-items: center; justify-content: center; }
.sv-step strong { display: block; margin-bottom: 0.15rem; }
.sv-step p { font-size: 0.9rem; }
.sv-integrations { position: relative; overflow: hidden; }
.sv-int-glow { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 700px; height: 700px; background: radial-gradient(circle, rgba(109,183,87,0.16), transparent 60%); animation: drift 22s ease-in-out infinite; }
.sv-int-grid { display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center; }
.sv-int-chip { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.14); color: #fff; border-radius: 999px; padding: 0.6rem 1.4rem; font-weight: 600; font-size: 0.9rem; transition: all var(--transition); }
.sv-int-chip:hover { background: rgba(109,183,87,0.18); border-color: rgba(109,183,87,0.5); transform: translateY(-2px); }
.sv-why { display: grid; grid-template-columns: 0.8fr 1.2fr; gap: 3.5rem; align-items: start; }
@media (max-width: 820px) { .sv-why { grid-template-columns: 1fr; gap: 2rem; } }
.sv-why-grid { list-style: none; display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
@media (max-width: 540px) { .sv-why-grid { grid-template-columns: 1fr; } }
.sv-why-item { display: flex; gap: 0.85rem; align-items: flex-start; }
.sv-why-ico { font-size: 1.5rem; flex-shrink: 0; }
.sv-why-item strong { display: block; margin-bottom: 0.2rem; }
.sv-why-item p { font-size: 0.88rem; }
.sv-cta { padding: 4.5rem 0; position: relative; overflow: hidden; }
.sv-cta-glow { position: absolute; top: -50%; right: -10%; width: 500px; height: 500px; background: radial-gradient(circle, rgba(109,183,87,0.25), transparent 60%); animation: drift 18s ease-in-out infinite; }
.sv-cta-inner { display: flex; align-items: center; justify-content: space-between; gap: 3rem; flex-wrap: wrap; position: relative; z-index: 1; }
.sv-cta h2, .sv-cta p { color: #fff; }
.sv-cta p { color: rgba(255,255,255,0.75); margin-top: 0.5rem; }
.sv-cta-actions { display: flex; gap: 1rem; flex-shrink: 0; flex-wrap: wrap; }
</style>
