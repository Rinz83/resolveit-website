---
import Layout from '../../../layouts/Layout.astro';
import FormModal from '../../../components/FormModal.astro';
import { calendlyUrl, pardotForms } from '../../../i18n/ui.js';
import '../../../styles/product.css';

const pillars = [
  {
    icon: '🚀',
    title: 'Implementation',
    text: 'We implement Fin from the ground up: natively in the new Intercom 2 helpdesk, or on the platform you already use, such as Salesforce, Zendesk or Freshdesk. From setup to training Fin on your knowledge base and tone of voice.',
    points: [
      'Implementing Fin on Intercom 2, Salesforce, Zendesk or Freshdesk',
      'Intercom 2 helpdesk setup: inbox, help centre and workflows',
      'Training Fin on your knowledge base, processes and tone of voice',
      'Integrations with your CRM and internal systems, go-live with guidance',
    ],
  },
  {
    icon: '🛡️',
    title: 'Managed Services',
    text: 'After go-live, optimisation keeps paying off: Fin gets better as the knowledge base and settings get sharper. We manage, monitor and continuously improve your environment.',
    points: [
      'Continuous optimisation of Fin resolution rates',
      'Management of knowledge base, workflows and settings',
      'Monthly reporting with improvement recommendations',
      'A dedicated contact who knows your environment',
    ],
  },
];

const steps = [
  { title: 'Intake & AI audit', text: 'We map your service, sales and e-commerce processes, ticket volume and knowledge base and determine where Fin makes the biggest impact.' },
  { title: 'Setup & integrations', text: 'We configure your environment, Intercom 2 or your existing platform, connect your systems and train Fin on your content, tone of voice and escalation paths.' },
  { title: 'Go-live & validation', text: 'A controlled go-live: we validate the quality of Fin’s answers and fine-tune where needed, together with your team.' },
  { title: 'Management & optimisation', text: 'With managed services we keep monitoring, reporting and improving, so the resolution rate keeps climbing.' },
];

const why = [
  { icon: '🥇', title: 'Fin Gold Partner', text: 'As a Gold Partner of Fin (formerly Intercom) we have a direct line to the platform and early access to new features. We are certified on the data model, the REST APIs and historical data migration.' },
  { icon: '🤖', title: 'Hands-on AI expertise', text: 'We build AI solutions every day, from Agentforce to our own AI products. That experience goes into every Fin implementation.' },
  { icon: '🔗', title: 'Strong in integrations', text: 'Fin only reaches its full power with the right data. Fin integrates natively with Salesforce, and we connect the rest of your system landscape, robust and maintainable.' },
];

const faqs = [
  { q: 'What is Fin?', a: 'Fin is the AI Customer Agent from the company of the same name (formerly Intercom). Fin answers service questions automatically based on your knowledge base, supports sales and e-commerce, and hands complex cases over to your team with full context. Fin works natively in Intercom 2 and also runs on Salesforce, Zendesk and Freshdesk.' },
  { q: 'What is the difference between Fin and Intercom?', a: 'Since 12 May 2026, the company behind Intercom is called Fin. The name Intercom lives on for the helpdesk software itself, which has been rebuilt from the ground up and is now called Intercom 2. So Fin is both the company name and the AI agent, which sits natively in Intercom 2 and also works standalone on platforms such as Salesforce, Zendesk and Freshdesk.' },
  { q: 'What does it mean that Resolve IT is a Gold Partner?', a: 'The Gold Partner status is Fin’s (formerly Intercom’s) recognition of partners with proven implementations and certified knowledge. For you it means a direct line to Fin, faster support and a partner who knows the platform inside out.' },
  { q: 'How quickly can Fin go live?', a: 'That depends on the quality of your knowledge base and the number of integrations. A first working setup is usually in place within a few weeks. After that, the resolution rate improves step by step through training and optimisation.' },
  { q: 'Does Fin work with Salesforce?', a: 'Yes. Fin integrates natively with Salesforce, and on 15 June 2026 Salesforce even announced its acquisition of Fin. As a Salesforce partner we also connect Fin to the rest of your Salesforce environment, so conversations, customer data and cases come together. Also see our <a href="/en/diensten/development">development &amp; integrations</a>.' },
  { q: 'What is included in the managed services for Fin?', a: 'Ongoing management of your Fin and Intercom environment: monitoring of answer quality, optimisation of the knowledge base and workflows, monthly reporting and a dedicated contact. We tailor the exact scope to your organisation.' },
  { q: 'Does Fin speak Dutch?', a: 'Yes. Fin works in multiple languages and answers questions in Dutch and English, among others, based on the same knowledge base.' },
  { q: 'We already use Intercom. Can you take over our existing environment?', a: 'Certainly. We start with an audit of your current setup and resolution rates, guide your move to Intercom 2 if desired, and then take over management and optimisation. <a href="#ask">Ask a question</a> to explore the options.' },
];

const faqJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') } })),
});
---

<Layout
  title="Fin: AI Customer Agent for service, sales & e-commerce"
  description="Resolve IT is a Gold Partner of Fin (formerly Intercom). We implement Fin, the AI Customer Agent for service, sales and e-commerce, and manage your environment with managed services."
  breadcrumbs={[{ name: 'Home', item: '/en' }, { name: 'Services', item: '/en/diensten' }, { name: 'Fin AI', item: '/en/diensten/intercom-fin-ai' }]}
>

  <!-- HERO -->
  <section class="pp-hero fin-hero">
    <div class="pp-aurora" aria-hidden="true"><span></span><span></span></div>
    <div class="container pp-hero-inner">
      <div class="pp-hero-copy">
        <div class="fin-badges">
          <span class="pp-badge"><span class="pp-badge-dot"></span> Service · Fin AI Agent</span>
          <span class="pp-badge fin-gold-badge">🥇 Fin Gold Partner</span>
        </div>
        <h1><span class="gradient-text">Fin</span>: the AI Customer Agent for service, sales and e-commerce</h1>
        <p>Fin answers customer questions, supports sales and guides purchases, day and night, in your tone of voice. Natively in Intercom 2 or on your own platform. As a <strong>Gold Partner of Fin</strong> (formerly Intercom) we implement Fin for new customers and keep your environment in top shape with managed services.</p>
        <div class="pp-hero-actions">
          <a href={calendlyUrl} target="_blank" rel="noopener" class="btn btn-primary">Schedule a call</a>
          <a href="#ask" class="btn btn-outline">Ask a question</a>
        </div>
        <div class="fin-hero-logos">
          <div class="fin-logo-chip fin-logo-chip-fin"><img src="/images/logos/fin-ai.svg" alt="Fin AI" /></div>
          <div class="fin-logo-chip"><img src="/images/logos/intercom.svg" alt="Intercom 2" /><span>Intercom 2</span></div>
        </div>
      </div>
      <div class="pp-hero-visual">
        <div class="fin-chat">
          <div class="fin-chat-head">
            <img src="/images/logos/intercom.svg" alt="Intercom 2 messenger" class="fin-chat-ico" />
            <div><strong>Fin</strong><small>AI Customer Agent · online</small></div>
            <span class="fin-chat-status">● Live</span>
          </div>
          <div class="fin-msg fin-msg-user">Can I upgrade my subscription for next month?</div>
          <div class="fin-msg fin-msg-ai">Of course! Your upgrade will take effect from the next billing period. Shall I set it up for you right away?</div>
          <div class="fin-msg fin-msg-user">Yes please!</div>
          <div class="fin-resolved">✓ Resolved automatically by Fin</div>
        </div>
        <div class="fin-gold-float">🥇 <div><strong>Gold Partner</strong><small>Fin</small></div></div>
      </div>
    </div>
  </section>

  <!-- TRUST STRIP -->
  <section class="pp-trust">
    <div class="container pp-trust-grid">
      <div><strong>Gold</strong><span>Fin Partner</span></div>
      <div><strong>24/7</strong><span>AI Customer Agent</span></div>
      <div><strong>3 domains</strong><span>service, sales & e-commerce</span></div>
      <div><strong>2-in-1</strong><span>implementation & management</span></div>
    </div>
  </section>

  <!-- PILLARS -->
  <section class="section bg-off-white">
    <div class="container">
      <div class="section-header reveal">
        <span class="eyebrow">One partner for everything</span>
        <h2>From first implementation to ongoing management</h2>
        <p>Whether you are just starting with Fin, or want to take your existing environment to the next level: we combine both services under one roof.</p>
      </div>
      <div class="fin-pillars">
        {pillars.map((p, i) => (
          <div class="card fin-pillar reveal" style={`--reveal-delay:${i * 0.1}s`}>
            <div class="pp-feature-ico">{p.icon}</div>
            <h3>{p.title}</h3>
            <p class="text-muted">{p.text}</p>
            <ul class="list-check">
              {p.points.map(pt => <li>{pt}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHAT IS FIN -->
  <section class="section">
    <div class="container fin-what">
      <div class="reveal">
        <span class="eyebrow">What is Fin?</span>
        <h2>The AI Customer Agent for your entire customer journey</h2>
        <p class="text-muted">Fin is the AI Customer Agent from the company of the same name (formerly Intercom). Fin reads your knowledge base, help articles and previous conversations and uses them to answer customer questions instantly and accurately, in multiple languages. Questions that need human attention are handed over to your team with full context.</p>
        <p class="text-muted">And Fin goes beyond service alone: the same agent qualifies leads for sales and guides visitors in your webshop to the right purchase. Fin works natively in Intercom 2 and runs on the platforms you already use, such as Salesforce, Zendesk and Freshdesk.</p>
        <ul class="list-check" style="margin-top:1.25rem;">
          <li>Answers questions automatically based on your own content</li>
          <li>Also deployable for sales and e-commerce: from lead qualification to product advice</li>
          <li>Native in Intercom 2, and available on Salesforce, Zendesk and Freshdesk</li>
          <li>Escalates seamlessly to your team, multilingual, and gets better with every optimisation round</li>
        </ul>
      </div>
      <div class="fin-stats-card reveal">
        <img src="/images/logos/fin-ai.svg" alt="Fin AI" class="fin-stats-logo" />
        <div class="fin-stat"><strong>Instant answers</strong><span>no queue for frequently asked questions</span></div>
        <div class="fin-stat"><strong>Service, sales & e-commerce</strong><span>one agent for the entire customer journey</span></div>
        <div class="fin-stat"><strong>Your tone of voice</strong><span>trained on your knowledge base and style</span></div>
      </div>
    </div>
  </section>

  <!-- SALESFORCE ACQUISITION -->
  <section class="section-sm">
    <div class="container">
      <div class="fin-news reveal">
        <div class="fin-news-badge">News</div>
        <div>
          <h3>Salesforce is acquiring Fin</h3>
          <p class="text-muted">On 15 June 2026, Salesforce announced its acquisition of Fin for approximately $3.6 billion; closing is expected in Q4 of fiscal year 2027. For you, this means Fin and Salesforce will only grow closer together. Resolve IT is a <a href="/en/over-ons">Salesforce partner</a> and a Fin Gold Partner, and is already helping you connect both worlds.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- APPROACH -->
  <section class="section bg-dark pp-how">
    <div class="pp-how-glow" aria-hidden="true"></div>
    <div class="container" style="position:relative;z-index:1;">
      <div class="section-header reveal">
        <span class="eyebrow">Our approach</span>
        <h2 class="text-white">How we bring Fin to your customers</h2>
      </div>
      <div class="pp-steps">
        {steps.map((s, i) => (
          <div class="pp-step reveal" style={`--reveal-delay:${i * 0.1}s`}>
            <div class="pp-step-n">{i + 1}</div>
            <h3 class="text-white">{s.title}</h3>
            <p style="color:rgba(255,255,255,0.72)">{s.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY -->
  <section class="section bg-off-white">
    <div class="container">
      <div class="section-header reveal">
        <span class="eyebrow">Why Resolve IT</span>
        <h2>Gold Partner with proven AI experience</h2>
      </div>
      <div class="grid-3">
        {why.map((w, i) => (
          <div class="card pp-feature reveal" style={`--reveal-delay:${(i % 3) * 0.08}s`}>
            <div class="pp-feature-ico">{w.icon}</div>
            <h3>{w.title}</h3>
            <p class="text-muted">{w.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container" style="max-width:820px;">
      <div class="section-header reveal">
        <span class="eyebrow">Frequently asked questions</span>
        <h2>Good to know</h2>
      </div>
      <div class="pp-faq-list">
        {faqs.map(f => (
          <details class="pp-faq reveal"><summary>{f.q}<span class="pp-faq-plus">+</span></summary><p set:html={f.a} /></details>
        ))}
      </div>
    </div>
    <script type="application/ld+json" set:html={faqJsonLd} is:inline />
  </section>

  <!-- CTA -->
  <section class="pp-cta bg-dark">
    <div class="pp-cta-glow" aria-hidden="true"></div>
    <div class="container pp-cta-inner reveal">
      <div>
        <h2>Ready for an AI agent that really works?</h2>
        <p>Schedule a no-obligation call. We will show you what Fin can do for your service, sales and e-commerce.</p>
      </div>
      <div class="pp-cta-actions">
        <a href={calendlyUrl} target="_blank" rel="noopener" class="btn btn-primary">Schedule a call</a>
        <a href="#ask" class="btn btn-outline">Ask a question</a>
      </div>
    </div>
  </section>

  <FormModal id="ask" title="Ask a question" formUrl={pardotForms.askIntercom} />

</Layout>

<style>
/* Hero */
.fin-badges { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-bottom: 1.5rem; }
.fin-badges .pp-badge { margin-bottom: 0; }
.fin-gold-badge { border-color: rgba(240,185,60,0.55); background: rgba(240,185,60,0.14); color: #fff; }
.fin-hero-logos { display: flex; flex-wrap: wrap; gap: 0.85rem; margin-top: 2rem; }
.fin-logo-chip { display: inline-flex; align-items: center; gap: 0.6rem; background: #fff; border-radius: 14px; padding: 0.6rem 1.1rem; font-weight: 700; color: var(--color-text); font-size: 0.9rem; box-shadow: 0 10px 24px rgba(0,0,0,0.25); }
.fin-logo-chip img { height: 26px; width: auto; }
.fin-logo-chip-fin img { height: 34px; }

/* Chat visual */
.pp-hero-visual { position: relative; }
.fin-chat { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.12); border-radius: var(--radius-lg); padding: 1.5rem; display: flex; flex-direction: column; gap: 0.8rem; }
.fin-chat-head { display: flex; align-items: center; gap: 0.7rem; padding-bottom: 0.9rem; border-bottom: 1px solid rgba(255,255,255,0.1); }
.fin-chat-ico { width: 36px; height: 36px; border-radius: 9px; }
.fin-chat-head strong { display: block; color: #fff; font-size: 0.95rem; }
.fin-chat-head small { color: rgba(255,255,255,0.55); font-size: 0.75rem; }
.fin-chat-status { margin-left: auto; color: var(--color-green-soft); font-size: 0.75rem; font-weight: 700; }
.fin-msg { border-radius: 14px; padding: 0.7rem 1rem; font-size: 0.88rem; line-height: 1.45; max-width: 88%; }
.fin-msg-user { background: rgba(255,255,255,0.1); color: #fff; align-self: flex-end; }
.fin-msg-ai { background: #fff; color: var(--color-text); align-self: flex-start; }
.fin-resolved { align-self: flex-end; margin-top: 0.3rem; background: rgba(109,183,87,0.16); border: 1px solid rgba(109,183,87,0.4); color: var(--color-green-soft); font-size: 0.78rem; font-weight: 700; padding: 0.35rem 0.9rem; border-radius: 999px; }
.fin-gold-float { position: absolute; bottom: -16px; left: -14px; background: #fff; border-radius: 14px; padding: 0.65rem 1rem; box-shadow: var(--shadow-lg); display: flex; align-items: center; gap: 0.55rem; font-size: 1.4rem; }
.fin-gold-float strong { display: block; font-size: 0.88rem; color: var(--color-text); }
.fin-gold-float small { font-size: 0.72rem; color: var(--color-text-muted); }

/* Salesforce acquisition news */
.fin-news { display: flex; gap: 1.5rem; align-items: flex-start; background: var(--color-off-white); border: 1px solid var(--color-light); border-radius: var(--radius-lg); padding: 1.75rem 2rem; }
.fin-news-badge { flex-shrink: 0; background: var(--color-green); color: #fff; font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; padding: 0.35rem 0.8rem; border-radius: 999px; margin-top: 0.2rem; }
.fin-news h3 { font-size: 1.15rem; margin-bottom: 0.4rem; }
.fin-news p { margin: 0; font-size: 0.95rem; }
.fin-news :global(a) { color: var(--color-green-dark); font-weight: 600; }
@media (max-width: 560px) { .fin-news { flex-direction: column; gap: 0.85rem; } }

/* Pillars */
.fin-pillars { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
@media (max-width: 820px) { .fin-pillars { grid-template-columns: 1fr; } }
.fin-pillar h3 { font-size: 1.25rem; margin-bottom: 0.5rem; }
.fin-pillar .text-muted { margin-bottom: 1.1rem; }

/* What is Fin */
.fin-what { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 4rem; align-items: center; }
@media (max-width: 860px) { .fin-what { grid-template-columns: 1fr; gap: 2.5rem; } }
.fin-what .text-muted { margin-top: 0.85rem; }
.fin-stats-card { background: var(--color-off-white); border: 1px solid var(--color-light); border-radius: var(--radius-lg); padding: 2rem; display: flex; flex-direction: column; gap: 1.25rem; }
.fin-stats-logo { height: 52px; width: auto; align-self: flex-start; }
.fin-stat strong { display: block; font-size: 1.05rem; color: var(--color-text); }
.fin-stat span { font-size: 0.88rem; color: var(--color-text-muted); }
</style>
