---
import Layout from '../../layouts/Layout.astro';
import { sectors } from '../../data/sectors.js';

const services = [
  { icon: '/images/Icon-1.svg', title: 'Implementation & Onboarding', text: 'Implement Salesforce so it aligns with your strategic goals and delivers value from day one.', href: '/en/diensten/implementatie' },
  { icon: '/images/Icon-2.svg', title: 'Audit & Consultancy', text: 'Optimise your existing Salesforce environment and set a roadmap with quick wins and long-term improvements.', href: '/en/diensten/consultancy' },
  { icon: '/images/Icon-3.svg', title: 'Development & Integrations', text: 'Custom development and connections to tools like Exact Online, SharePoint, Stripe, DocuSign and more.', href: '/en/diensten/development' },
  { icon: '/images/Icon-4.svg', title: 'Training & Best Practices', text: 'User training and admin certification so your team works with Salesforce independently.', href: '/en/diensten/training' },
];

const products = [
  { title: 'Billing Platform', text: 'Invoicing, subscriptions and payments from Salesforce, connected to Stripe, Exact Online and your administration.', badge: 'Managed App', href: '/en/producten/billing-module' },
  { title: 'Datasolver (CoC integration)', text: 'Automatically retrieve and sync company data from the Chamber of Commerce into Salesforce.', badge: 'Managed App', href: '/en/producten/kvk-integratie' },
  { title: 'SignFlow', text: 'Get contracts and quotes digitally signed straight from Salesforce, without an external signing tool.', badge: 'Managed App', href: '/en/producten/signflow' },
  { title: 'Exact Online', text: 'Seamless connection between Salesforce and Exact Online for real-time financial data.', badge: 'Exact Online App Store', href: '/en/producten/exact-online' },
  { title: 'SharePoint Integration', text: 'Manage documents from Salesforce with a direct connection to SharePoint.', badge: 'AppExchange & Microsoft AppSource', href: '/en/producten/sharepoint' },
];

// English labels + descriptions for the industry cards (data/sectors.js is NL).
const industry = {
  'backoffice-services': { label: 'Backoffice Services', desc: 'Invoicing, contracts, projects, time tracking & data enrichment, automated.' },
  'saas': { label: 'SaaS', desc: 'Scalable sales and customer-success processes.' },
  'professional-services': { label: 'Professional Services', desc: 'Projects, hours and invoicing seamlessly connected.' },
  'manufacturing': { label: 'Manufacturing', desc: 'Orders, inventory and production in real time.' },
  'recruitment': { label: 'Recruitment', desc: 'Candidates, vacancies and placements in one pipeline.' },
  'energie-utilities': { label: 'Energy & Utilities', desc: 'Contracts, field service and compliance streamlined.' },
  'media-communicatie': { label: 'Media & Communications', desc: 'Ads, subscribers and content in one system.' },
  'overige-sectoren': { label: 'Other industries', desc: 'Custom Salesforce for every industry.' },
};

const integrations = ['Stripe', 'Exact Online', 'SharePoint', 'OneDrive', 'Google Drive', 'Aircall', 'SAP', 'DocuSign', 'ChatGPT', 'Microsoft Teams', 'Slack', 'HubSpot'];

const clients = [
  { src: '/images/clients/gospooky.png', alt: 'GoSpooky' },
  { src: '/images/clients/aquaplus.svg', alt: 'Aqua+' },
  { src: '/images/clients/magistor.svg', alt: 'Magistor' },
  { src: '/images/clients/comcam.svg', alt: 'ComCam' },
  { src: '/images/clients/genomescan.png', alt: 'GenomeScan' },
  { src: '/images/clients/andmore.png', alt: 'And More Interim' },
  { src: '/images/clients/euroforum.png', alt: 'Euroforum' },
  { src: '/images/clients/werkeninderegio.png', alt: 'Werken in de Regio' },
  { src: '/images/clients/opple.png', alt: 'OPPLE Lighting' },
  { src: '/images/clients/talpa.png', alt: 'Talpa Studios' },
  { src: '/images/clients/multacasting.jpg', alt: 'MULTA Casting' },
  { src: '/images/clients/considerati.png', alt: 'Considerati' },
  { src: '/images/clients/parkbee.png', alt: 'ParkBee' },
  { src: '/images/clients/mediconnect.png', alt: 'MediConnect' },
  { src: '/images/clients/citystone.png', alt: 'Citystone' },
  { src: '/images/clients/zyfer.png', alt: 'Zyfer' },
  { src: '/images/clients/solvid.png', alt: 'Solvid Ondernemen' },
  { src: '/images/clients/admesy.png', alt: 'Admesy' },
  { src: '/images/clients/ioit.png', alt: 'IOIT' },
  { src: '/images/clients/artoffiber.webp', alt: 'Art of Fiber' },
  { src: '/images/clients/autoglassclinic.png', alt: 'Autoglass Clinic' },
  { src: '/images/clients/oranjebemiddelt.png', alt: 'OranjeBemiddelt' },
  { src: '/images/clients/cloudcrossing.svg', alt: 'CloudCrossing' },
  { src: '/images/clients/aquaplus-sprinkler.png', alt: 'Aqua+ Sprinklersystemen' },
  { src: '/images/clients/mokma.jpeg', alt: 'MoneyOak' },
  { src: '/images/clients/silverstone.png', alt: 'Silverstone Real Estate' },
];

const mid = Math.ceil(clients.length / 2);
const row1 = clients.slice(0, mid);
const row2 = clients.slice(mid);
---

<Layout title="Harness the Power of Salesforce" description="Resolve IT helps businesses turn Salesforce into an engine for growth: implementation, integrations, training and consultancy." transparentHeader={true}>

  <!-- HERO -->
  <section class="hero">
    <!-- animated background layers -->
    <div class="hero-aurora" aria-hidden="true">
      <span class="aurora-blob a1"></span>
      <span class="aurora-blob a2"></span>
      <span class="aurora-blob a3"></span>
    </div>
    <div class="hero-grid-overlay" aria-hidden="true"></div>

    <div class="container hero-inner">
      <div class="hero-content">
        <span class="hero-pill"><span class="dot"></span> Salesforce Gold Partner · since 2019</span>
        <h1>Harness the power of<br /><span class="gradient-text">Salesforce</span></h1>
        <p>Resolve IT helps businesses turn Salesforce into an engine for growth, from implementation to integration, training and consultancy.</p>
        <div class="hero-actions">
          <a href="/en/producten" class="btn btn-primary">Our products</a>
          <a href="/en/contact" class="btn btn-outline">Ask a question</a>
        </div>
        <div class="hero-stats">
          <div class="hstat"><span class="hstat-num"><span data-count="300" data-suffix="+">0</span></span><span class="hstat-label">Projects</span></div>
          <div class="hstat"><span class="hstat-num"><span data-count="10" data-suffix="+">0</span></span><span class="hstat-label">Experts</span></div>
          <div class="hstat"><span class="hstat-num">5★</span><span class="hstat-label">AppExchange</span></div>
        </div>
        <div class="hero-partners">
          <span class="hp-badge">★ Salesforce Gold Consultancy Partner</span>
          <span class="hp-badge">⬡ Salesforce ISV Partner</span>
        </div>
      </div>

      <div class="hero-visual">
        <div class="hero-img-wrap">
          <div class="hero-person">
            <div class="hero-person-backdrop" aria-hidden="true"></div>
            <div class="hero-person-ring" aria-hidden="true"></div>
            <img src="/images/hero-person.png" alt="Happy Resolve IT customer working with Salesforce on a laptop" class="hero-person-img" />
          </div>

          <!-- floating glass badges -->
          <div class="float-badge fb-1">
            <span class="fb-icon" style="background:rgba(109,183,87,0.18);color:var(--color-green)">✓</span>
            <div><strong>Salesforce Gold Partner</strong><small>Certified experts</small></div>
          </div>
          <div class="float-badge fb-2">
            <span class="fb-icon" style="background:rgba(108,68,148,0.18);color:#a988d0">↑</span>
            <div><strong>+45% efficiency</strong><small>average result</small></div>
          </div>
        </div>
        <div class="orb orb-green" aria-hidden="true"></div>
        <div class="orb orb-purple" aria-hidden="true"></div>
      </div>
    </div>

    <a href="#diensten" class="scroll-cue" aria-label="Scroll down"><span></span></a>
  </section>

  <!-- INTEGRATIONS MARQUEE -->
  <section class="marquee-band">
    <div class="marquee" aria-hidden="true">
      <div class="marquee-track">
        {[...integrations, ...integrations].map(name => (
          <span class="marquee-item">{name}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="diensten" class="section bg-off-white">
    <div class="container">
      <div class="section-header reveal">
        <span class="eyebrow">Services</span>
        <h2>Everything you need for Salesforce success</h2>
        <p>From implementation to optimisation, we guide you every step of the way.</p>
      </div>
      <div class="grid-4">
        {services.map((s, i) => (
          <a href={s.href} class="service-card card reveal" style={`--reveal-delay:${i * 0.08}s`}>
            <div class="service-icon"><img src={s.icon} alt="" width="80" height="61" loading="lazy" /></div>
            <h3>{s.title}</h3>
            <p class="text-muted">{s.text}</p>
            <span class="card-link">Read more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY RESOLVE IT -->
  <section class="section">
    <div class="container">
      <div class="two-col">
        <div class="reveal">
          <span class="eyebrow">Why Resolve IT?</span>
          <h2>Our approach makes the difference</h2>
          <p class="text-muted" style="margin-bottom:2rem;">We combine deep Salesforce expertise with a practical, no-nonsense approach that truly works for your organisation.</p>
          <ul class="list-check">
            <li>Independent advice with no hidden agenda</li>
            <li>Practical approach: we think along as a partner</li>
            <li>Crystal-clear communication, no jargon</li>
            <li>Long-term collaboration, also after go-live</li>
            <li>Certified Salesforce experts on your team</li>
            <li>Tailored solutions for your specific situation</li>
          </ul>
          <div style="margin-top:2rem;">
            <a href="/en/over-ons" class="btn btn-outline-dark">More about us</a>
          </div>
        </div>
        <div class="value-grid">
          {[
            { num: 2019, suffix: '', label: 'Founded', plain: true },
            { num: 300, suffix: '+', label: 'Projects completed' },
            { num: 10, suffix: '+', label: 'Certified experts' },
            { num: 5, suffix: '★', label: 'AppExchange rating', plain: true },
          ].map((v, i) => (
            <div class="value-item reveal" style={`--reveal-delay:${i * 0.1}s`}>
              <span class="value-num">
                {v.plain ? `${v.num}${v.suffix}` : <span data-count={v.num} data-suffix={v.suffix}>0</span>}
              </span>
              <span class="value-label">{v.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- BILLING PLATFORM SPOTLIGHT -->
  <section class="section bp-spotlight">
    <div class="container bp-inner">
      <div class="bp-copy reveal">
        <span class="eyebrow">Featured · Billing Platform</span>
        <h2>One platform for invoicing, subscriptions &amp; payments</h2>
        <p class="text-muted">The heart of your order-to-cash in Salesforce. Create and send invoices, manage subscriptions and MRR, and collect payments automatically, seamlessly connected to the tools you already use.</p>
        <ul class="bp-list">
          <li><strong>Invoicing</strong><span>Custom PDF invoices, generated and sent automatically</span></li>
          <li><strong>Subscription management</strong><span>Recurring billing with real-time MRR insight</span></li>
          <li><strong>Payments</strong><span>Automatic collection via Stripe (card, SEPA, PayPal)</span></li>
          <li><strong>Receivables</strong><span>Automated reminders &amp; outstanding items</span></li>
        </ul>
        <div class="bp-actions">
          <a href="/en/producten/billing-module" class="btn btn-primary">Discover the Billing Platform</a>
          <a href="/en/contact#afspraak" class="btn btn-outline-dark">Request a demo</a>
        </div>
      </div>

      <div class="bp-hub reveal" aria-label="The Billing Platform connects with Stripe, Exact Online, Datasolver and SharePoint">
        <div class="bp-center">
          <span class="bp-center-ico">💶</span>
          <span>Billing Platform</span>
        </div>
        <a href="/en/producten/exact-online" class="bp-node bp-n1"><img class="bp-logo bp-logo-wide" src="/images/logos/exact-online.svg" alt="Exact Online" /></a>
        <a href="/en/producten/billing-module" class="bp-node bp-n2"><span class="bp-stripe">Stripe</span> Payments</a>
        <a href="/en/producten/kvk-integratie" class="bp-node bp-n3"><span>🏢</span> Datasolver</a>
        <a href="/en/producten/sharepoint" class="bp-node bp-n4"><img class="bp-logo" src="/images/logos/sharepoint.svg" alt="SharePoint" /> SharePoint</a>
        <svg class="bp-lines" viewBox="0 0 320 320" aria-hidden="true">
          <line x1="160" y1="160" x2="60" y2="60"/><line x1="160" y1="160" x2="260" y2="60"/>
          <line x1="160" y1="160" x2="60" y2="260"/><line x1="160" y1="160" x2="260" y2="260"/>
        </svg>
      </div>
    </div>
  </section>

  <!-- PRODUCTS -->
  <section class="section bg-dark products-section">
    <div class="products-glow" aria-hidden="true"></div>
    <div class="container" style="position:relative;z-index:1;">
      <div class="section-header reveal">
        <span class="eyebrow">Products</span>
        <h2 class="text-white">Smart Salesforce extensions</h2>
        <p style="color:rgba(255,255,255,0.7)">Our own products on the Salesforce AppExchange, ready to use, proven effective.</p>
      </div>
      <div class="grid-2">
        {products.map((p, i) => (
          <a href={p.href} class="product-card-dark reveal" style={`--reveal-delay:${i * 0.08}s`}>
            <div class="product-card-top"><span class="badge">{p.badge}</span></div>
            <h3 class="text-white">{p.title}</h3>
            <p style="color:rgba(255,255,255,0.7)">{p.text}</p>
            <span class="card-link">View product →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- INDUSTRIES -->
  <section class="section">
    <div class="container">
      <div class="section-header reveal">
        <span class="eyebrow">Industries</span>
        <h2>Industry-specific Salesforce solutions</h2>
        <p>Every sector has its own challenges. We understand yours and deliver solutions that truly work.</p>
      </div>
      <div class="sector-grid">
        {sectors.map((s, i) => (
          <a href={`/en${s.href}`} class="sector-card reveal" style={`--reveal-delay:${(i % 4) * 0.07}s`}>
            <span class="sector-ico" set:html={s.svg} />
            <span class="sector-name">{industry[s.slug].label}</span>
            <span class="sector-desc">{industry[s.slug].desc}</span>
            <span class="sector-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CLIENTS (tile wall) -->
  <section class="section bg-off-white">
    <div class="container">
      <div class="section-header reveal" style="margin-bottom:2.5rem;">
        <span class="eyebrow">Our clients</span>
        <h2>Trusted by leading organisations</h2>
        <p>From scale-ups to established names, organisations across many sectors build on Salesforce with us.</p>
      </div>
    </div>
    <div class="client-carousel">
      <div class="client-row">
        <div class="client-row-track">
          {[...row1, ...row1].map(c => (
            <div class="client-tile"><img src={c.src} alt={c.alt} title={c.alt} loading="lazy" /></div>
          ))}
        </div>
      </div>
      <div class="client-row">
        <div class="client-row-track reverse">
          {[...row2, ...row2].map(c => (
            <div class="client-tile"><img src={c.src} alt={c.alt} title={c.alt} loading="lazy" /></div>
          ))}
        </div>
      </div>
    </div>
    <p class="clients-more">…and many others</p>
  </section>

  <!-- CTA STRIP -->
  <section class="cta-strip bg-dark">
    <div class="cta-glow" aria-hidden="true"></div>
    <div class="container cta-strip-inner reveal">
      <div>
        <h2>Ready to unlock the full potential of Salesforce?</h2>
        <p>Get in touch for a no-obligation conversation, or book a meeting directly.</p>
      </div>
      <div class="cta-strip-actions">
        <a href="/en/contact#afspraak" class="btn btn-primary">Book a meeting</a>
        <a href="/en/contact" class="btn btn-outline">Ask a question</a>
      </div>
    </div>
  </section>

</Layout>

<style>
/* ============ HERO ============ */
.hero {
  background: var(--color-dark);
  color: var(--color-white);
  padding: 7rem 0 7rem;
  position: relative;
  overflow: hidden;
  isolation: isolate;
}

/* animated aurora blobs */
.hero-aurora { position: absolute; inset: 0; z-index: 0; overflow: hidden; }
.aurora-blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(70px);
  opacity: 0.55;
}
.aurora-blob.a1 { width: 520px; height: 520px; background: rgba(109,183,87,0.45); top: -160px; left: -120px; animation: drift 18s ease-in-out infinite; }
.aurora-blob.a2 { width: 460px; height: 460px; background: rgba(108,68,148,0.42); bottom: -180px; right: -80px; animation: drift 22s ease-in-out infinite reverse; }
.aurora-blob.a3 { width: 360px; height: 360px; background: rgba(109,183,87,0.22); top: 40%; left: 45%; animation: aurora 26s ease-in-out infinite; }

/* dot grid overlay */
.hero-grid-overlay {
  position: absolute; inset: 0; z-index: 0;
  background-image: radial-gradient(rgba(255,255,255,0.07) 1px, transparent 1px);
  background-size: 32px 32px;
  mask-image: radial-gradient(ellipse 80% 60% at 50% 40%, #000 30%, transparent 75%);
  -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 40%, #000 30%, transparent 75%);
}

.hero-inner {
  display: grid;
  grid-template-columns: 1.05fr 0.95fr;
  gap: 4rem;
  align-items: center;
  position: relative;
  z-index: 1;
}

.hero-pill {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.15);
  backdrop-filter: blur(8px);
  padding: 0.45rem 1rem;
  border-radius: var(--radius-pill);
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  color: rgba(255,255,255,0.85);
  margin-bottom: 1.5rem;
}
.hero-pill .dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--color-green);
  box-shadow: 0 0 0 0 rgba(109,183,87,0.7);
  animation: pulse-ring 2s ease-out infinite;
}

.hero-content h1 { color: var(--color-white); margin-bottom: 1.25rem; font-size: clamp(2.4rem, 5.5vw, 4rem); }
.hero-content p {
  color: rgba(255,255,255,0.78);
  font-size: 1.18rem;
  margin-bottom: 2rem;
  max-width: 520px;
}
.hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 2.75rem; }

.hero-stats { display: flex; gap: 2.75rem; }
.hstat { display: flex; flex-direction: column; gap: 0.15rem; }
.hstat-num { font-size: 2.1rem; font-weight: 800; color: var(--color-green-soft); line-height: 1; }
.hstat-label { font-size: 0.82rem; color: rgba(255,255,255,0.6); }

.hero-partners { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-top: 1.75rem; }
.hp-badge {
  display: inline-flex; align-items: center; gap: 0.4rem;
  background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.18);
  border-radius: var(--radius-pill); padding: 0.4rem 0.9rem;
  font-size: 0.78rem; font-weight: 600; color: rgba(255,255,255,0.9);
}

/* hero visual */
.hero-visual { position: relative; }
.hero-img-wrap {
  position: relative;
  z-index: 2;
  animation: float-y 7s ease-in-out infinite;
}
/* ===== Hero person composition ===== */
.hero-person { position: relative; display: flex; align-items: flex-end; justify-content: center; }
.hero-person-backdrop {
  position: absolute; left: 50%; top: 46%; transform: translate(-50%, -50%);
  width: 360px; height: 360px; border-radius: 50%;
  background: radial-gradient(circle at 35% 30%, rgba(109,183,87,0.95), rgba(108,68,148,0.9) 75%);
  filter: blur(2px);
}
.hero-person-ring {
  position: absolute; left: 50%; top: 46%; transform: translate(-50%, -50%);
  width: 420px; height: 420px; border-radius: 50%;
  border: 1.5px dashed rgba(255,255,255,0.25);
  animation: spin-slow 40s linear infinite;
}
@keyframes spin-slow { to { transform: translate(-50%, -50%) rotate(360deg); } }
.hero-person-img {
  position: relative; z-index: 1;
  width: 100%; max-width: 440px; height: auto; display: block;
  filter: drop-shadow(0 28px 40px rgba(0,0,0,0.5));
}
@media (max-width: 820px) { .hero-person-backdrop { width: 300px; height: 300px; } .hero-person-ring { width: 350px; height: 350px; } }

.float-badge {
  position: absolute;
  z-index: 3;
  display: flex;
  align-items: center;
  gap: 0.65rem;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(10px);
  border-radius: 14px;
  padding: 0.7rem 1rem;
  box-shadow: 0 12px 30px rgba(0,0,0,0.22);
}
.float-badge strong { display: block; font-size: 0.85rem; color: var(--color-text); line-height: 1.2; }
.float-badge small { font-size: 0.72rem; color: var(--color-text-muted); }
.fb-icon {
  width: 34px; height: 34px; border-radius: 9px;
  display: flex; align-items: center; justify-content: center;
  font-weight: 700; font-size: 1rem;
}
.fb-1 { top: 18%; left: -38px; animation: float-y 5.5s ease-in-out infinite; }
.fb-2 { bottom: 16%; right: -30px; animation: float-y 6.5s ease-in-out infinite 0.6s; }

.orb { position: absolute; border-radius: 50%; filter: blur(6px); z-index: 1; }
.orb-green { width: 120px; height: 120px; background: rgba(109,183,87,0.55); bottom: -28px; left: -30px; animation: drift 14s ease-in-out infinite; }
.orb-purple { width: 90px; height: 90px; background: rgba(108,68,148,0.55); top: -26px; right: 30px; animation: drift 16s ease-in-out infinite reverse; }

/* scroll cue */
.scroll-cue {
  position: absolute;
  bottom: 1.5rem; left: 50%;
  transform: translateX(-50%);
  width: 26px; height: 42px;
  border: 2px solid rgba(255,255,255,0.35);
  border-radius: 14px;
  z-index: 2;
  display: flex;
  justify-content: center;
}
.scroll-cue span {
  width: 4px; height: 8px;
  background: var(--color-green);
  border-radius: 2px;
  margin-top: 7px;
  animation: scroll-dot 1.8s ease-in-out infinite;
}
@keyframes scroll-dot {
  0% { opacity: 0; transform: translateY(-4px); }
  40% { opacity: 1; }
  80% { opacity: 0; transform: translateY(12px); }
  100% { opacity: 0; }
}

@media (max-width: 820px) {
  .hero-inner { grid-template-columns: 1fr; gap: 3.5rem; }
  .hero { padding: 4.5rem 0 5rem; }
  .hero-stats { gap: 1.75rem; }
  .float-badge { display: none; }
  .scroll-cue { display: none; }
}

/* ============ INTEGRATIONS MARQUEE ============ */
.marquee-band {
  background: var(--color-dark-2);
  padding: 1.1rem 0;
  overflow: hidden;
