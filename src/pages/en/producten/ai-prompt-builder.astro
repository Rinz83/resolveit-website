---
import Layout from '../../../layouts/Layout.astro';
import { calendlyUrl } from '../../../i18n/ui.js';
import '../../../styles/product.css';

const features = [
  { icon: '🤖', title: 'AI natively in your Flow', text: 'Call an AI model as an invocable action — no code, no external middleware. Works in Screen Flows, Record-Triggered Flows, and Auto-Launched Flows.' },
  { icon: '📝', title: 'Dynamic Prompt Templates', text: 'Build prompt templates that combine merge fields with fixed instruction text. Pull live data from record variables, GET requests, or any other Salesforce data source.' },
  { icon: '🔌', title: 'Multiple AI models', text: 'Choose the model that fits your use case: OpenAI, Anthropic, Google Gemini, Azure Co-Pilot, or your own LLM — the connector handles the rest.' },
  { icon: '⚡', title: 'All Flow types supported', text: 'Use AI logic in every type of Salesforce Flow: from user-driven screens to fully automated background processes.' },
  { icon: '🔄', title: 'Context-rich responses', text: 'Feed the AI only relevant data: account details, website content, case information. The richer the context, the more relevant the output.' },
  { icon: '💡', title: 'Bring your own LLM — zero callout cost', text: 'Connect your own Large Language Model and pay only the fixed monthly platform fee — no per-callout charges.' },
];

const steps = [
  { n: '1', title: 'Model your Flow', text: 'Define the purpose of your Flow: which trigger starts the process, which data inputs you need, and what the AI action should deliver.' },
  { n: '2', title: 'Build your Prompt Template', text: 'Combine fixed instruction text with dynamic merge fields like {Account.Name} or {GET_Response.Website} — directly available as a Flow resource.' },
  { n: '3', title: 'Use the AI output', text: 'The AI response is returned as a variable in your Flow. Use it as input for the next action, a record update, or a screen component.' },
  { n: '4', title: 'Complete your Flow', text: 'Display the output on a screen, save it to a field, send an email, or pass it to the next step — your Flow, your logic.' },
];

const models = [
  { name: 'OpenAI', icon: '🟢' },
  { name: 'Anthropic', icon: '🟣' },
  { name: 'Google Gemini', icon: '🔵' },
  { name: 'Azure Co-Pilot', icon: '🔷' },
  { name: 'Own LLM', icon: '⚙️' },
];

const faqs = [
  { q: 'Does our team need technical expertise to use this?', a: 'No. The AI Prompt Builder works as a standard invocable action in Salesforce Flow. Anyone with Flow experience can get started immediately — no Apex or API knowledge required.' },
  { q: 'Which AI models does the Prompt Builder support?', a: 'The current release supports OpenAI, Anthropic (Claude), Google Gemini, and Azure Co-Pilot. Custom LLM connections are also possible. Additional models are continuously being added.' },
  { q: 'Can I use the output of an AI action as input for the next step?', a: 'Yes. The response is returned as a Flow variable and is immediately available as a resource: for a screen component, a record update, an email, or a follow-up action.' },
  { q: 'How is our data and prompts secured?', a: 'The Prompt Builder works as a Managed Package within your Salesforce environment. Data passes through the secure Salesforce API layer. The AI model you choose determines which privacy and data retention policy applies.' },
  { q: 'What does it cost?', a: 'There is a fixed monthly fee of €150 including 1,500 callouts. Additional callouts are billed from €0.10 per call, with volume discounts for larger usage. If you use your own LLM, there are no per-callout charges. Contact us for custom pricing.' },
  { q: 'How do I install the Prompt Builder?', a: 'The AI Prompt Builder is a Salesforce Managed Package. Resolve IT handles the installation, configuration, and training so your team is productive from day one.' },
];

const faqJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') } })),
});
---

<Layout
  breadcrumbs={[{ name: 'Home', item: '/en' }, { name: 'Products', item: '/en/producten' }, { name: 'AI Prompt Builder', item: '/en/producten/ai-prompt-builder' }]}
  title="AI Prompt Builder — AI models natively in your Salesforce Flow"
  description="Integrate OpenAI, Anthropic, Gemini or your own LLM directly into Salesforce Flows. The AI Prompt Builder makes AI a native part of your automation — without any code."
>
  <script type="application/ld+json" set:html={faqJsonLd} />

  <!-- HERO -->
  <section class="pp-hero">
    <div class="pp-aurora" aria-hidden="true"><span></span><span></span></div>
    <div class="container pp-hero-inner">
      <div class="pp-hero-copy">
        <span class="pp-badge"><span class="pp-badge-dot"></span> AI Prompt Builder · Managed Package</span>
        <h1>AI natively in your <span class="gradient-text">Salesforce Flow</span></h1>
        <p>Combine the power of leading AI models with your Salesforce data — through a simple invocable action. No code, no external middleware. Just: your Flow, your prompt, your AI.</p>
        <div class="pp-hero-actions">
          <a href="/en/contact#afspraak" class="btn btn-primary">Schedule a demo</a>
          <a href="/en/contact" class="btn btn-outline">Ask a question</a>
        </div>
      </div>
      <div class="pp-hero-visual">
        <div class="aipb-flow">
          <div class="aipb-flow-node aipb-start">
            <span class="aipb-node-icon">▶</span>
            <div><strong>Screen Flow</strong><span>Start</span></div>
          </div>
          <div class="aipb-connector"></div>
          <div class="aipb-flow-node">
            <span class="aipb-node-icon aipb-pink">🔍</span>
            <div><strong>Get Account</strong><span>Get Records from CRM</span></div>
          </div>
          <div class="aipb-connector"></div>
          <div class="aipb-flow-node aipb-highlight">
            <span class="aipb-node-icon aipb-green">🤖</span>
            <div><strong>AI Prompt Builder</strong><span>Apex Action</span></div>
          </div>
          <div class="aipb-connector"></div>
          <div class="aipb-flow-node">
            <span class="aipb-node-icon aipb-blue">🖥</span>
            <div><strong>ResponseScreen</strong><span>Screen</span></div>
          </div>
          <div class="aipb-connector"></div>
          <div class="aipb-flow-node">
            <span class="aipb-node-icon aipb-pink">✏️</span>
            <div><strong>Update Record</strong><span>Update Records</span></div>
          </div>
          <div class="aipb-connector"></div>
          <div class="aipb-flow-node aipb-end">
            <span class="aipb-node-icon aipb-red">⏹</span>
            <div><strong>End</strong></div>
          </div>
        </div>
        <div class="aipb-prompt-preview">
          <div class="aipb-prompt-label">Prompt Template</div>
          <div class="aipb-prompt-body" set:html={`Can you make a summary of the goods and services <span class="aipb-merge">{!Account.Name}</span> offers? You can also retrieve information from <span class="aipb-merge">{!Account.Website}</span>. Output in HTML.`} />
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST STRIP -->
  <section class="pp-trust">
    <div class="container">
      <div class="pp-trust-grid">
        <div><strong>5+</strong><span>supported AI models</span></div>
        <div><strong>€0.10</strong><span>per callout (pay-per-use)</span></div>
        <div><strong>1,500</strong><span>callouts included/month</span></div>
        <div><strong>All</strong><span>Salesforce Flow types</span></div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="section">
    <div class="container">
      <div class="section-header reveal">
        <span class="eyebrow">Capabilities</span>
        <h2>AI as a native part of your automation</h2>
        <p>The AI Prompt Builder brings intelligence to every step of your Salesforce Flow — without your team writing a single line of code.</p>
      </div>
      <div class="grid-3 mt-xl">
        {features.map((f, i) => (
          <div class="pp-feature reveal" style={`--reveal-delay:${i * 0.08}s`}>
            <div class="pp-feature-ico">{f.icon}</div>
            <h3>{f.title}</h3>
            <p>{f.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="section bg-dark pp-how">
    <div class="pp-how-glow" aria-hidden="true"></div>
    <div class="container" style="position:relative;z-index:1">
      <div class="section-header reveal">
        <span class="eyebrow" style="color:var(--color-green-soft)">How it works</span>
        <h2 style="color:#fff">From Flow idea to AI automation in 4 steps</h2>
      </div>
      <div class="pp-steps mt-xl">
        {steps.map((s, i) => (
          <div class="pp-step reveal" style={`--reveal-delay:${i * 0.1}s`}>
            <div class="pp-step-n">{s.n}</div>
            <h3>{s.title}</h3>
            <p style="color:rgba(255,255,255,0.65);font-size:0.92rem">{s.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- MODELS -->
  <section class="section bg-off-white">
    <div class="container">
      <div class="section-header reveal">
        <span class="eyebrow">Supported models</span>
        <h2>Choose the model that fits your use case</h2>
        <p>The AI Prompt Builder connects to the leading AI platforms. Have your own LLM? We'll connect that too.</p>
      </div>
      <div class="aipb-models reveal">
        {models.map(m => (
          <div class="aipb-model-chip">
            <span>{m.icon}</span>
            <span>{m.name}</span>
          </div>
        ))}
        <div class="aipb-model-chip aipb-model-soon">
          <span>🔜</span>
          <span>More coming soon</span>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section class="section">
    <div class="container">
      <div class="section-header reveal">
        <span class="eyebrow">Pricing</span>
        <h2>Transparent, scalable pricing</h2>
        <p>Start small and scale as your usage grows. Large volumes? Contact us for a volume discount.</p>
      </div>
      <div class="aipb-pricing mt-xl">
        <div class="aipb-price-card reveal">
          <div class="aipb-price-label">Monthly subscription</div>
          <div class="aipb-price-amount"><span class="aipb-price-currency">€</span>150<span class="aipb-price-period">/mo</span></div>
          <ul class="aipb-price-features">
            <li>✓ 1,500 callouts per month included</li>
            <li>✓ Access to all supported AI models</li>
            <li>✓ Salesforce Managed Package</li>
            <li>✓ Updates & maintenance included</li>
          </ul>
        </div>
        <div class="aipb-price-card reveal" style="--reveal-delay:0.1s">
          <div class="aipb-price-label">Additional callouts</div>
          <div class="aipb-price-amount"><span class="aipb-price-currency">€</span>0.10<span class="aipb-price-period">/callout</span></div>
          <ul class="aipb-price-features">
            <li>✓ Pay only for what you use</li>
            <li>✓ Volume discounts for higher usage</li>
            <li>✓ Monthly invoice via Salesforce</li>
          </ul>
        </div>
        <div class="aipb-price-card aipb-price-own reveal" style="--reveal-delay:0.2s">
          <div class="aipb-price-label">Own LLM</div>
          <div class="aipb-price-amount aipb-price-free">No callout charges</div>
          <ul class="aipb-price-features">
            <li>✓ Connect your own Large Language Model</li>
            <li>✓ Only the fixed monthly platform fee</li>
            <li>✓ Full control over your data</li>
          </ul>
        </div>
      </div>
      <p class="aipb-price-note">Contact your account manager for custom rates and volume discounts.</p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section bg-off-white">
    <div class="container">
      <div class="section-header reveal">
        <span class="eyebrow">Frequently asked questions</span>
        <h2>Everything you need to know about the AI Prompt Builder</h2>
      </div>
      <div class="faq-list mt-xl">
        {faqs.map((f, i) => (
          <details class="faq-item reveal" style={`--reveal-delay:${i * 0.06}s`}>
            <summary class="faq-q">{f.q}</summary>
            <div class="faq-a" set:html={f.a} />
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="pp-cta bg-dark">
    <div class="pp-cta-glow" aria-hidden="true"></div>
    <div class="container pp-cta-inner reveal">
      <div>
        <h2>Ready to bring AI into your Flows?</h2>
        <p>We handle installation, configuration, and training so your team is productive from day one.</p>
      </div>
      <div class="pp-hero-actions">
        <a href="/en/contact#afspraak" class="btn btn-primary">Schedule a demo</a>
        <a href={calendlyUrl} target="_blank" rel="noopener" class="btn btn-outline">Book a meeting</a>
      </div>
    </div>
  </section>

</Layout>

<style>
.aipb-flow {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: var(--radius-lg);
  padding: 1.5rem 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 0;
  max-width: 280px;
  margin: 0 auto;
}
.aipb-flow-node {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 10px;
  padding: 0.7rem 1rem;
}
.aipb-flow-node.aipb-highlight {
  background: rgba(109,183,87,0.18);
  border-color: rgba(109,183,87,0.45);
  box-shadow: 0 0 16px rgba(109,183,87,0.2);
}
.aipb-flow-node.aipb-start, .aipb-flow-node.aipb-end { background: rgba(255,255,255,0.04); }
.aipb-flow-node div { display: flex; flex-direction: column; line-height: 1.3; }
.aipb-flow-node strong { font-size: 0.82rem; color: #fff; }
.aipb-flow-node span { font-size: 0.72rem; color: rgba(255,255,255,0.55); }
.aipb-node-icon { font-size: 1.1rem; width: 28px; text-align: center; flex-shrink: 0; }
.aipb-node-icon.aipb-pink { color: #e96c9c; }
.aipb-node-icon.aipb-green { color: #6db757; }
.aipb-node-icon.aipb-blue { color: #4da8d8; }
.aipb-node-icon.aipb-red { color: #e05252; }
.aipb-connector { width: 2px; height: 18px; background: rgba(255,255,255,0.18); margin: 0 auto; }
.aipb-prompt-preview {
  margin-top: 1rem;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.14);
  border-radius: 10px;
  padding: 1rem;
  max-width: 280px;
  margin-inline: auto;
}
.aipb-prompt-label { font-size: 0.72rem; color: var(--color-green-soft); font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 0.5rem; }
.aipb-prompt-body { font-size: 0.8rem; color: rgba(255,255,255,0.75); line-height: 1.6; font-family: monospace; }
.aipb-merge { color: var(--color-green-soft); background: rgba(109,183,87,0.15); border-radius: 3px; padding: 0 3px; }
.aipb-models { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; margin-top: 2.5rem; }
.aipb-model-chip {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.65rem 1.25rem;
  background: var(--color-white);
  border: 1px solid var(--color-light);
  border-radius: var(--radius-pill);
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--color-text);
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}
.aipb-model-soon { opacity: 0.5; font-style: italic; }
.aipb-pricing { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
@media (max-width: 760px) { .aipb-pricing { grid-template-columns: 1fr; } }
.aipb-price-card {
  background: var(--color-white);
  border: 1px solid var(--color-light);
  border-radius: var(--radius-lg);
  padding: 2rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}
.aipb-price-card.aipb-price-own {
  border-color: rgba(109,183,87,0.4);
  background: linear-gradient(135deg, rgba(109,183,87,0.05), rgba(108,68,148,0.04));
}
.aipb-price-label { font-size: 0.82rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-text-muted); }
.aipb-price-amount { font-size: 2.2rem; font-weight: 800; color: var(--color-text); line-height: 1; }
.aipb-price-free { font-size: 1.4rem; color: var(--color-green-dark); }
.aipb-price-currency { font-size: 1.3rem; vertical-align: top; margin-top: 0.35rem; display: inline-block; }
.aipb-price-period { font-size: 0.9rem; font-weight: 500; color: var(--color-text-muted); margin-left: 0.15rem; }
.aipb-price-features { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
.aipb-price-features li { font-size: 0.88rem; color: var(--color-text-muted); }
.aipb-price-note { text-align: center; margin-top: 1.5rem; font-size: 0.88rem; color: var(--color-text-muted); }
.pp-cta { padding: 5rem 0; position: relative; overflow: hidden; }
.pp-cta-glow { position: absolute; top: 50%; right: 0; transform: translateY(-50%); width: 600px; height: 600px; background: radial-gradient(circle, rgba(109,183,87,0.2), transparent 60%); animation: drift 20s ease-in-out infinite; }
.pp-cta-inner { display: flex; align-items: center; justify-content: space-between; gap: 3rem; flex-wrap: wrap; position: relative; z-index: 1; }
.pp-cta h2, .pp-cta p { color: #fff; }
.pp-cta p { color: rgba(255,255,255,0.72); margin-top: 0.5rem; }
</style>
