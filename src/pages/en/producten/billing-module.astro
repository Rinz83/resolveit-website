---
import Layout from '../../../layouts/Layout.astro';
import FormModal from '../../../components/FormModal.astro';
import { calendlyUrl, pardotForms } from '../../../i18n/ui.js';
import '../../../styles/product.css';

const features = [
  { icon: '🧾', title: 'Automatic invoices', text: 'Generate PDF invoices based on product type, language and location, straight from Salesforce, in your own house style.' },
  { icon: '🔁', title: 'Subscriptions & MRR', text: 'Sell subscriptions from Opportunities with monthly, quarterly or annual intervals. Real-time insight into your Monthly Recurring Revenue.' },
  { icon: '💳', title: 'Automatic collection', text: 'Our Payment Collection App connects Salesforce to Stripe. Manage credit cards, direct debit and PayPal, and collect automatically.' },
  { icon: '⏰', title: 'Automated reminders', text: 'Payment reminders are sent automatically at the right moments. Less manual work, faster payment.' },
  { icon: '📅', title: 'Revenue allocation', text: 'Assign invoices to a specific month with start and end dates on invoice lines, for clean revenue recognition.' },
  { icon: '📊', title: 'Reports & dashboards', text: 'Insight into payment intents, subscriptions without a payment method and the performance of your entire billing process.' },
];

const steps = [
  { n: '1', title: 'Deal closed', text: 'When an opportunity reaches closed-won, the subscription is activated automatically.' },
  { n: '2', title: 'Invoice generated', text: 'The correct invoice is created: as draft or directly active, in the right language and template.' },
  { n: '3', title: 'Collected automatically', text: 'Via Stripe, the amount is charged to the customer’s preferred payment method.' },
  { n: '4', title: 'Followed up & reported', text: 'Reminders go out automatically and all figures appear live on your dashboards.' },
];

const plans = [
  { name: 'Start', price: '250', sub: 'Invoicing from Salesforce', features: ['Create invoices in Salesforce', 'Generate PDF invoices', 'Send invoices'], popular: false },
  { name: 'Flow', price: '379', sub: 'Most popular choice', features: ['Everything in Start', 'Subscription management', 'Accounts receivable management', 'Automatic invoicing from subscriptions', 'Billing based on contract terms', 'Flow Automation Rules'], popular: true },
  { name: 'Pro', price: null, sub: 'Custom priced', features: ['Everything in Flow', 'Deferred revenue', 'Payment gateways', 'Automatic collection & credit card', 'ERP integration'], popular: false },
];

const quotes = [
  { t: 'I finally have a complete overview of all financial flows.', n: 'Theo van der Steen', r: 'COO, MarketResponse', caseSlug: 'marketresponse' },
  { t: 'A clean system for managing subscriptions and capturing MRR.', n: 'Michael Charnley', r: 'Manager, ParkBee', caseSlug: 'parkbee' },
  { t: 'Creating invoices has never been this easy.', n: 'Marcel Geurtse', r: 'Controller, MYbusinessmedia', caseSlug: 'mybusinessmedia' },
];

const faqs = [
  { q: 'Which accounting packages does the Billing Module connect to?', a: 'Among others Exact Online, Unit4 Multivers and Microsoft Dynamics 365 Business Central. The Pro licence offers full ERP integration. For Exact Online you use our dedicated <a href="/en/producten/exact-online">Influx Exact Connector</a>, for Business Central our <a href="/en/producten/business-central">Influx Business Central Connector</a>. <a href="/blog/billing-platform-koppelen-aan-je-erp">Read more about ERP connections →</a>' },
  { q: 'Can I sell subscriptions with different intervals?', a: 'Yes: monthly, quarterly and annually, with automatic billing per interval and dynamic price adjustment on up- or downgrades. Subscription management activates invoices automatically as soon as a deal reaches closed-won.' },
  { q: 'How does automatic collection work?', a: 'Through our Payment Collection App, which connects Salesforce to Stripe. Payment methods (credit card, direct debit, PayPal) are managed securely in Salesforce and collected automatically on the customer’s preferred method. <a href="/blog/automatische-incasso-met-stripe">Read more about automatic collection →</a>' },
  { q: 'What is deferred revenue and is it supported?', a: 'Deferred revenue spreads the proceeds of, say, an annual contract across the correct months. With start and end dates on invoice lines, revenue is allocated cleanly, available in the Pro licence.' },
  { q: 'How does the module help with accounts receivable?', a: 'Payment reminders are sent automatically at the moments you set, with an overview of outstanding amounts linked to credit limits. This shortens your receivables term without manual chasing. <a href="/blog/geautomatiseerde-betalingsherinneringen">Read more about automated reminders →</a>' },
  { q: 'Do I get insight into my MRR and billing?', a: 'Yes. Reports and dashboards give real-time insight into Monthly Recurring Revenue, payment intents, subscriptions without an active payment method and the performance of your entire billing process. <a href="/blog/rapportages-en-dashboards-billing-platform">Read more about reporting →</a>' },
  { q: 'Can I generate invoices in multiple languages and house styles?', a: 'Certainly. Invoices are generated as PDF based on product type, language and location, with customisable templates per administration. <a href="/blog/facturen-in-de-juiste-taal">Read more about language recognition →</a>' },
  { q: 'Do you help with implementation and training?', a: 'Yes. Our consultants handle the <a href="/en/diensten/implementatie">implementation</a> and give your team <a href="/en/diensten/training">training</a>, so you quickly work independently with the Billing Module.' },
  { q: 'Is there a free trial?', a: 'Yes, you can try the Billing Module without obligation. <a href="/en/contact">Get in touch</a> and we’ll set up a trial environment for you.' },
];

const faqJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') } })),
});
---

<Layout breadcrumbs={[{ name: 'Home', item: '/en' }, { name: 'Products', item: '/en/producten' }, { name: 'Billing Platform', item: '/en/producten/billing-module' }]} title="Billing Platform: invoicing, subscriptions & payments in Salesforce" description="The complete Billing Platform for Salesforce: invoicing, subscription management, MRR insight, accounts receivable and automatic collection via Stripe, connected to Exact Online and Datasolver.">

  <section class="pp-hero">
    <div class="pp-aurora" aria-hidden="true"><span></span><span></span></div>
    <div class="container pp-hero-inner">
      <div class="pp-hero-copy">
        <span class="pp-badge"><span class="pp-badge-dot"></span> Billing Platform · Salesforce-native</span>
        <h1>Invoicing, subscriptions &amp; <span class="gradient-text">payments</span>, in Salesforce</h1>
        <p>The complete platform for your order-to-cash. Create and send invoices, manage subscriptions and MRR, and collect automatically. <strong>Connected to Stripe, Exact Online and Datasolver</strong>: error-free and fully automated.</p>
        <div class="pp-hero-actions">
          <a href="#demo" class="btn btn-primary">Request a demo</a>
          <a href="/en/contact" class="btn btn-outline">Try for free</a>
        </div>
      </div>
      <div class="pp-hero-visual">
        <div class="bm-invoice">
          <div class="bm-inv-head">
            <div><span class="bm-inv-label">Invoice</span><span class="bm-inv-no">#2026-0428</span></div>
            <span class="bm-inv-status">Paid ✓</span>
          </div>
          <div class="bm-inv-rows">
            <div class="bm-row"><span>Salesforce licence, annual</span><span>€ 4,800</span></div>
            <div class="bm-row"><span>Influx Exact Connector</span><span>€ 876</span></div>
            <div class="bm-row"><span>Support &amp; maintenance</span><span>€ 1,200</span></div>
          </div>
          <div class="bm-inv-total"><span>Total</span><span>€ 6,876</span></div>
          <div class="bm-inv-pay"><span class="bm-stripe">Stripe</span> Collected automatically</div>
        </div>
        <div class="bm-mrr">
          <span class="bm-mrr-label">MRR</span>
          <span class="bm-mrr-val">€ 48,250</span>
          <div class="bm-mrr-bars"><i style="--h:50%"></i><i style="--h:62%"></i><i style="--h:58%"></i><i style="--h:74%"></i><i style="--h:88%"></i></div>
        </div>
      </div>
    </div>
  </section>

  <section class="pp-trust">
    <div class="container pp-trust-grid">
      <div><strong>PDF</strong><span>tailored invoices</span></div>
      <div><strong>MRR</strong><span>real-time insight</span></div>
      <div><strong>Stripe</strong><span>automatic collection</span></div>
      <div><strong>ERP</strong><span>Exact · Unit4 · Dynamics</span></div>
    </div>
  </section>

  <!-- ECOSYSTEM -->
  <section class="section">
    <div class="container">
      <div class="section-header reveal">
        <span class="eyebrow">One platform, everything connected</span>
        <h2>The Billing Platform connects your entire order-to-cash</h2>
        <p>Not just an invoicing module, but a platform that works with the tools your customers already use.</p>
      </div>
      <div class="bm-eco reveal">
        <a href="/en/producten/exact-online" class="bm-eco-card">
          <span class="bm-eco-ico"><img src="/images/logos/exact-online.svg" alt="Exact Online" /></span>
          <h3>Exact Online</h3>
          <p class="text-muted">Invoices and payments pushed automatically to your accounting via the Influx Exact Connector.</p>
          <span class="card-link">View connection →</span>
        </a>
        <a href="/en/producten/business-central" class="bm-eco-card">
          <span class="bm-eco-ico"><img src="/images/logos/business-central.svg" alt="Business Central" /></span>
          <h3>Business Central</h3>
          <p class="text-muted">Synchronise invoices, customers and the chart of accounts with Microsoft Dynamics 365 Business Central.</p>
          <span class="card-link">View connection →</span>
        </a>
        <a href="/en/producten/billing-module" class="bm-eco-card">
          <span class="bm-eco-ico"><span class="bm-stripe-lg">Stripe</span></span>
          <h3>Stripe payments</h3>
          <p class="text-muted">Automatic collection via credit card, SEPA and PayPal, managed securely from Salesforce.</p>
          <span class="card-link">Part of Pro →</span>
        </a>
        <a href="/en/producten/kvk-integratie" class="bm-eco-card">
          <span class="bm-eco-ico"><img src="/images/logos/datasolver.svg" alt="Datasolver" /></span>
          <h3>Datasolver</h3>
          <p class="text-muted">Enrich customer data, validate VAT numbers and look up Peppol IDs for legally correct, e-invoicing-ready invoices.</p>
          <span class="card-link">View Datasolver →</span>
        </a>
      </div>
    </div>
  </section>

  <section class="section bg-off-white">
    <div class="container">
      <div class="section-header reveal">
        <span class="eyebrow">Features</span>
        <h2>Your complete billing engine in Salesforce</h2>
        <p>From first invoice to recurring revenue: everything in one place, automatically.</p>
      </div>
      <div class="grid-3">
        {features.map((f, i) => (
          <div class="card pp-feature reveal" style={`--reveal-delay:${(i % 3) * 0.08}s`}>
            <div class="pp-feature-ico">{f.icon}</div>
            <h3>{f.title}</h3>
            <p class="text-muted">{f.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-dark pp-how">
    <div class="pp-how-glow" aria-hidden="true"></div>
    <div class="container" style="position:relative;z-index:1;">
      <div class="section-header reveal">
        <span class="eyebrow">How it works</span>
        <h2 class="text-white">From deal to payment, automatically</h2>
      </div>
      <div class="pp-steps">
        {steps.map((s, i) => (
          <div class="pp-step reveal" style={`--reveal-delay:${i * 0.1}s`}>
            <div class="pp-step-n">{s.n}</div>
            <h3 class="text-white">{s.title}</h3>
            <p style="color:rgba(255,255,255,0.72)">{s.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header reveal">
        <span class="eyebrow">Pricing</span>
        <h2>Choose the plan that fits you</h2>
        <p>Start small and grow along: you can always upgrade.</p>
      </div>
      <div class="pp-pricing">
        {plans.map(p => (
          <div class={`pp-plan reveal ${p.popular ? 'popular' : ''}`}>
            {p.popular && <span class="pp-plan-flag">Most popular choice</span>}
            <span class="pp-plan-name">{p.name}</span>
            <div class="pp-plan-price">
              {p.price ? <Fragment><span class="cur">€</span>{p.price}<span class="per">/mo</span></Fragment> : <Fragment>Custom</Fragment>}
            </div>
            <span class="pp-plan-sub">{p.sub}</span>
            <ul class="list-check">{p.features.map(f => <li>{f}</li>)}</ul>
            <a href="#demo" class={`btn ${p.popular ? 'btn-primary' : 'btn-outline-dark'}`}>Choose {p.name}</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-off-white">
    <div class="container">
      <div class="section-header reveal">
        <span class="eyebrow">In their words</span>
        <h2>Trusted by finance teams</h2>
      </div>
      <div class="pp-quotes">
        {quotes.map(q => (
          <div class="pp-quote reveal">
            <p>“{q.t}”</p>
            <div class="pp-quote-by">
              <span class="pp-quote-av">{q.n.split(' ').map(w => w[0]).slice(0,2).join('')}</span>
              <div><strong>{q.n}</strong><small>{q.r}</small></div>
            </div>
            {q.caseSlug && <a href={`/en/cases/${q.caseSlug}`} class="pp-quote-case">View the case →</a>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:820px;">
      <div class="section-header reveal"><span class="eyebrow">Frequently asked questions</span><h2>Good to know</h2></div>
      <div class="pp-faq-list">
        {faqs.map(f => (
          <details class="pp-faq reveal"><summary>{f.q}<span class="pp-faq-plus">+</span></summary><p set:html={f.a} /></details>
        ))}
      </div>
    </div>
    <script type="application/ld+json" set:html={faqJsonLd} is:inline />
  </section>

  <section class="pp-cta bg-dark">
    <div class="pp-cta-glow" aria-hidden="true"></div>
    <div class="container pp-cta-inner reveal">
      <div><h2>Ready to automate your invoicing?</h2><p>Request a demo or start a free trial.</p></div>
      <div class="pp-cta-actions">
        <a href="#demo" class="btn btn-primary">Request a demo</a>
        <a href="/en/contact" class="btn btn-outline">Ask a question</a>
      </div>
    </div>
  </section>

  <FormModal id="demo" title="Request a demo: Billing Platform" formUrl={pardotForms.demoBilling} />

</Layout>

<style>
/* ecosystem cards */
.bm-eco { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
@media (max-width: 960px) { .bm-eco { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 560px) { .bm-eco { grid-template-columns: 1fr; } }
.bm-eco-card { display: flex; flex-direction: column; background: var(--color-white); border: 1px solid var(--color-light); border-radius: var(--radius-lg); padding: 1.75rem; box-shadow: var(--shadow); transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition); }
.bm-eco-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); border-color: rgba(109,183,87,0.4); }
.bm-eco-ico { font-size: 2rem; margin-bottom: 0.85rem; display: flex; align-items: center; height: 32px; }
.bm-eco-ico img { height: 26px; width: auto; }
.bm-stripe-lg { background: #635bff; color: #fff; font-weight: 700; font-size: 0.85rem; padding: 0.25rem 0.6rem; border-radius: 6px; }
.bm-eco-card h3 { font-size: 1.1rem; margin-bottom: 0.5rem; }
.bm-eco-card .card-link { margin-top: auto; padding-top: 1.1rem; color: var(--color-green); font-weight: 600; font-size: 0.9rem; }

.pp-hero-visual { position: relative; }
.bm-invoice { background: #fff; border-radius: var(--radius-lg); box-shadow: 0 30px 70px rgba(0,0,0,0.45); padding: 1.75rem; animation: float-y 7s ease-in-out infinite; }
.bm-inv-head { display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 1px solid var(--color-light); padding-bottom: 1rem; margin-bottom: 1rem; }
.bm-inv-label { display: block; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-text-muted); }
.bm-inv-no { font-weight: 800; color: var(--color-text); font-size: 1.1rem; }
.bm-inv-status { background: rgba(109,183,87,0.14); color: var(--color-green-dark); font-weight: 700; font-size: 0.75rem; padding: 0.3rem 0.7rem; border-radius: 999px; }
.bm-inv-rows { display: flex; flex-direction: column; gap: 0.6rem; }
.bm-row { display: flex; justify-content: space-between; font-size: 0.85rem; color: var(--color-text); }
.bm-row span:first-child { color: var(--color-text-muted); }
.bm-inv-total { display: flex; justify-content: space-between; font-weight: 800; color: var(--color-text); font-size: 1.05rem; border-top: 1px solid var(--color-light); margin-top: 0.85rem; padding-top: 0.85rem; }
.bm-inv-pay { margin-top: 0.85rem; font-size: 0.78rem; color: var(--color-text-muted); display: flex; align-items: center; gap: 0.4rem; }
.bm-stripe { background: #635bff; color: #fff; font-weight: 700; font-size: 0.7rem; padding: 0.15rem 0.5rem; border-radius: 5px; }
.bm-mrr { position: absolute; bottom: -28px; right: -18px; background: var(--color-dark-2); border: 1px solid rgba(255,255,255,0.12); border-radius: 14px; padding: 1rem 1.25rem; box-shadow: 0 16px 36px rgba(0,0,0,0.35); animation: float-y 6s ease-in-out infinite 0.5s; }
.bm-mrr-label { font-size: 0.7rem; color: rgba(255,255,255,0.6); text-transform: uppercase; letter-spacing: 0.08em; }
.bm-mrr-val { display: block; font-size: 1.3rem; font-weight: 800; color: var(--color-green-soft); margin: 0.1rem 0 0.5rem; }
.bm-mrr-bars { display: flex; align-items: flex-end; gap: 4px; height: 34px; }
.bm-mrr-bars i { width: 9px; height: var(--h); background: linear-gradient(180deg, #b9e0a8, var(--color-green)); border-radius: 2px; transform-origin: bottom; animation: grow-bar 1s cubic-bezier(0.16,1,0.3,1) backwards; }
.bm-mrr-bars i:nth-child(2){animation-delay:.1s} .bm-mrr-bars i:nth-child(3){animation-delay:.2s} .bm-mrr-bars i:nth-child(4){animation-delay:.3s} .bm-mrr-bars i:nth-child(5){animation-delay:.4s}
@keyframes grow-bar { from { transform: scaleY(0); opacity: 0; } to { transform: scaleY(1); opacity: 1; } }
@media (max-width: 820px) { .bm-mrr { right: 0; } }
</style>
</content>
</invoke>
