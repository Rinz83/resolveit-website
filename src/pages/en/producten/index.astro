---
import Layout from '../../../layouts/Layout.astro';

const products = [
  {
    logo: '/images/logos/billing-platform.svg',
    title: 'Billing Platform',
    badge: 'Managed App',
    href: '/en/producten/billing-module',
    description: 'Invoicing straight from Salesforce: automated, accurate and seamlessly connected to your accounting.',
    features: ['Automatic invoice creation', 'Connection to accounting packages', 'Recurring billing', 'Reports & dashboards'],
  },
  {
    logo: '/images/logos/ai-prompt-builder.svg',
    title: 'AI Prompt Builder',
    badge: 'Managed App',
    href: '/en/producten/ai-prompt-builder',
    description: 'Integrate OpenAI, Anthropic, Gemini or your own LLM directly into Salesforce Flows, without code.',
    features: ['AI as an invocable action', 'Dynamic prompt templates', 'Multiple AI models', 'Works in all Flow types'],
  },
  {
    logo: '/images/logos/datasolver.svg',
    title: 'Company integration (Datasolver)',
    badge: 'Managed App',
    href: '/en/producten/kvk-integratie',
    description: 'Automatically retrieve and keep company data up to date from the business register in Salesforce.',
    features: ['Automatic data retrieval', 'Validate company data', 'Synchronise contact details', 'Bulk-update capabilities'],
  },
  {
    logo: '/images/logos/signflow.svg',
    title: 'SignFlow',
    badge: 'Managed App',
    href: '/en/producten/signflow',
    description: 'Get documents digitally signed straight from Salesforce: from contract to executed PDF on the record.',
    features: ['Signing without a Salesforce login', 'AI document generation or your own PDF', 'Signing order and observers', 'Signed document automatically on the record'],
  },
  {
    logo: '/images/logos/influx-exact-connector.svg',
    title: 'Influx Exact Connector',
    badge: 'Exact Online App Store',
    href: '/en/producten/exact-online',
    description: 'Real-time financial data and two-way synchronisation between Salesforce and Exact Online.',
    features: ['Real-time synchronisation', 'Invoices & payments', 'AI-guided onboarding with Claude', 'Financial dashboard'],
  },
  {
    logo: '/images/logos/salespoint.svg',
    title: 'SalesPoint',
    badge: 'AppExchange & AppSource',
    href: '/en/producten/sharepoint',
    description: 'Manage documents and files directly from Salesforce with a seamless connection to SharePoint.',
    features: ['Document management from Salesforce', 'Automatic saving', 'Version history', 'Teams integration'],
  },
];
---

<Layout title="Products" description="Discover Resolve IT's Salesforce products: Billing Module, Company integration, Exact Online and SalesPoint.">

  <div class="page-hero">
    <div class="container">
      <span class="eyebrow">Products</span>
      <h1>Smart extensions for Salesforce</h1>
      <p>Our own products on the Salesforce AppExchange, proven, ready to use and fully supported.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="products-grid">
        {products.map(p => (
          <a href={p.href} class="product-card card">
            <div class="product-header">
              <div class="product-icon">
                {p.logo ? <img src={p.logo} alt={p.title} width="48" height="48" /> : p.icon}
              </div>
              <span class="badge">{p.badge}</span>
            </div>
            <h2>{p.title}</h2>
            <p class="text-muted">{p.description}</p>
            <ul class="list-check">
              {p.features.map(f => <li>{f}</li>)}
            </ul>
            <span class="card-link">More information →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="integration-section section bg-off-white">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Popular integrations</span>
        <h2>Connect Salesforce to your favourite tools</h2>
        <p>Besides our own products, we also build custom integrations with virtually any system.</p>
      </div>
      <div class="integrations-grid">
        {['Stripe', 'OneDrive', 'Google Drive', 'Exact Online', 'Aircall', 'SAP', 'DocuSign', 'ChatGPT', 'Microsoft Teams', 'SharePoint', 'HubSpot', 'Slack'].map(tool => (
          <div class="integration-chip">{tool}</div>
        ))}
      </div>
      <div style="text-align:center;margin-top:2.5rem;">
        <a href="/en/diensten/development" class="btn btn-outline-dark">More about integrations</a>
      </div>
    </div>
  </section>

</Layout>

<style>
.products-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 2rem;
}
@media (max-width: 768px) { .products-grid { grid-template-columns: 1fr; } }

.product-card { display: flex; flex-direction: column; gap: 1rem; color: var(--color-text); transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition); }
.product-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); border-color: rgba(109,183,87,0.4); }
.product-header { display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; }
.product-header .badge { white-space: nowrap; font-size: 0.7rem; padding: 0.3rem 0.7rem; flex-shrink: 0; }
.product-icon { font-size: 2rem; display: flex; align-items: center; min-height: 44px; }
.product-icon img { height: 34px; width: auto; max-width: 160px; object-fit: contain; display: block; }
.product-card h2 { font-size: 1.4rem; }
.product-card .text-muted { min-height: 7.2em; }
.product-card .list-check { flex: 1; }
.product-card .card-link { margin-top: auto; padding-top: 0.5rem; color: var(--color-green); font-weight: 600; font-size: 0.9rem; }

.integrations-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  justify-content: center;
}
.integration-chip {
  background: var(--color-white);
  border: 1px solid var(--color-light-gray);
  border-radius: 999px;
  padding: 0.5rem 1.25rem;
  font-weight: 600;
  font-size: 0.875rem;
  color: var(--color-text);
  box-shadow: var(--shadow);
  transition: all var(--transition);
}
.integration-chip:hover {
  border-color: var(--color-accent);
  color: var(--color-accent);
  transform: translateY(-2px);
}
</style>
</content>
