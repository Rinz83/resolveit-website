---
import Layout from '../../../layouts/Layout.astro';
import FormModal from '../../../components/FormModal.astro';
import { calendlyUrl, pardotForms } from '../../../i18n/ui.js';
import '../../../styles/product.css';

const features = [
  { icon: '🏢', title: 'Company enrichment', text: 'Search by registration number, trade name or (part of an) address and enrich records with trade names, industry codes, addresses and branch details, in one click.' },
  { icon: '✅', title: 'VIES VAT validation', text: 'Validate EU VAT numbers straight from the Salesforce record. Ensure your invoices meet the legal requirements for European customers.' },
  { icon: '🔗', title: 'Peppol Directory', text: 'Look up Peppol identification numbers without leaving Salesforce. Ready for the mandatory e-invoicing coming across Europe.' },
  { icon: '🔄', title: 'Automatic periodic checks', text: 'The tool checks previously enriched companies automatically. Changes in the register appear clearly in a report.' },
  { icon: '🧩', title: 'Three flexible licences', text: 'Start with register enrichment and grow into VAT validation and Peppol. Three tiers, per user per month: exactly what you need.' },
  { icon: '🎯', title: 'Clean, current data', text: 'No more polluted database. Company data stays automatically up to date, so you build on reliable information.' },
];

const plans = [
  { name: 'Basic', price: '20', sub: 'Clean register data', features: ['Search the business register (CoC)', 'Enrich existing records', 'Automatic periodic checks'], popular: false },
  { name: 'Professional', price: '25', sub: 'Including VAT validation', features: ['Everything in Basic', 'EU VAT validation (VIES)', 'Create records from VAT numbers'], popular: true },
  { name: 'Premium', price: '30', sub: 'Ready for e-invoicing', features: ['Everything in Professional', 'Peppol Directory integration'], popular: false },
];

const dataFields = ['Registration no.', 'VAT number', 'Branch number', 'Legal form', 'Head office', 'Number of employees', 'Trade names', 'Addresses', 'Industry codes', 'Peppol ID'];

const faqs = [
  { q: 'What can I search on in the company enrichment?', a: 'By registration number, VAT number, trade name, address or part of the address. You browse the results from the business register and create or update a Salesforce record in one click.' },
  { q: 'Which company data is retrieved?', a: 'Among others registration number, VAT number, branch number, legal form, head and secondary office, number of employees, trade names, addresses and industry codes, automatically in the correct fields.' },
  { q: 'How do the automatic periodic checks work?', a: 'The tool automatically checks previously assessed companies. If there are changes in the business register, these are shown clearly in a report, so your database stays current without manual work.' },
  { q: 'Which licence tiers are available?', a: 'Three tiers, per user per month. Basic (€20): search the business register, enrich records and periodic checks. Professional (€25): everything in Basic plus EU VAT validation (VIES) and creating records from VAT numbers. Premium (€30): everything in Professional plus the Peppol Directory integration.' },
  { q: 'How do I validate VAT numbers of European customers?', a: 'Via the built-in VIES validation you check EU VAT numbers straight from the Salesforce record. This ensures your invoices meet the legal requirements for B2B in Europe.' },
  { q: 'Why is Peppol important for e-invoicing?', a: 'E-invoicing via Peppol is becoming mandatory across Europe: already in force in Belgium, from September 2026 in France, and EU-wide towards 2030. Combine this with our <a href="/en/producten/exact-online">Influx Exact Connector</a> for Peppol-compliant invoicing under EN 16931.' },
  { q: 'Does clean data also lead to better invoicing?', a: 'Certainly. Correct company and VAT data form the basis for error-free invoices. Many customers therefore combine Datasolver with our <a href="/en/producten/billing-module">Billing Module</a>.' },
  { q: 'Does it help clean up a polluted database?', a: 'Yes. Existing accounts are enriched with current data and checked periodically. For a thorough approach, our <a href="/en/diensten/consultancy">consultancy</a> experts are happy to help. <a href="/en/cases/marketresponse">MarketResponse</a> used this to enrich company information and drastically reduce duplicate entry.' },
  { q: 'Is there a demo or trial?', a: 'Yes. <a href="/en/contact">Get in touch</a> for a demo or a no-obligation trial of the Datasolver module.' },
];

const faqJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') } })),
});
---

<Layout breadcrumbs={[{ name: 'Home', item: '/en' }, { name: 'Products', item: '/en/producten' }, { name: 'Datasolver', item: '/en/producten/kvk-integratie' }]} title="Datasolver / Company integration: enrich your Salesforce data" description="Automate the enrichment of your company data in Salesforce: business register data, VIES VAT validation and Peppol Directory. Always current, reliable data.">

  <section class="pp-hero">
    <div class="pp-aurora" aria-hidden="true"><span></span><span></span></div>
    <div class="container pp-hero-inner">
      <div class="pp-hero-copy">
        <span class="pp-badge"><span class="pp-badge-dot"></span> Datasolver · Integration</span>
        <h1>Enrich your <span class="gradient-text">company data</span> automatically</h1>
        <p>Retrieve business register data, validate VAT numbers and find Peppol IDs, <strong>without leaving Salesforce.</strong> Always current, clean data to build on.</p>
        <div class="pp-hero-actions">
          <a href="#demo" class="btn btn-primary">Request a demo</a>
          <a href="/en/contact" class="btn btn-outline">Try for free</a>
        </div>
      </div>
      <div class="pp-hero-visual">
        <div class="ds-card">
          <div class="ds-search">
            <span class="ds-search-ico">🔍</span>
            <span class="ds-search-txt">Reg. 34216805</span>
            <span class="ds-search-cursor"></span>
          </div>
          <div class="ds-result">
            <div class="ds-result-head">
              <span class="ds-logo">🏢</span>
              <div><strong>Resolve IT B.V.</strong><small>Head office · Active</small></div>
              <span class="ds-check">✓</span>
            </div>
            <div class="ds-fields">
              <div class="ds-field"><span>Legal form</span><b>B.V.</b></div>
              <div class="ds-field"><span>Industry code</span><b>62010</b></div>
              <div class="ds-field"><span>VAT (VIES)</span><b class="ds-valid">Valid ✓</b></div>
              <div class="ds-field"><span>Peppol ID</span><b>0106:8412…</b></div>
              <div class="ds-field"><span>Employees</span><b>10+</b></div>
              <div class="ds-field"><span>Address</span><b>Netherlands</b></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="pp-trust">
    <div class="container pp-trust-grid">
      <div><strong>KvK</strong><span>business register</span></div>
      <div><strong>VIES</strong><span>VAT validation</span></div>
      <div><strong>Peppol</strong><span>e-invoicing-ready</span></div>
      <div><strong>Auto</strong><span>periodic updates</span></div>
    </div>
  </section>

  <section class="section bg-off-white">
    <div class="container">
      <div class="section-header reveal">
        <span class="eyebrow">Features</span>
        <h2>Three powerful tools, one module</h2>
        <p>Enrich, validate and make e-invoicing-proof: all within Salesforce.</p>
      </div>
      <div class="grid-3">
        {features.map((f, i) => (
          <div class="card pp-feature reveal" style={`--reveal-delay:${(i % 3) * 0.08}s`}>
            <div class="pp-feature-ico">{f.icon}</div>
            <h3>{f.title}</h3>
            <p class="text-muted">{f.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header reveal">
        <span class="eyebrow">What you retrieve</span>
        <h2>Complete company data, in one click</h2>
        <p>Straight from the business register into your Salesforce record.</p>
      </div>
      <div class="ds-fieldgrid reveal">
        {dataFields.map(f => <span class="ds-fieldchip">{f}</span>)}
      </div>
    </div>
  </section>

  <section class="section bg-off-white">
    <div class="container">
      <div class="section-header reveal">
        <span class="eyebrow">Licences</span>
        <h2>Pick the licence that fits</h2>
        <p>From register enrichment to full e-invoicing readiness, you only pay for what you use.</p>
      </div>
      <div class="pp-pricing">
        {plans.map(p => (
          <div class={`pp-plan reveal ${p.popular ? 'popular' : ''}`}>
            {p.popular && <span class="pp-plan-flag">Most chosen</span>}
            <span class="pp-plan-name">{p.name}</span>
            <div class="pp-plan-price"><span class="cur">€</span>{p.price}<span class="per">per user /mo</span></div>
            <span class="pp-plan-sub">{p.sub}</span>
            <ul class="list-check">{p.features.map(f => <li>{f}</li>)}</ul>
            <a href="#demo" class={`btn ${p.popular ? 'btn-primary' : 'btn-outline-dark'}`}>Choose {p.name}</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:820px;">
      <div class="section-header reveal"><span class="eyebrow">Frequently asked questions</span><h2>Good to know</h2></div>
      <div class="pp-faq-list">
        {faqs.map(f => (
          <details class="pp-faq reveal"><summary>{f.q}<span class="pp-faq-plus">+</span></summary><p set:html={f.a} /></details>
        ))}
      </div>
    </div>
    <script type="application/ld+json" set:html={faqJsonLd} is:inline />
  </section>

  <section class="pp-cta bg-dark">
    <div class="pp-cta-glow" aria-hidden="true"></div>
    <div class="container pp-cta-inner reveal">
      <div><h2>Ready for clean, current company data?</h2><p>Request a demo or try Datasolver for free.</p></div>
      <div class="pp-cta-actions">
        <a href="#demo" class="btn btn-primary">Request a demo</a>
        <a href="/en/contact" class="btn btn-outline">Ask a question</a>
      </div>
    </div>
  </section>

  <FormModal id="demo" title="Request a demo: Datasolver" formUrl={pardotForms.demoKvk} />

</Layout>

<style>
.pp-hero-visual { position: relative; }
.ds-card { background: #fff; border-radius: var(--radius-lg); box-shadow: 0 30px 70px rgba(0,0,0,0.45); padding: 1.5rem; animation: float-y 7s ease-in-out infinite; }
.ds-search { display: flex; align-items: center; gap: 0.6rem; background: var(--color-off-white); border: 1px solid var(--color-light); border-radius: 10px; padding: 0.7rem 1rem; margin-bottom: 1.25rem; }
.ds-search-txt { font-weight: 600; color: var(--color-text); font-size: 0.95rem; }
.ds-search-cursor { width: 2px; height: 18px; background: var(--color-green); animation: blink 1.1s steps(1) infinite; }
@keyframes blink { 50% { opacity: 0; } }
.ds-result-head { display: flex; align-items: center; gap: 0.75rem; padding-bottom: 1rem; border-bottom: 1px solid var(--color-light); margin-bottom: 1rem; }
.ds-logo { width: 40px; height: 40px; border-radius: 10px; background: rgba(109,183,87,0.14); display: flex; align-items: center; justify-content: center; font-size: 1.2rem; }
.ds-result-head strong { display: block; color: var(--color-text); font-size: 0.95rem; }
.ds-result-head small { color: var(--color-text-muted); font-size: 0.78rem; }
.ds-check { margin-left: auto; width: 26px; height: 26px; border-radius: 50%; background: var(--color-green); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; font-weight: 700; }
.ds-fields { display: grid; grid-template-columns: 1fr 1fr; gap: 0.65rem 1.25rem; }
.ds-field { display: flex; justify-content: space-between; font-size: 0.82rem; border-bottom: 1px dashed var(--color-light); padding-bottom: 0.4rem; }
.ds-field span { color: var(--color-text-muted); }
.ds-field b { color: var(--color-text); }
.ds-valid { color: var(--color-green-dark) !important; }
.ds-fieldgrid { display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center; }
.ds-fieldchip { background: var(--color-white); border: 1px solid var(--color-light); border-radius: 999px; padding: 0.6rem 1.25rem; font-weight: 600; font-size: 0.88rem; box-shadow: var(--shadow); transition: all var(--transition); }
.ds-fieldchip:hover { border-color: rgba(109,183,87,0.5); color: var(--color-green-dark); transform: translateY(-2px); }
.ds-price-wrap { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 4rem; align-items: center; justify-items: center; }
@media (max-width: 820px) { .ds-price-wrap { grid-template-columns: 1fr; gap: 2.5rem; } }
</style>
</content>
