---
import Layout from '../../../layouts/Layout.astro';
import FormModal from '../../../components/FormModal.astro';
import { calendlyUrl, pardotForms } from '../../../i18n/ui.js';
import '../../../styles/product.css';

const features = [
  { icon: '✍️', title: 'Digital signing from Salesforce', text: 'Send contracts, quotes and invoices for signature without leaving Salesforce. No separate e-signing tool, no exports, no duplicate administration.' },
  { icon: '🧭', title: '4-step wizard', text: 'Configure the document, add signers, place the signature fields and send. The built-in wizard guides every user through the process without errors.' },
  { icon: '🤖', title: 'Generate documents with AI', text: 'No document yet? Describe what you need and let AI draft it. Or upload an existing PDF, or pick a file already attached to the record.' },
  { icon: '🎯', title: 'Drop fields onto the PDF', text: 'Place signature, initials and date fields with a click, exactly where they belong and assigned to the right signer. You decide who signs where.' },
  { icon: '🔢', title: 'Signing order and observers', text: 'Multiple signers per party, in the order you choose. Add observers who receive a copy and get notified, without having to sign themselves.' },
  { icon: '📎', title: 'Signed document back on the record', text: 'Once all parties have signed, the final executed PDF is generated automatically and attached to the Salesforce record. Fully auditable, always easy to find.' },
];

const steps = [
  { n: '1', title: 'Configure document', text: 'Choose: generate with AI, upload a PDF or use a file from the record. Your own party is pre-filled automatically from the record page.' },
  { n: '2', title: 'Add recipients', text: 'Add signers and observers per party, including email, title and signing order. A visual preview shows the sequence.' },
  { n: '3', title: 'Place signature fields', text: 'Click on the PDF to place signature, initials and date fields, each assigned to the right signer.' },
  { n: '4', title: 'Review and send', text: 'Pick an email template for the invitation and send. Every signer receives a secure, personal link. No Salesforce login required.' },
];

const faqs = [
  { q: 'Do signers need a Salesforce account?', a: 'No. Every signer receives a secure, time-limited link by email that opens a dedicated signing page. They sign the document in the browser, on any device, without logging in.' },
  { q: 'Where can I use SignFlow?', a: 'Anywhere. The component works on any record page (Opportunity, Account, Contact or any custom object) and on the Home and App pages. On a record page, your own party is pre-filled automatically from the record.' },
  { q: 'How do I get the document that needs to be signed?', a: 'In three ways: let AI generate the document from your description, upload an existing PDF, or pick a file that is already stored in the record\'s Files.' },
  { q: 'Can I set multiple signers and a signing order?', a: 'Yes. Add as many signers per party as you need, each with their own order number. Party 1 always signs first; signers with the same order number sign simultaneously. Observers receive a copy once everything is signed.' },
  { q: 'Can I customise the invitation email?', a: 'Fully. SignFlow uses Salesforce Email Templates: any template you place in the "Document Signing Templates" folder automatically appears in the dropdown. Your team controls the tone and content without configuration changes.' },
  { q: 'What happens after everyone has signed?', a: 'The system automatically generates the final executed PDF and attaches it to the Salesforce record. Observers are notified. Nothing needs to be archived manually.' },
  { q: 'Is SignFlow a connection to an external e-signing service?', a: 'No, SignFlow is built fully native in Salesforce. Your documents and signing process stay within your own Salesforce environment, with no separate licences for an external signing tool.' },
  { q: 'Is a demo available?', a: 'Yes. <a href="/en/contact">Get in touch</a> for a personal demo of SignFlow in your own Salesforce environment.' },
];

const faqJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') } })),
});
---

<Layout breadcrumbs={[{ name: 'Home', item: '/en' }, { name: 'Products', item: '/en/producten' }, { name: 'SignFlow', item: '/en/producten/signflow' }]} title="SignFlow: digital document signing from Salesforce" description="Send contracts and quotes for digital signature straight from Salesforce. Native component, AI document generation, signing order and automatic archiving.">

  <section class="pp-hero">
    <div class="pp-aurora" aria-hidden="true"><span></span><span></span></div>
    <div class="container pp-hero-inner">
      <div class="pp-hero-copy">
        <span class="pp-badge"><span class="pp-badge-dot"></span> SignFlow · Native Salesforce e-signing</span>
        <h1>Get documents <span class="gradient-text">digitally signed</span> from Salesforce</h1>
        <p>Contract ready? Send it for signature <strong>without leaving Salesforce.</strong> No external signing tool, no exports: from document to executed PDF on the record, in four steps.</p>
        <div class="pp-hero-actions">
          <a href="#demo" class="btn btn-primary">Request a demo</a>
          <a href={calendlyUrl} target="_blank" rel="noopener" class="btn btn-outline">Book a meeting</a>
        </div>
      </div>
      <div class="pp-hero-visual">
        <div class="sf-card">
          <div class="sf-steps">
            <span class="sf-step done">✓</span><i></i>
            <span class="sf-step done">✓</span><i></i>
            <span class="sf-step done">✓</span><i></i>
            <span class="sf-step active">4</span>
          </div>
          <div class="sf-doc">
            <span class="sf-doc-ico">📄</span>
            <div><strong>Contract_2026-0142.pdf</strong><small>Ready to send</small></div>
            <span class="sf-check">✓</span>
          </div>
          <div class="sf-signers">
            <div class="sf-signer"><span class="sf-avatar">JG</span><div><b>Jane Grey</b><small>Party 1 · Signs 1st</small></div><span class="sf-sig">✍️</span></div>
            <div class="sf-signer"><span class="sf-avatar">EF</span><div><b>Edna Frank</b><small>Party 2 · Signs 2nd</small></div><span class="sf-sig">✍️</span></div>
          </div>
          <div class="sf-send">Send for signing →</div>
        </div>
      </div>
    </div>
  </section>

  <section class="pp-trust">
    <div class="container pp-trust-grid">
      <div><strong>100% native</strong><span>in Salesforce</span></div>
      <div><strong>No login</strong><span>for signers</span></div>
      <div><strong>AI</strong><span>document generation</span></div>
      <div><strong>Auto</strong><span>archiving on the record</span></div>
    </div>
  </section>

  <section class="section bg-off-white">
    <div class="container">
      <div class="section-header reveal">
        <span class="eyebrow">Features</span>
        <h2>Everything for digital signing, in one place</h2>
        <p>From document creation to executed PDF, entirely within your Salesforce environment.</p>
      </div>
      <div class="grid-3">
        {features.map((f, i) => (
          <div class="card pp-feature reveal" style={`--reveal-delay:${(i % 3) * 0.08}s`}>
            <div class="pp-feature-ico">{f.icon}</div>
            <h3>{f.title}</h3>
            <p class="text-muted">{f.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header reveal">
        <span class="eyebrow">How it works</span>
        <h2>From document to signature in 4 steps</h2>
        <p>A built-in wizard guides the user from start to finish.</p>
      </div>
      <div class="sf-stepgrid">
        {steps.map((s, i) => (
          <div class="card sf-stepcard reveal" style={`--reveal-delay:${i * 0.08}s`}>
            <span class="sf-stepnum">{s.n}</span>
            <h3>{s.title}</h3>
            <p class="text-muted">{s.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-off-white">
    <div class="container sf-why-wrap">
      <div class="reveal">
        <span class="eyebrow">Why SignFlow?</span>
        <h2>Stop emailing, printing and waiting</h2>
        <ul class="list-check" style="margin-top:1.5rem;">
          <li>Faster signed deals: sending takes minutes, not days</li>
          <li>No separate e-signing licences or standalone tools needed</li>
          <li>Your own party is pre-filled automatically from the record</li>
          <li>Full visibility: status and signed documents on the record</li>
          <li>Works on any object, including custom objects and the Home page</li>
        </ul>
      </div>
      <div class="card sf-flexcard reveal">
        <h3>Usable anywhere in Salesforce</h3>
        <p class="text-muted">Place the SignFlow component on any record page (Opportunity, Account, Contact or any custom object) or on the Home and App pages. One component covers every signing scenario: from a deal, an account or a standalone document workflow.</p>
        <a href="#demo" class="btn btn-primary" style="margin-top:1rem;">Request a demo</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:820px;">
      <div class="section-header reveal"><span class="eyebrow">Frequently asked questions</span><h2>Good to know</h2></div>
      <div class="pp-faq-list">
        {faqs.map(f => (
          <details class="pp-faq reveal"><summary>{f.q}<span class="pp-faq-plus">+</span></summary><p set:html={f.a} /></details>
        ))}
      </div>
    </div>
    <script type="application/ld+json" set:html={faqJsonLd} is:inline />
  </section>

  <section class="pp-cta bg-dark">
    <div class="pp-cta-glow" aria-hidden="true"></div>
    <div class="container pp-cta-inner reveal">
      <div><h2>Ready to close deals faster?</h2><p>Request a demo and see SignFlow at work in your own Salesforce environment.</p></div>
      <div class="pp-cta-actions">
        <a href="#demo" class="btn btn-primary">Request a demo</a>
        <a href="/en/contact" class="btn btn-outline">Ask a question</a>
      </div>
    </div>
  </section>

  <FormModal id="demo" title="Request a demo: SignFlow" formUrl={pardotForms.contact} />

</Layout>

<style>
.pp-hero-visual { position: relative; }
.sf-card { background: #fff; border-radius: var(--radius-lg); box-shadow: 0 30px 70px rgba(0,0,0,0.45); padding: 1.5rem; animation: float-y 7s ease-in-out infinite; }
.sf-steps { display: flex; align-items: center; gap: 0.35rem; margin-bottom: 1.25rem; }
.sf-steps i { flex: 1; height: 2px; background: var(--color-green); }
.sf-step { width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: 700; }
.sf-step.done { background: var(--color-green); color: #fff; }
.sf-step.active { background: #fff; color: var(--color-green-dark); border: 2px solid var(--color-green); }
.sf-doc { display: flex; align-items: center; gap: 0.75rem; padding: 0.85rem 1rem; background: var(--color-off-white); border: 1px solid var(--color-light); border-radius: 10px; margin-bottom: 1rem; }
.sf-doc strong { display: block; color: var(--color-text); font-size: 0.9rem; }
.sf-doc small { color: var(--color-text-muted); font-size: 0.76rem; }
.sf-check { margin-left: auto; width: 24px; height: 24px; border-radius: 50%; background: var(--color-green); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: 700; }
.sf-signers { display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 1.1rem; }
.sf-signer { display: flex; align-items: center; gap: 0.7rem; border-bottom: 1px dashed var(--color-light); padding-bottom: 0.55rem; }
.sf-avatar { width: 32px; height: 32px; border-radius: 50%; background: rgba(109,183,87,0.16); color: var(--color-green-dark); font-size: 0.75rem; font-weight: 700; display: flex; align-items: center; justify-content: center; }
.sf-signer b { display: block; color: var(--color-text); font-size: 0.86rem; }
.sf-signer small { color: var(--color-text-muted); font-size: 0.74rem; }
.sf-sig { margin-left: auto; }
.sf-send { text-align: center; background: var(--color-green); color: #fff; font-weight: 600; font-size: 0.9rem; border-radius: 10px; padding: 0.7rem; }
.sf-stepgrid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
@media (max-width: 960px) { .sf-stepgrid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 560px) { .sf-stepgrid { grid-template-columns: 1fr; } }
.sf-stepcard { position: relative; padding-top: 2.5rem; }
.sf-stepnum { position: absolute; top: -0.9rem; left: 1.25rem; width: 40px; height: 40px; border-radius: 12px; background: var(--color-green); color: #fff; font-weight: 700; font-size: 1.1rem; display: flex; align-items: center; justify-content: center; box-shadow: var(--shadow); }
.sf-stepcard h3 { font-size: 1.05rem; margin-bottom: 0.5rem; }
.sf-why-wrap { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 4rem; align-items: center; }
@media (max-width: 820px) { .sf-why-wrap { grid-template-columns: 1fr; gap: 2.5rem; } }
.sf-flexcard h3 { margin-bottom: 0.6rem; }
</style>
