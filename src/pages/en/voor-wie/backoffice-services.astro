---
import Layout from '../../../layouts/Layout.astro';
import SectorPage from '../../../components/SectorPage.astro';
const icon = `<svg viewBox="0 0 24 24" fill="none"><path d="M12 3l9 4.5-9 4.5-9-4.5L12 3z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/><path d="M3 12l9 4.5 9-4.5" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/><path d="M3 16.5 12 21l9-4.5" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>`;
---
<Layout title="Backoffice Services: invoicing, contracts, projects & data in Salesforce" description="Automate your entire backoffice in Salesforce: invoicing, subscriptions, contracts, project management, time tracking, payments and data enrichment, in one connected platform.">
  <SectorPage
    lang="en"
    eyebrow="Focus area · Backoffice Services"
    title="Your entire backoffice, automated in Salesforce"
    intro="Not an industry, but our specialty. We connect the processes your organisation runs on every day: invoicing, contracts, projects, hours and data, in one platform. Less re-typing, fewer errors, real-time grip on your order-to-cash."
    icon={icon}
    dashboard={{
      title: 'Backoffice Control Center',
      kpis: [ { label: 'Revenue YTD', value: '€1.24M', trend: '▲ 18%' }, { label: 'Outstanding', value: '€86K', trend: '▼ 9 days DSO' } ],
      barLabel: 'Invoiced per month',
      bars: [48, 56, 52, 67, 70, 90],
      ring: '94%', ringLabel: 'paid on time',
      legend: [ { label: 'Invoicing', value: '€142K', color: '#6db757' }, { label: 'Subscriptions', value: '€61K', color: '#85b160' }, { label: 'Projects', value: '€39K', color: '#6c4494' } ],
    }}
    painLine="Your backoffice runs on separate systems that don’t talk to each other"
    painPoints={[
      'Invoices, contracts, hours and CRM live in separate tools: re-typing data is a daily chore',
      'Month-end closing is a manual job with too much room for error',
      'Receivables pile up because reminders keep slipping',
      'No real-time view of revenue, margins and outstanding items',
      'Contract renewals get missed for lack of alerts',
      'Customer data is dirty, leading to incorrect invoices and VAT issues',
    ]}
    capabilities={[
      { icon: '🧾', title: 'Invoicing & subscriptions', text: 'Custom PDF invoices, recurring billing and MRR insight via our Billing Platform, automatically from Salesforce.' },
      { icon: '💳', title: 'Payments & receivables', text: 'Automatic collection via Stripe and automated reminders that shorten your DSO.' },
      { icon: '📄', title: 'Contract management', text: 'Manage contracts centrally with automatic alerts for renewals and notice periods.' },
      { icon: '📐', title: 'Projects & time tracking', text: 'Projects linked to sales and invoicing, with time tracking and automatic billing.' },
      { icon: '🏢', title: 'Data enrichment & VAT', text: 'Enrich customer data and validate VAT numbers with Datasolver for clean, compliant data.' },
      { icon: '📒', title: 'Accounting connection', text: 'Seamless integration with Exact Online, so sales and finance work from the same, current figures.' },
    ]}
    metrics={[
      { num: '1 platform', label: 'for your whole backoffice' },
      { num: 'Lower', label: 'DSO & fewer receivables' },
      { num: 'Less', label: 'manual re-typing' },
      { num: 'Faster', label: 'order to cash' },
    ]}
    products={[
      { label: 'Billing Platform', href: '/en/producten/billing-module', featured: true },
      { label: 'Exact Online connection', href: '/en/producten/exact-online' },
      { label: 'Datasolver', href: '/en/producten/kvk-integratie' },
      { label: 'SharePoint', href: '/en/producten/sharepoint' },
    ]}
  />
</Layout>
