---
import Layout from '../../../layouts/Layout.astro';
import SectorPage from '../../../components/SectorPage.astro';
const icon = `<svg viewBox="0 0 24 24" fill="none"><rect x="3" y="7" width="18" height="13" rx="2" stroke="currentColor" stroke-width="1.4"/><path d="M8.5 7V5.5A1.5 1.5 0 0 1 10 4h4a1.5 1.5 0 0 1 1.5 1.5V7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><path d="M3 12h18" stroke="currentColor" stroke-width="1.4"/></svg>`;
---
<Layout title="Salesforce for Professional Services — projects, hours & margins" description="Salesforce for professional services firms: connect sales, projects, time tracking and invoicing. Real-time insight into utilisation, margins and project profitability.">
  <SectorPage
    lang="en"
    eyebrow="Industries · Professional Services"
    title="From sold project to invoiced margin — in one chain"
    intro="In professional services your margin is your people. We connect sales, delivery, time tracking and invoicing in Salesforce, so you steer in real time on utilisation, project profitability and cash flow — instead of discovering it afterwards."
    icon={icon}
    dashboard={{
      title: 'Projects & Margin Dashboard',
      kpis: [ { label: 'Billability', value: '78%', trend: '▲ 4%' }, { label: 'Project margin', value: '32%', trend: '▲ 3%' } ],
      barLabel: 'Revenue per month',
      bars: [50, 58, 55, 64, 71, 86],
      ring: '91%', ringLabel: 'on-time delivery',
      legend: [ { label: 'Billable', value: '1,840 h', color: '#6db757' }, { label: 'Non-billable', value: '420 h', color: '#85b160' }, { label: 'WIP', value: '€58K', color: '#6c4494' } ],
    }}
    painLine="What you sell and what you deliver live in different worlds"
    painPoints={[
      'Sales promises, but delivery and planning only see it later — capacity strains',
      'Hours are logged late or incompletely, delaying invoicing',
      'Only at final billing does it become clear whether a project was profitable',
      'Utilisation and pipeline are hard to combine into a reliable forecast',
      'Assembling invoices from timesheets by hand takes days per month',
      'Customer satisfaction and aftercare disappear from view after delivery',
    ]}
    capabilities={[
      { icon: '📋', title: 'Project & resource planning', text: 'Projects linked to opportunities, with capacity and utilisation planning across your team.' },
      { icon: '⏱️', title: 'Time tracking', text: 'Easy time logging with automatic billing to invoices — billable and non-billable in view.' },
      { icon: '🧾', title: 'Automated invoicing', text: 'Invoices based on hours, fixed fee or contract via our Billing Platform — without re-typing.' },
      { icon: '📊', title: 'Margin & utilisation dashboards', text: 'Real-time insight into billability, project margin, work in progress and forecast.' },
      { icon: '🔮', title: 'Reliable forecast', text: 'Combine pipeline and capacity into a forecast you can plan and hire against.' },
      { icon: '🤝', title: 'Satisfaction & aftercare', text: 'Stay on top of satisfaction, expansion opportunities and repeat business after delivery.' },
    ]}
    metrics={[
      { num: '1 chain', label: 'from sales to invoice' },
      { num: 'Higher', label: 'billability' },
      { num: 'Real-time', label: 'insight into margins' },
      { num: 'Faster', label: 'invoicing & cash flow' },
    ]}
    products={[
      { label: 'Billing Platform', href: '/en/producten/billing-module', featured: true },
      { label: 'Exact Online connection', href: '/en/producten/exact-online' },
      { label: 'SharePoint', href: '/en/producten/sharepoint' },
    ]}
  />
</Layout>
