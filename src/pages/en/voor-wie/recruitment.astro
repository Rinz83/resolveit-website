---
import Layout from '../../../layouts/Layout.astro';
import SectorPage from '../../../components/SectorPage.astro';
const icon = `<svg viewBox="0 0 24 24" fill="none"><circle cx="9" cy="8" r="3.2" stroke="currentColor" stroke-width="1.4"/><path d="M3.5 19.5c0-3 2.5-5 5.5-5s5.5 2 5.5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><circle cx="17.5" cy="7" r="2.2" stroke="currentColor" stroke-width="1.4"/></svg>`;
---
<Layout title="Salesforce for Recruitment & Staffing — pipeline, placements & margin" description="Salesforce for recruitment and staffing agencies: manage candidates, vacancies and clients in one pipeline, automate follow-ups and link placements directly to invoicing.">
  <SectorPage
    lang="en"
    eyebrow="Industries · Recruitment & Staffing"
    title="From first match to invoiced placement — in one pipeline"
    intro="Recruitment is a game of speed. Whoever calls first wins the candidate and the assignment. We bring candidates, vacancies and clients together in one Salesforce pipeline, automate follow-up and link placements directly to invoicing — so your recruiters recruit instead of administrate."
    icon={icon}
    dashboard={{
      title: 'Recruitment Pipeline Dashboard',
      kpis: [ { label: 'Open vacancies', value: '64', trend: '▲ 8' }, { label: 'Time-to-hire', value: '19 days', trend: '▼ 4 days' } ],
      barLabel: 'Placements per month',
      bars: [45, 52, 49, 61, 68, 82],
      ring: '74%', ringLabel: 'fill rate',
      legend: [ { label: 'Candidates', value: '1,240', color: '#6db757' }, { label: 'Interviews', value: '186', color: '#85b160' }, { label: 'Placements', value: '58', color: '#6c4494' } ],
    }}
    painLine="Great candidates drop out while your data sits in ten tools"
    painPoints={[
      'CVs, emails and notes are scattered across inboxes and spreadsheets',
      'Slow follow-up: candidates are gone before the interview is scheduled',
      'No real-time view of the pipeline, fill rate and time-to-hire',
      'Matching happens on gut feeling instead of on data',
      'Placements are tracked separately from invoicing, causing errors',
      'Clients and candidates live in separate systems',
    ]}
    capabilities={[
      { icon: '👥', title: 'Candidate & vacancy management', text: 'One central environment for candidates, vacancies and clients — with the full picture per contact.' },
      { icon: '⚡', title: 'Fast, automatic follow-up', text: 'Automated follow-ups, reminders and status updates throughout the funnel.' },
      { icon: '🎯', title: 'Smart matching', text: 'Match candidates on skills and availability based on data, not gut feeling.' },
      { icon: '🔗', title: 'Job board & email integration', text: 'Connect job boards, email and calendar so everything lands in Salesforce automatically.' },
      { icon: '🧾', title: 'Placement → invoicing', text: 'Placements linked directly to invoicing via our Billing Platform — including recurring secondment invoices.' },
      { icon: '📊', title: 'Pipeline dashboards', text: 'Real-time insight into pipeline, fill rate, time-to-hire and revenue per recruiter.' },
    ]}
    metrics={[
      { num: 'Faster', label: 'candidate placements' },
      { num: '1 source', label: 'for all candidate data' },
      { num: 'Less', label: 'manual follow-up' },
      { num: 'Direct', label: 'from placement to invoice' },
    ]}
    products={[
      { label: 'Billing Platform', href: '/en/producten/billing-module', featured: true },
      { label: 'Datasolver', href: '/en/producten/kvk-integratie' },
      { label: 'Development & Integrations', href: '/en/diensten/development' },
    ]}
  />
</Layout>
