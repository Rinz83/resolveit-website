---
import Layout from '../layouts/Layout.astro';

const services = [
  { icon: '/images/Icon-1.svg', title: 'Implementatie & Onboarding', text: 'Salesforce op maat implementeren zodat het aansluit op uw strategische doelen en direct waarde levert.', href: '/diensten/implementatie' },
  { icon: '/images/Icon-2.svg', title: 'Audit & Consultancy', text: 'Uw huidige Salesforce-omgeving optimaliseren en een roadmap bepalen met quick wins en langetermijnverbeteringen.', href: '/diensten/consultancy' },
  { icon: '/images/Icon-3.svg', title: 'Development & Integraties', text: 'Maatwerk ontwikkeling en koppelingen met tools zoals Exact Online, SharePoint, Stripe, DocuSign en meer.', href: '/diensten/development' },
  { icon: '/images/Icon-4.svg', title: 'Training & Best Practices', text: 'Gebruikerstraining en admin-certificering zodat uw team zelfstandig met Salesforce aan de slag kan.', href: '/diensten/training' },
];

const products = [
  { title: 'Billing Platform', text: 'Facturatie, abonnementen en betalingen vanuit Salesforce, gekoppeld aan Stripe, Exact Online en uw administratie.', badge: 'Managed App', href: '/producten/billing-module' },
  { title: 'AI Prompt Builder', text: 'Integreer OpenAI, Anthropic, Gemini of uw eigen LLM rechtstreeks in Salesforce Flows, zonder code.', badge: 'Managed App', href: '/producten/ai-prompt-builder' },
  { title: 'Datasolver', text: 'Bedrijfsgegevens ophalen via de Kamer van Koophandel, BTW-nummers valideren via VIES en Peppol ID\'s opzoeken — rechtstreeks in Salesforce.', badge: 'AppExchange', href: '/producten/kvk-integratie' },
  { title: 'Influx Exact Connector', text: 'Naadloze koppeling tussen Salesforce en Exact Online voor realtime financiële data en aansturing.', badge: 'Exact Online App Store', href: '/producten/exact-online' },
  { title: 'SharePoint Integratie', text: 'Documenten en bestanden beheren vanuit Salesforce met een directe koppeling naar SharePoint.', badge: 'AppExchange & Microsoft AppSource', href: '/producten/sharepoint' },
];

import { sectors } from '../data/sectors.js';

const integrations = ['Stripe', 'Exact Online', 'SharePoint', 'OneDrive', 'Google Drive', 'Aircall', 'SAP', 'DocuSign', 'ChatGPT', 'Microsoft Teams', 'Slack', 'HubSpot'];

// Customer logos. Original site wordmarks + logos pulled from our Salesforce
// (active customers): the Logo__c URLs, plus marks fetched from each customer's
// own website. Shown on uniform tiles so mixed logo shapes sit cleanly together.
const clients = [
  { src: '/images/clients/gospooky.png', alt: 'GoSpooky' },
  { src: '/images/clients/aquaplus.svg', alt: 'Aqua+' },
  { src: '/images/clients/magistor.svg', alt: 'Magistor' },
  { src: '/images/clients/comcam.svg', alt: 'ComCam' },
  { src: '/images/clients/genomescan.png', alt: 'GenomeScan' },
  { src: '/images/clients/andmore.png', alt: 'And More Interim' },
  { src: '/images/clients/euroforum.png', alt: 'Euroforum' },
  { src: '/images/clients/werkeninderegio.png', alt: 'Werken in de Regio' },
  { src: '/images/clients/opple.png', alt: 'OPPLE Lighting' },
  { src: '/images/clients/talpa.png', alt: 'Talpa Studios' },
  { src: '/images/clients/multacasting.jpg', alt: 'MULTA Casting' },
  { src: '/images/clients/considerati.png', alt: 'Considerati' },
  { src: '/images/clients/parkbee.png', alt: 'ParkBee' },
  { src: '/images/clients/mediconnect.png', alt: 'MediConnect' },
  { src: '/images/clients/citystone.png', alt: 'Citystone' },
  { src: '/images/clients/zyfer.png', alt: 'Zyfer' },
  { src: '/images/clients/solvid.png', alt: 'Solvid Ondernemen' },
  { src: '/images/clients/admesy.png', alt: 'Admesy' },
  { src: '/images/clients/ioit.png', alt: 'IOIT' },
  { src: '/images/clients/artoffiber.webp', alt: 'Art of Fiber' },
  { src: '/images/clients/autoglassclinic.png', alt: 'Autoglass Clinic' },
  { src: '/images/clients/oranjebemiddelt.png', alt: 'OranjeBemiddelt' },
  { src: '/images/clients/cloudcrossing.svg', alt: 'CloudCrossing' },
  { src: '/images/clients/aquaplus-sprinkler.png', alt: 'Aqua+ Sprinklersystemen' },
  { src: '/images/clients/mokma.jpeg', alt: 'MoneyOak' },
  { src: '/images/clients/silverstone.png', alt: 'Silverstone Real Estate' },
];

// Split across two carousel rows that scroll in opposite directions.
const mid = Math.ceil(clients.length / 2);
const row1 = clients.slice(0, mid);
const row2 = clients.slice(mid);
---

<Layout title="Salesforce Partner Nederland — Implementatie & Integratie" description="Resolve IT helpt bedrijven Salesforce in te zetten als motor voor groei. Implementatie, integraties, training en consultancy." transparentHeader={true}>

  <!-- HERO -->
  <section class="hero">
    <!-- animated background layers -->
    <div class="hero-aurora" aria-hidden="true">
      <span class="aurora-blob a1"></span>
      <span class="aurora-blob a2"></span>
      <span class="aurora-blob a3"></span>
    </div>
    <div class="hero-grid-overlay" aria-hidden="true"></div>

    <div class="container hero-inner">
      <div class="hero-content">
        <span class="hero-pill"><span class="dot"></span> Salesforce Gold Partner · sinds 2019</span>
        <h1>Harness the<br />power of<br /><span class="gradient-text">Salesforce</span></h1>
        <p>Resolve IT helpt bedrijven Salesforce in te zetten als motor voor groei — van implementatie tot integratie, training en consultancy.</p>
        <div class="hero-actions">
          <a href="/producten" class="btn btn-primary">Onze producten</a>
          <a href="/contact" class="btn btn-outline">Stel een vraag</a>
        </div>
        <div class="hero-stats">
          <div class="hstat"><span class="hstat-num"><span data-count="300" data-suffix="+">0</span></span><span class="hstat-label">Projecten</span></div>
          <div class="hstat"><span class="hstat-num"><span data-count="10" data-suffix="+">0</span></span><span class="hstat-label">Experts</span></div>
          <div class="hstat"><span class="hstat-num">5★</span><span class="hstat-label">AppExchange</span></div>
        </div>
        <div class="hero-partners">
          <span class="hp-badge"><span class="hp-icon hp-gold">★</span> Salesforce Gold Consultancy Partner</span>
          <span class="hp-badge"><span class="hp-icon hp-blue">⬡</span> Salesforce ISV Partner</span>
        </div>
      </div>

      <div class="hero-visual">
        <div class="hero-img-wrap">
          <div class="hero-person">
            <div class="hero-person-backdrop" aria-hidden="true"></div>
            <div class="hero-person-ring" aria-hidden="true"></div>
            <img src="/images/hero-person.png" alt="Tevreden Resolve IT-klant werkt met Salesforce op een laptop" class="hero-person-img" />
          </div>

          <!-- floating glass badges -->
          <div class="float-badge fb-1">
            <span class="fb-icon" style="background:rgba(109,183,87,0.18);color:var(--color-green)">✓</span>
            <div><strong>Salesforce Gold Partner</strong><small>Gecertificeerde experts</small></div>
          </div>
          <div class="float-badge fb-2">
            <span class="fb-icon" style="background:rgba(108,68,148,0.18);color:#a988d0">↑</span>
            <div><strong>+45% efficiëntie</strong><small>gemiddeld resultaat</small></div>
          </div>
        </div>
        <div class="orb orb-green" aria-hidden="true"></div>
        <div class="orb orb-purple" aria-hidden="true"></div>
      </div>
    </div>

  </section>

  <!-- DIENSTEN -->
  <section id="diensten" class="section bg-off-white">
    <div class="container">
      <div class="section-header reveal">
        <span class="eyebrow">Diensten</span>
        <h2>Alles wat u nodig heeft voor Salesforce-succes</h2>
        <p>Van implementatie tot optimalisatie — wij begeleiden u bij elke stap.</p>
      </div>
      <div class="grid-4">
        {services.map((s, i) => (
          <a href={s.href} class="service-card card reveal" style={`--reveal-delay:${i * 0.08}s`}>
            <div class="service-icon"><img src={s.icon} alt="" width="80" height="61" loading="lazy" /></div>
            <h3>{s.title}</h3>
            <p class="text-muted">{s.text}</p>
            <span class="card-link">Meer lezen →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- WAAROM RESOLVE IT -->
  <section class="section">
    <div class="container">
      <div class="two-col">
        <div class="reveal">
          <span class="eyebrow">Waarom Resolve IT?</span>
          <h2>Onze aanpak maakt het verschil</h2>
          <p class="text-muted" style="margin-bottom:2rem;">Wij combineren diepgaande Salesforce-expertise met een praktische, no-nonsense aanpak die echt werkt voor uw organisatie.</p>
          <ul class="list-check">
            <li>Onafhankelijk advies zonder verborgen agenda</li>
            <li>Praktische aanpak — wij denken mee als partner</li>
            <li>Kristalheldere communicatie, geen jargon</li>
            <li>Langdurige samenwerking ook na implementatie</li>
            <li>Gecertificeerde Salesforce-experts in uw team</li>
            <li>Maatwerk oplossingen voor uw specifieke situatie</li>
          </ul>
          <div style="margin-top:2rem;">
            <a href="/over-ons" class="btn btn-outline-dark">Meer over ons</a>
          </div>
        </div>
        <div class="value-grid">
          {[
            { num: 2019, suffix: '', label: 'Opgericht', plain: true },
            { num: 300, suffix: '+', label: 'Projecten afgerond' },
            { num: 10, suffix: '+', label: 'Gecertificeerde experts' },
            { num: 5, suffix: '★', label: 'AppExchange rating', plain: true },
          ].map((v, i) => (
            <div class="value-item reveal" style={`--reveal-delay:${i * 0.1}s`}>
              <span class="value-num">
                {v.plain ? `${v.num}${v.suffix}` : <span data-count={v.num} data-suffix={v.suffix}>0</span>}
              </span>
              <span class="value-label">{v.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- BILLING PLATFORM SPOTLIGHT -->
  <section class="section bp-spotlight">
    <div class="container bp-inner">
      <div class="bp-copy reveal">
        <span class="eyebrow">Uitgelicht · Billing Platform</span>
        <h2>Eén platform voor facturatie, abonnementen &amp; betalingen</h2>
        <p class="text-muted">Het hart van uw order-to-cash in Salesforce. Maak en verstuur facturen, beheer abonnementen en MRR, en incasseer automatisch — naadloos gekoppeld aan de tools die u al gebruikt.</p>
        <ul class="bp-list">
          <li><strong>Facturatie</strong><span>PDF-facturen op maat, automatisch gegenereerd en verstuurd</span></li>
          <li><strong>Abonnementsbeheer</strong><span>Terugkerende facturatie met realtime MRR-inzicht</span></li>
          <li><strong>Betalingen</strong><span>Automatische incasso via Stripe (creditcard, SEPA, PayPal)</span></li>
          <li><strong>Debiteurenbeheer</strong><span>Geautomatiseerde herinneringen &amp; openstaande posten</span></li>
        </ul>
        <div class="bp-actions">
          <a href="/producten/billing-module" class="btn btn-primary">Ontdek het Billing Platform</a>
          <a href="/contact#afspraak" class="btn btn-outline-dark">Vraag een demo aan</a>
        </div>
      </div>

      <div class="bp-hub reveal" aria-label="Het Billing Platform verbindt met Stripe, Exact Online, Datasolver en SharePoint">
        <div class="bp-center">
          <span class="bp-center-ico">💶</span>
          <span>Billing Platform</span>
        </div>
        <a href="/producten/exact-online" class="bp-node bp-n1"><img class="bp-logo bp-logo-wide" src="/images/logos/exact-online.svg" alt="Exact Online" /></a>
        <a href="/producten/billing-module" class="bp-node bp-n2"><span class="bp-stripe">Stripe</span> Betalingen</a>
        <a href="/producten/kvk-integratie" class="bp-node bp-n3"><span>🏢</span> Datasolver</a>
        <a href="/producten/sharepoint" class="bp-node bp-n4"><img class="bp-logo" src="/images/logos/sharepoint.svg" alt="SharePoint" /> SharePoint</a>
        <svg class="bp-lines" viewBox="0 0 320 320" aria-hidden="true">
          <line x1="160" y1="160" x2="60" y2="60"/><line x1="160" y1="160" x2="260" y2="60"/>
          <line x1="160" y1="160" x2="60" y2="260"/><line x1="160" y1="160" x2="260" y2="260"/>
        </svg>
      </div>
    </div>
  </section>

  <!-- PRODUCTEN -->
  <section class="section bg-dark products-section">
    <div class="products-glow" aria-hidden="true"></div>
    <div class="container" style="position:relative;z-index:1;">
      <div class="section-header reveal">
        <span class="eyebrow">Producten</span>
        <h2 class="text-white">Slimme Salesforce-uitbreidingen</h2>
        <p style="color:rgba(255,255,255,0.7)">Onze eigen producten op de Salesforce AppExchange — direct inzetbaar, bewezen effectief.</p>
      </div>
      <div class="grid-2">
        {products.map((p, i) => (
          <a href={p.href} class="product-card-dark reveal" style={`--reveal-delay:${i * 0.08}s`}>
            <div class="product-card-top"><span class="badge">{p.badge}</span></div>
            <h3 class="text-white">{p.title}</h3>
            <p style="color:rgba(255,255,255,0.7)">{p.text}</p>
            <span class="card-link">Bekijk product →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- SECTOREN -->
  <section class="section">
    <div class="container">
      <div class="section-header reveal">
        <span class="eyebrow">Voor wie?</span>
        <h2>Branche-specifieke Salesforce-oplossingen</h2>
        <p>Elke sector heeft zijn eigen uitdagingen. Wij begrijpen uw branche en leveren oplossingen die écht werken.</p>
      </div>
      <div class="sector-grid">
        {sectors.map((s, i) => (
          <a href={s.href} class="sector-card reveal" style={`--reveal-delay:${(i % 4) * 0.07}s`}>
            <span class="sector-ico" set:html={s.svg} />
            <span class="sector-name">{s.label}</span>
            <span class="sector-desc">{s.desc}</span>
            <span class="sector-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- KLANTEN (tile wall) -->
  <section class="section bg-off-white">
    <div class="container">
      <div class="section-header reveal" style="margin-bottom:2.5rem;">
        <span class="eyebrow">Onze klanten</span>
        <h2>Vertrouwd door toonaangevende organisaties</h2>
        <p>Van scale-ups tot gevestigde namen — organisaties in uiteenlopende sectoren bouwen met ons op Salesforce.</p>
      </div>
    </div>
    <div class="client-carousel">
      <div class="client-row">
        <div class="client-row-track">
          {[...row1, ...row1].map(c => (
            <div class="client-tile"><img src={c.src} alt={c.alt} title={c.alt} loading="lazy" /></div>
          ))}
        </div>
      </div>
      <div class="client-row">
        <div class="client-row-track reverse">
          {[...row2, ...row2].map(c => (
            <div class="client-tile"><img src={c.src} alt={c.alt} title={c.alt} loading="lazy" /></div>
          ))}
        </div>
      </div>
    </div>
    <p class="clients-more">…en vele anderen</p>
  </section>

  <!-- CTA STRIP -->
  <section class="cta-strip bg-dark">
    <div class="cta-glow" aria-hidden="true"></div>
    <div class="container cta-strip-inner reveal">
      <div>
        <h2>Klaar om het volledige potentieel van Salesforce te benutten?</h2>
        <p>Neem contact op voor een vrijblijvend gesprek of plan direct een afspraak in.</p>
      </div>
      <div class="cta-strip-actions">
        <a href="/contact#afspraak" class="btn btn-primary">Maak een afspraak</a>
        <a href="/contact" class="btn btn-outline">Stel een vraag</a>
      </div>
    </div>
  </section>

</Layout>

<style>
/* ============ HERO ============ */
.hero {
  background: var(--color-dark);
  color: var(--color-white);
  padding: 7rem 0 7rem;
  position: relative;
  overflow: hidden;
  isolation: isolate;
}

/* animated aurora blobs */
.hero-aurora { position: absolute; inset: 0; z-index: 0; overflow: hidden; }
.aurora-blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(70px);
  opacity: 0.55;
}
.aurora-blob.a1 { width: 520px; height: 520px; background: rgba(109,183,87,0.45); top: -160px; left: -120px; animation: drift 18s ease-in-out infinite; }
.aurora-blob.a2 { width: 460px; height: 460px; background: rgba(108,68,148,0.42); bottom: -180px; right: -80px; animation: drift 22s ease-in-out infinite reverse; }
.aurora-blob.a3 { width: 360px; height: 360px; background: rgba(109,183,87,0.22); top: 40%; left: 45%; animation: aurora 26s ease-in-out infinite; }

/* dot grid overlay */
.hero-grid-overlay {
  position: absolute; inset: 0; z-index: 0;
  background-image: radial-gradient(rgba(255,255,255,0.07) 1px, transparent 1px);
  background-size: 32px 32px;
  mask-image: radial-gradient(ellipse 80% 60% at 50% 40%, #000 30%, transparent 75%);
  -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 40%, #000 30%, transparent 75%);
}

.hero-inner {
  display: grid;
  grid-template-columns: 1.05fr 0.95fr;
  gap: 4rem;
  align-items: center;
  position: relative;
  z-index: 1;
}

.hero-pill {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.15);
  backdrop-filter: blur(8px);
  padding: 0.45rem 1rem;
  border-radius: var(--radius-pill);
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  color: rgba(255,255,255,0.85);
  margin-bottom: 1.5rem;
}
.hero-pill .dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--color-green);
  box-shadow: 0 0 0 0 rgba(109,183,87,0.7);
  animation: pulse-ring 2s ease-out infinite;
}

.hero-content h1 { color: var(--color-white); margin-bottom: 1.25rem; font-size: clamp(2.4rem, 5.5vw, 4rem); }
.hero-content p {
  color: rgba(255,255,255,0.78);
  font-size: 1.18rem;
  margin-bottom: 2rem;
  max-width: 520px;
}
.hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 2.75rem; }

.hero-stats { display: flex; gap: 2.75rem; }
.hstat { display: flex; flex-direction: column; gap: 0.15rem; }
.hstat-num { font-size: 2.1rem; font-weight: 800; color: var(--color-green-soft); line-height: 1; }
.hstat-label { font-size: 0.82rem; color: rgba(255,255,255,0.6); }

.hero-partners { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-top: 1.75rem; }
.hp-badge {
  display: inline-flex; align-items: center; gap: 0.4rem;
  background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.18);
  border-radius: var(--radius-pill); padding: 0.4rem 0.9rem;
  font-size: 0.78rem; font-weight: 600; color: rgba(255,255,255,0.9);
}
.hp-icon { font-style: normal; }
.hp-gold { color: #f5c518; }
.hp-blue { color: #00a1e0; }

/* hero visual */
.hero-visual { position: relative; }
.hero-img-wrap {
  position: relative;
  z-index: 2;
  animation: float-y 7s ease-in-out infinite;
}
/* ===== Hero person composition ===== */
.hero-person { position: relative; display: flex; align-items: flex-end; justify-content: center; }
.hero-person-backdrop {
  position: absolute; left: 50%; top: 46%; transform: translate(-50%, -50%);
  width: 360px; height: 360px; border-radius: 50%;
  background: radial-gradient(circle at 35% 30%, rgba(109,183,87,0.95), rgba(108,68,148,0.9) 75%);
  filter: blur(2px);
}
.hero-person-ring {
  position: absolute; left: 50%; top: 46%; transform: translate(-50%, -50%);
  width: 420px; height: 420px; border-radius: 50%;
  border: 1.5px dashed rgba(255,255,255,0.25);
  animation: spin-slow 40s linear infinite;
}
@keyframes spin-slow { to { transform: translate(-50%, -50%) rotate(360deg); } }
.hero-person-img {
  position: relative; z-index: 1;
  width: 100%; max-width: 440px; height: auto; display: block;
  filter: drop-shadow(0 28px 40px rgba(0,0,0,0.5));
}
@media (max-width: 820px) { .hero-person-backdrop { width: 300px; height: 300px; } .hero-person-ring { width: 350px; height: 350px; } }

/* ===== Dashboard mockup (legacy, unused) ===== */
.dash {
  background: #ffffff;
  border-radius: 18px;
  box-shadow: 0 30px 70px rgba(0,0,0,0.45);
  border: 1px solid rgba(255,255,255,0.12);
  overflow: hidden;
  width: 100%;
}
.dash-head {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.85rem 1.1rem;
  background: var(--color-off-white);
  border-bottom: 1px solid var(--color-light);
}
.dash-dots { display: flex; gap: 6px; }
.dash-dots i { width: 10px; height: 10px; border-radius: 50%; background: var(--color-light); }
.dash-dots i:nth-child(1) { background: #ff5f57; }
.dash-dots i:nth-child(2) { background: #febc2e; }
.dash-dots i:nth-child(3) { background: #28c840; }
.dash-title { font-size: 0.82rem; font-weight: 600; color: var(--color-text); }
.dash-live {
  margin-left: auto; display: inline-flex; align-items: center; gap: 0.35rem;
  font-size: 0.72rem; font-weight: 600; color: var(--color-green-dark);
}
.lv-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--color-green); animation: pulse-ring 2s ease-out infinite; }

.dash-body { padding: 1.25rem; display: flex; flex-direction: column; gap: 1.1rem; }

.dash-kpis { display: grid; grid-template-columns: 1fr 1fr; gap: 0.85rem; }
.kpi {
  background: var(--color-off-white);
  border: 1px solid var(--color-light);
  border-radius: 12px;
  padding: 0.85rem 1rem;
  display: flex; flex-direction: column; gap: 0.15rem;
}
.kpi-label { font-size: 0.7rem; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em; }
.kpi-val { font-size: 1.5rem; font-weight: 800; color: var(--color-text); line-height: 1.1; }
.kpi-trend { font-size: 0.72rem; font-weight: 700; color: var(--color-green-dark); }

.dash-chart { display: flex; flex-direction: column; gap: 0.6rem; }
.chart-head { display: flex; justify-content: space-between; align-items: center; font-size: 0.72rem; color: var(--color-text-muted); }
