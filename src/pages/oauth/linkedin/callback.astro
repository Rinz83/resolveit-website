---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="LinkedIn autorisatie" description="Interne pagina voor het afronden van de LinkedIn OAuth-koppeling." noindex={true}>
  <div class="section" style="padding-top:4rem;padding-bottom:6rem;">
    <div class="container" style="max-width:640px;">
      <h1>LinkedIn autorisatie</h1>
      <p class="text-muted">Deze pagina is alleen bedoeld om de autorisatiecode van LinkedIn zichtbaar te maken. Kopieer de code hieronder en stuur deze door.</p>
      <div id="result" style="margin-top:2rem;padding:1.5rem;border:1px solid var(--color-light-gray);border-radius:12px;background:var(--color-white);word-break:break-all;font-family:monospace;font-size:0.95rem;">
        Bezig met lezen van de LinkedIn-respons...
      </div>
      <p id="error-msg" class="text-muted" style="margin-top:1rem;display:none;color:#b3261e;"></p>
    </div>
  </div>
</Layout>

<script is:inline>
  (function () {
    var params = new URLSearchParams(window.location.search);
    var code = params.get('code');
    var error = params.get('error');
    var errorDesc = params.get('error_description');
    var box = document.getElementById('result');
    var errBox = document.getElementById('error-msg');

    if (code) {
      box.textContent = code;
    } else if (error) {
      box.textContent = 'Geen code ontvangen.';
      errBox.style.display = 'block';
      errBox.textContent = 'LinkedIn meldde: ' + error + (errorDesc ? ' (' + errorDesc + ')' : '');
    } else {
      box.textContent = 'Geen code of foutmelding gevonden in de URL.';
    }
  })();
</script>
