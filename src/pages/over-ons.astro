---
import Layout from '../layouts/Layout.astro';

const team = [
  { name: 'Rinse van Dorp', role: 'Managing Director', photo: '/images/team/rinse-van-dorp.jpg' },
  { name: 'Rick Koevoets', role: 'Managing Partner', photo: '/images/team/rick-koevoets.jpg' },
  { name: 'Tom Hofland', role: 'Managing Consultant', photo: '/images/team/tom-hofland.jpg' },
  { name: 'Yatish Salihan', role: 'Lead Salesforce Developer', photo: '/images/team/yatish-salihan.jpg' },
  { name: 'Jigar Raval', role: 'Senior Salesforce Developer', photo: '/images/team/jigar-raval.jpg' },
  { name: 'Susana Ferreira', role: 'Developer', photo: '/images/team/susana-ferreira.jpg' },
];

const icons = {
  foundation: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-5 9 5"/><path d="M5 9.5v8M9.67 9.5v8M14.33 9.5v8M19 9.5v8"/><path d="M3 21h18"/></svg>`,
  flexible: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 8h13l-3.5-3.5M20 16H7l3.5 3.5"/></svg>`,
  innovation: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 18h5M10.5 21h3"/><path d="M12 3a6 6 0 0 0-3.8 10.6c.7.6 1.05 1.2 1.05 2.4h5.5c0-1.2.35-1.8 1.05-2.4A6 6 0 0 0 12 3z"/></svg>`,
  partnership: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3"/><path d="M3.5 19a5.5 5.5 0 0 1 11 0"/><circle cx="17.5" cy="9.5" r="2.3"/><path d="M16.5 14.4a4.6 4.6 0 0 1 4.5 4.6"/></svg>`,
};
const values = [
  { icon: icons.foundation, title: 'Sterke fundering', text: 'Slimme, robuuste Salesforce-integraties met schaalbare automatisering en workflows die de tand des tijds doorstaan.' },
  { icon: icons.flexible, title: 'Flexibel & transparant', text: 'We combineren onze expertise met uw kennis. Onafhankelijk advies, praktische implementatie en heldere communicatie.' },
  { icon: icons.innovation, title: 'Innovatiegericht', text: 'Complexe vraagstukken aanpakken met creatieve, op maat gemaakte oplossingen, continu strevend naar excellentie.' },
  { icon: icons.partnership, title: 'Collegiale samenwerking', text: 'Langdurige betrokkenheid die verder gaat dan implementatie, met doorlopende training en updates.' },
];

const timeline = [
  { year: '2019', title: 'Resolve IT opgericht', text: 'Gestart met één missie: organisaties helpen het volledige potentieel van Salesforce te benutten.' },
  { year: '2021', title: 'Eigen producten', text: 'Lancering van onze eigen Salesforce-modules op de AppExchange, waaronder het Billing Platform.' },
  { year: '2023', title: 'Groeiend expertteam', text: 'Uitgegroeid tot een hecht team van gecertificeerde consultants en developers.' },
  { year: '2025', title: 'Exact Golden Luca', text: 'Erkenning voor onze Exact-integratie met de Golden Luca 2025 award.' },
  { year: 'Nu', title: '300+ projecten', text: 'Meer dan 300 afgeronde projecten voor organisaties in uiteenlopende sectoren.' },
];
---

<Layout title="Over ons" description="Leer meer over Resolve IT: opgericht in 2019, met 10+ gecertificeerde Salesforce-experts en 300+ afgeronde projecten.">

  <!-- HERO -->
  <section class="ab-hero">
    <div class="ab-aurora" aria-hidden="true"><span></span><span></span></div>
    <div class="container ab-hero-inner">
      <div class="ab-hero-copy">
        <span class="pp-badge"><span class="pp-badge-dot"></span> Over Resolve IT</span>
        <h1>Uw partner in <span class="gradient-text">Salesforce-succes</span></h1>
        <p>Opgericht in 2019 met één missie: organisaties empoweren om het transformatieve potentieel van Salesforce te benutten, als onafhankelijke partner, met heldere taal en bewezen resultaat.</p>
        <div class="ab-hero-actions">
          <a href="/contact#afspraak" class="btn btn-primary">Maak kennis met ons</a>
          <a href="/cases" class="btn btn-outline">Bekijk cases</a>
        </div>
      </div>
      <div class="ab-hero-img">
        <img src="/images/cases/case-1.jpg" alt="Het team van Resolve IT aan het werk" />
        <div class="ab-hero-badge"><strong>Salesforce</strong><span>Certified Partner</span></div>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="ab-stats">
    <div class="container ab-stats-grid">
      {[
        { num: 2019, plain: true, label: 'Opgericht' },
        { num: 300, suffix: '+', label: 'Afgeronde projecten' },
        { num: 10, suffix: '+', label: 'Gecertificeerde experts' },
        { num: '5★', plain: true, label: 'AppExchange rating' },
      ].map(s => (
        <div class="ab-stat">
          <span class="ab-stat-num">{s.plain ? s.num : <span data-count={s.num} data-suffix={s.suffix}>0</span>}</span>
          <span class="ab-stat-lbl">{s.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- MISSION -->
  <section class="section">
    <div class="container ab-mission">
      <div class="ab-mission-img reveal">
        <img src="/images/cases/case-3.jpg" alt="Samenwerken aan Salesforce-oplossingen" />
      </div>
      <div class="reveal">
        <span class="eyebrow">Onze missie</span>
        <h2>Organisaties laten groeien met Salesforce</h2>
        <p class="text-muted">Wij geloven in samenwerkingen gebouwd op vertrouwen en open communicatie. Onze aanpak combineert diepgaande technische expertise met een praktisch oog voor uw bedrijfsdoelstellingen.</p>
        <p class="text-muted">Als onafhankelijk Salesforce-partner adviseren we zonder verborgen agenda. We spreken duidelijke taal en zorgen dat u altijd begrijpt wat we doen en waarom.</p>
        <ul class="list-check" style="margin-top:1.25rem;">
          <li>Onafhankelijk advies, geen verborgen agenda</li>
          <li>Gecertificeerde experts in uw team</li>
          <li>Langdurige samenwerking, ook na livegang</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- TIMELINE -->
  <section class="section bg-off-white">
    <div class="container">
      <div class="section-header reveal">
        <span class="eyebrow">Ons verhaal</span>
        <h2>Van start-up tot Salesforce-specialist</h2>
      </div>
      <div class="ab-timeline">
        {timeline.map((t, i) => (
          <div class="ab-tl-item reveal" style={`--reveal-delay:${i * 0.08}s`}>
            <span class="ab-tl-year">{t.year}</span>
            <div class="ab-tl-dot" aria-hidden="true"></div>
            <div class="ab-tl-card">
              <h3>{t.title}</h3>
              <p class="text-muted">{t.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- VALUES -->
  <section class="section">
    <div class="container">
      <div class="section-header reveal">
        <span class="eyebrow">Onze waarden</span>
        <h2>Waar wij voor staan</h2>
      </div>
      <div class="grid-4">
        {values.map((v, i) => (
          <div class="card reveal" style={`--reveal-delay:${(i % 4) * 0.08}s`}>
            <div class="icon-circle value-ico" set:html={v.icon} />
            <h4>{v.title}</h4>
            <p class="text-muted">{v.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TEAM -->
  <section class="section bg-off-white">
    <div class="container">
      <div class="section-header reveal">
        <span class="eyebrow">Ons team</span>
        <h2>De mensen achter Resolve IT</h2>
        <p>Een hecht team van gecertificeerde Salesforce-experts, klaar om uw organisatie vooruit te helpen.</p>
      </div>
      <div class="team-carousel">
        <button class="team-nav team-prev" aria-label="Vorige" type="button">‹</button>
        <div class="team-track" id="team-track">
          {team.map((m) => (
            <div class="team-card">
              {m.photo
                ? <img class="team-photo" src={m.photo} alt={m.name} loading="lazy" />
                : <div class="team-avatar">{m.name.split(' ').map(n => n[0]).join('').slice(0,2)}</div>}
              <h4>{m.name}</h4>
              <p class="text-muted">{m.role}</p>
            </div>
          ))}
        </div>
        <button class="team-nav team-next" aria-label="Volgende" type="button">›</button>
      </div>
    </div>
  </section>

  <!-- CERTIFICATIONS -->
  <section class="section-sm">
    <div class="container ab-certs reveal">
      <div class="ab-cert"><span class="ab-cert-ico">🏅</span><div><strong>Salesforce Partner</strong><span>Gecertificeerde consultants & developers</span></div></div>
      <div class="ab-cert"><span class="ab-cert-ico">⭐</span><div><strong>5-sterren AppExchange</strong><span>Beoordeeld door onze klanten</span></div></div>
      <div class="ab-cert"><span class="ab-cert-ico">🏆</span><div><strong>Exact Golden Luca 2025</strong><span>Bekroonde Exact-integratie</span></div></div>
    </div>
  </section>

  <!-- CTA -->
  <section class="ab-cta bg-dark">
    <div class="ab-cta-glow" aria-hidden="true"></div>
    <div class="container ab-cta-inner reveal">
      <div><h2>Benieuwd wat we voor u kunnen betekenen?</h2><p>Plan een vrijblijvend gesprek, of bekijk onze openstaande vacatures.</p></div>
      <div class="ab-cta-actions">
        <a href="/contact#afspraak" class="btn btn-primary">Plan een gesprek</a>
        <a href="/jobs" class="btn btn-outline">Bekijk vacatures</a>
      </div>
    </div>
  </section>

</Layout>

<style>
/* HERO */
.ab-hero { background: var(--color-dark); color: #fff; padding: 6rem 0 4rem; position: relative; overflow: hidden; }
.ab-aurora { position: absolute; inset: 0; z-index: 0; }
.ab-aurora span { position: absolute; border-radius: 50%; filter: blur(80px); }
.ab-aurora span:nth-child(1) { width: 460px; height: 460px; background: rgba(109,183,87,0.35); top: -150px; left: -100px; animation: drift 20s ease-in-out infinite; }
.ab-aurora span:nth-child(2) { width: 400px; height: 400px; background: rgba(108,68,148,0.35); bottom: -150px; right: -80px; animation: drift 24s ease-in-out infinite reverse; }
.ab-hero-inner { position: relative; z-index: 1; display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 4rem; align-items: center; }
.ab-hero-copy h1 { color: #fff; font-size: clamp(2.2rem, 5vw, 3.4rem); margin-bottom: 1.25rem; }
.ab-hero-copy p { color: rgba(255,255,255,0.8); font-size: 1.12rem; margin-bottom: 2rem; max-width: 540px; }
.ab-hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
.ab-hero-img { position: relative; }
.ab-hero-img img { width: 100%; border-radius: var(--radius-lg); box-shadow: 0 30px 70px rgba(0,0,0,0.45); aspect-ratio: 4/3; object-fit: cover; }
.ab-hero-badge { position: absolute; bottom: -18px; left: -18px; background: #fff; border-radius: 14px; padding: 0.8rem 1.1rem; box-shadow: var(--shadow-lg); }
.ab-hero-badge strong { display: block; color: var(--color-primary); font-size: 0.95rem; }
.ab-hero-badge span { font-size: 0.75rem; color: var(--color-text-muted); }
@media (max-width: 820px) { .ab-hero-inner { grid-template-columns: 1fr; gap: 3rem; } .ab-hero { padding: 4.5rem 0; } }

/* STATS */
.ab-stats { background: var(--color-dark-2); padding: 2rem 0; }
.ab-stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; text-align: center; }
.ab-stat-num { display: block; font-size: 2.2rem; font-weight: 800; color: var(--color-green-soft); }
.ab-stat-lbl { font-size: 0.85rem; color: rgba(255,255,255,0.65); }
@media (max-width: 560px) { .ab-stats-grid { grid-template-columns: 1fr 1fr; gap: 1.5rem; } }

/* MISSION */
.ab-mission { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
.ab-mission-img img { width: 100%; border-radius: var(--radius-lg); box-shadow: var(--shadow-lg); aspect-ratio: 4/3; object-fit: cover; }
@media (max-width: 820px) { .ab-mission { grid-template-columns: 1fr; gap: 2.5rem; } .ab-mission-img { order: 2; } }

/* TIMELINE */
.ab-timeline { max-width: 760px; margin: 0 auto; display: flex; flex-direction: column; gap: 0; position: relative; }
.ab-timeline::before { content: ''; position: absolute; left: 70px; top: 10px; bottom: 10px; width: 2px; background: var(--color-light); }
.ab-tl-item { display: grid; grid-template-columns: 60px 30px 1fr; gap: 0.5rem; align-items: start; padding: 0.85rem 0; position: relative; }
.ab-tl-year { font-weight: 800; color: var(--color-green-dark); font-size: 0.95rem; text-align: right; padding-top: 0.9rem; }
.ab-tl-dot { width: 14px; height: 14px; border-radius: 50%; background: var(--color-green); border: 3px solid var(--color-white); box-shadow: 0 0 0 2px var(--color-green); margin: 1rem auto 0; z-index: 1; }
.ab-tl-card { background: var(--color-white); border: 1px solid var(--color-light); border-radius: var(--radius); padding: 1.1rem 1.35rem; box-shadow: var(--shadow); }
.ab-tl-card h3 { font-size: 1.05rem; margin-bottom: 0.3rem; }
@media (max-width: 560px) { .ab-timeline::before { left: 7px; } .ab-tl-item { grid-template-columns: 16px 1fr; } .ab-tl-year { grid-column: 2; text-align: left; padding-top: 0; color: var(--color-green-dark); } .ab-tl-dot { grid-row: 1; grid-column: 1; margin: 4px 0 0; } .ab-tl-card { grid-column: 2; } }

/* VALUE ICONS */
.value-ico { color: var(--color-green-dark); }
.value-ico :global(svg) { width: 30px; height: 30px; }

/* TEAM CAROUSEL */
.team-carousel { position: relative; }
.team-track { display: flex; gap: 1.5rem; overflow-x: auto; scroll-snap-type: x mandatory; scroll-behavior: smooth; padding: 0.5rem 0.25rem 1rem; -ms-overflow-style: none; scrollbar-width: none; }
.team-track::-webkit-scrollbar { display: none; }
.team-card { flex: 0 0 calc((100% - 4.5rem) / 4); scroll-snap-align: start; text-align: center; padding: 2rem 1rem; background: var(--color-white); border: 1px solid var(--color-light); border-radius: var(--radius-lg); transition: transform var(--transition), box-shadow var(--transition); }
@media (max-width: 900px) { .team-card { flex-basis: calc((100% - 1.5rem) / 2); } }
@media (max-width: 560px) { .team-card { flex-basis: 78%; } }
.team-nav { position: absolute; top: calc(50% - 0.5rem); transform: translateY(-50%); z-index: 3; width: 44px; height: 44px; border-radius: 50%; border: 1px solid var(--color-light); background: var(--color-white); color: var(--color-green-dark); font-size: 1.6rem; line-height: 1; cursor: pointer; box-shadow: var(--shadow); transition: all var(--transition); display: flex; align-items: center; justify-content: center; }
.team-nav:hover { background: var(--color-green); color: #fff; border-color: var(--color-green); }
.team-nav:disabled { opacity: 0; pointer-events: none; }
.team-prev { left: -10px; }
.team-next { right: -10px; }
@media (max-width: 600px) { .team-prev { left: 2px; } .team-next { right: 2px; } }
.team-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }
.team-avatar { width: 64px; height: 64px; border-radius: 50%; background: linear-gradient(135deg, var(--color-green), var(--color-purple)); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 1.25rem; font-weight: 700; margin: 0 auto 1rem; }
.team-photo { width: 96px; height: 96px; border-radius: 50%; object-fit: cover; margin: 0 auto 1rem; display: block; box-shadow: 0 6px 18px rgba(0,0,0,0.12); }
.team-card h4 { margin-bottom: 0.25rem; }
.team-card p { font-size: 0.875rem; }

/* CERTS */
.ab-certs { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
@media (max-width: 700px) { .ab-certs { grid-template-columns: 1fr; } }
.ab-cert { display: flex; align-items: center; gap: 1rem; background: var(--color-off-white); border: 1px solid var(--color-light); border-radius: var(--radius-lg); padding: 1.25rem 1.5rem; }
.ab-cert-ico { font-size: 1.8rem; }
.ab-cert strong { display: block; font-size: 0.95rem; }
.ab-cert span { font-size: 0.8rem; color: var(--color-text-muted); }

/* CTA */
.ab-cta { padding: 4.5rem 0; position: relative; overflow: hidden; }
.ab-cta-glow { position: absolute; top: -50%; right: -10%; width: 500px; height: 500px; background: radial-gradient(circle, rgba(109,183,87,0.25), transparent 60%); animation: drift 18s ease-in-out infinite; }
.ab-cta-inner { display: flex; align-items: center; justify-content: space-between; gap: 3rem; flex-wrap: wrap; position: relative; z-index: 1; }
.ab-cta h2, .ab-cta p { color: #fff; }
.ab-cta p { color: rgba(255,255,255,0.75); margin-top: 0.5rem; }
.ab-cta-actions { display: flex; gap: 1rem; flex-shrink: 0; flex-wrap: wrap; }
</style>

<script>
  const track = document.getElementById('team-track');
  const prev = document.querySelector('.team-prev');
  const next = document.querySelector('.team-next');
  if (track && prev && next) {
    const step = () => {
      const card = track.querySelector('.team-card');
      return card ? card.getBoundingClientRect().width + 24 : track.clientWidth * 0.8;
    };
    const update = () => {
      const max = track.scrollWidth - track.clientWidth - 10;
      prev.disabled = track.scrollLeft <= 10;
      next.disabled = track.scrollLeft >= max;
    };
    prev.addEventListener('click', () => track.scrollBy({ left: -step(), behavior: 'smooth' }));
    next.addEventListener('click', () => track.scrollBy({ left: step(), behavior: 'smooth' }));
    track.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
    update();
  }
</script>
