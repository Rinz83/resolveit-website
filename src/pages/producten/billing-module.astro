---
import Layout from '../../layouts/Layout.astro';
import FormModal from '../../components/FormModal.astro';
import { calendlyUrl, pardotForms } from '../../i18n/ui.js';
import '../../styles/product.css';

const features = [
  { icon: '🧾', title: 'Automatische facturen', text: 'Genereer facturen als PDF op basis van producttype, taal en locatie — direct vanuit Salesforce, in uw eigen huisstijl.' },
  { icon: '🔁', title: 'Abonnementen & MRR', text: 'Verkoop abonnementen vanuit Opportunities met maandelijkse, kwartaal- of jaarintervallen. Realtime inzicht in uw Monthly Recurring Revenue.' },
  { icon: '💳', title: 'Automatische incasso', text: 'Onze Payment Collection App koppelt Salesforce aan Stripe. Beheer creditcards, automatische incasso en PayPal — en incasseer automatisch.' },
  { icon: '⏰', title: 'Geautomatiseerde herinneringen', text: 'Betalingsherinneringen worden automatisch verstuurd op de juiste momenten. Minder handwerk, snellere betaling.' },
  { icon: '📅', title: 'Omzettoerekening', text: 'Wijs facturen toe aan een specifieke maand met start- en einddatums op factuurregels — voor zuivere revenue recognition.' },
  { icon: '📊', title: 'Rapportages & dashboards', text: 'Inzicht in betaalintenties, abonnementen zonder betaalmethode en de prestaties van uw volledige facturatieproces.' },
];

const steps = [
  { n: '1', title: 'Deal gesloten', text: 'Bij een closed-won opportunity wordt het abonnement automatisch geactiveerd.' },
  { n: '2', title: 'Factuur gegenereerd', text: 'De juiste factuur wordt aangemaakt — in concept of direct actief, in de juiste taal en template.' },
  { n: '3', title: 'Automatisch geïncasseerd', text: 'Via Stripe wordt het bedrag geïnd op de voorkeursmethode van de klant.' },
  { n: '4', title: 'Opgevolgd & gerapporteerd', text: 'Herinneringen gaan automatisch uit en alle cijfers verschijnen live op uw dashboards.' },
];

const plans = [
  { name: 'Start', price: '250', sub: 'Factureren vanuit Salesforce', features: ['Facturen aanmaken in Salesforce', 'PDF facturen genereren', 'Facturen versturen'], popular: false },
  { name: 'Flow', price: '379', sub: 'Populairste keuze', features: ['Alles uit Start', 'Abonnementsbeheer', 'Debiteurenbeheer', 'Automatisch factureren uit abonnementen', 'Facturatie o.b.v. contractvoorwaarden', 'Flow Automation Rules'], popular: true },
  { name: 'Pro', price: null, sub: 'Op maat geprijsd', features: ['Alles uit Flow', 'Uitgestelde omzet', 'Payment gateways', 'Automatische incasso & creditcard', 'ERP-integratie'], popular: false },
];

const quotes = [
  { t: 'Eindelijk heb ik een compleet overzicht van alle financiële stromen.', n: 'Theo van der Steen', r: 'COO, Underlined' },
  { t: 'Een net systeem voor het beheren van abonnementen en het vastleggen van MRR.', n: 'Michael Charnley', r: 'Manager, ParkBee' },
  { t: 'Facturen maken is nog nooit zo makkelijk geweest.', n: 'Marcel Geurtse', r: 'Controller, MYbusinessmedia' },
];

const faqs = [
  { q: 'Met welke boekhoudpakketten koppelt de Billing Module?', a: 'Onder andere Exact Online, Unit4 Multivers en Microsoft Dynamics. De Pro-licentie biedt volledige ERP-integratie. Voor Exact Online gebruikt u onze dedicated <a href="/producten/exact-online">Influx Exact Connector</a>. <a href="/blog/billing-platform-koppelen-aan-je-erp">Lees meer over ERP-koppelingen →</a>' },
  { q: 'Kan ik abonnementen met verschillende intervallen verkopen?', a: 'Ja — maandelijks, per kwartaal en jaarlijks, met automatische facturatie per interval en dynamische prijsaanpassing bij up- of downgrades. Het abonnementsbeheer activeert facturen automatisch zodra een deal op closed-won staat.' },
  { q: 'Hoe werkt de automatische incasso?', a: 'Via onze Payment Collection App, die Salesforce met Stripe verbindt. Betaalmethoden (creditcard, automatische incasso, PayPal) worden veilig in Salesforce beheerd en automatisch geïncasseerd op de voorkeursmethode van de klant. <a href="/blog/automatische-incasso-met-stripe">Lees meer over automatische incasso →</a>' },
  { q: 'Wat is uitgestelde omzet (deferred revenue) en wordt dat ondersteund?', a: 'Uitgestelde omzet verdeelt de opbrengst van bijvoorbeeld een jaarcontract over de juiste maanden. Met start- en einddatums op factuurregels wordt omzet zuiver toegerekend — beschikbaar in de Pro-licentie.' },
  { q: 'Hoe helpt de module bij debiteurenbeheer?', a: 'Betalingsherinneringen worden automatisch verstuurd op de door u ingestelde momenten, met een overzicht van openstaande bedragen gekoppeld aan kredietlimieten. Zo verkort u uw debiteurentermijn zonder handmatig na te bellen. <a href="/blog/geautomatiseerde-betalingsherinneringen">Lees meer over geautomatiseerde herinneringen →</a>' },
  { q: 'Krijg ik inzicht in mijn MRR en facturatie?', a: 'Ja. Rapporten en dashboards geven realtime inzicht in Monthly Recurring Revenue, betaalintenties, abonnementen zonder actieve betaalmethode en de prestaties van uw volledige facturatieproces. <a href="/blog/rapportages-en-dashboards-billing-platform">Lees meer over rapportages →</a>' },
  { q: 'Kan ik facturen in meerdere talen en huisstijlen genereren?', a: 'Zeker. Facturen worden als PDF gegenereerd op basis van producttype, taal en locatie, met aanpasbare templates per administratie. <a href="/blog/facturen-in-de-juiste-taal">Lees meer over taalherkenning →</a>' },
  { q: 'Helpen jullie bij de implementatie en training?', a: 'Ja. Onze consultants verzorgen de <a href="/diensten/implementatie">implementatie</a> en geven uw team <a href="/diensten/training">training</a>, zodat u snel zelfstandig met de Billing Module werkt.' },
  { q: 'Is er een gratis proefperiode?', a: 'Ja, u kunt de Billing Module vrijblijvend uitproberen. <a href="/contact">Neem contact op</a> en we zetten een proefomgeving voor u klaar.' },
];

const faqJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a.replace(/<[^>]+>/g, '') } })),
});
---

<Layout title="Billing Platform — Facturatie, abonnementen & betalingen in Salesforce" description="Het complete Billing Platform voor Salesforce: facturatie, abonnementsbeheer, MRR-inzicht, debiteurenbeheer en automatische incasso via Stripe — gekoppeld aan Exact Online en Datasolver.">

  <section class="pp-hero">
    <div class="pp-aurora" aria-hidden="true"><span></span><span></span></div>
    <div class="container pp-hero-inner">
      <div class="pp-hero-copy">
        <span class="pp-badge"><span class="pp-badge-dot"></span> Billing Platform · Salesforce-native</span>
        <h1>Facturatie, abonnementen &amp; <span class="gradient-text">betalingen</span> — in Salesforce</h1>
        <p>Het complete platform voor uw order-to-cash. Maak en verstuur facturen, beheer abonnementen en MRR, en incasseer automatisch. <strong>Gekoppeld aan Stripe, Exact Online en Datasolver</strong> — foutloos en volledig geautomatiseerd.</p>
        <div class="pp-hero-actions">
          <a href="#demo" class="btn btn-primary">Vraag een demo aan</a>
          <a href="/contact" class="btn btn-outline">Gratis proberen</a>
        </div>
      </div>
      <div class="pp-hero-visual">
        <div class="bm-invoice">
          <div class="bm-inv-head">
            <div><span class="bm-inv-label">Factuur</span><span class="bm-inv-no">#2026-0428</span></div>
            <span class="bm-inv-status">Betaald ✓</span>
          </div>
          <div class="bm-inv-rows">
            <div class="bm-row"><span>Salesforce licentie — jaarlijks</span><span>€ 4.800</span></div>
            <div class="bm-row"><span>Influx Exact Connector</span><span>€ 876</span></div>
            <div class="bm-row"><span>Support &amp; onderhoud</span><span>€ 1.200</span></div>
          </div>
          <div class="bm-inv-total"><span>Totaal</span><span>€ 6.876</span></div>
          <div class="bm-inv-pay"><span class="bm-stripe">Stripe</span> Automatisch geïncasseerd</div>
        </div>
        <div class="bm-mrr">
          <span class="bm-mrr-label">MRR</span>
          <span class="bm-mrr-val">€ 48.250</span>
          <div class="bm-mrr-bars"><i style="--h:50%"></i><i style="--h:62%"></i><i style="--h:58%"></i><i style="--h:74%"></i><i style="--h:88%"></i></div>
        </div>
      </div>
    </div>
  </section>

  <section class="pp-trust">
    <div class="container pp-trust-grid">
      <div><strong>PDF</strong><span>facturen op maat</span></div>
      <div><strong>MRR</strong><span>realtime inzicht</span></div>
      <div><strong>Stripe</strong><span>automatische incasso</span></div>
      <div><strong>ERP</strong><span>Exact · Unit4 · Dynamics</span></div>
    </div>
  </section>

  <!-- ECOSYSTEM -->
  <section class="section">
    <div class="container">
      <div class="section-header reveal">
        <span class="eyebrow">Eén platform, alles verbonden</span>
        <h2>Het Billing Platform koppelt uw hele order-to-cash</h2>
        <p>Niet zomaar een factuurmodule, maar een platform dat samenwerkt met de tools die uw klanten al gebruiken.</p>
      </div>
      <div class="bm-eco reveal">
        <a href="/producten/exact-online" class="bm-eco-card">
          <span class="bm-eco-ico"><img src="/images/logos/exact-online.svg" alt="Exact Online" /></span>
          <h3>Exact Online</h3>
          <p class="text-muted">Facturen en betalingen automatisch door naar uw boekhouding via de Influx Exact Connector.</p>
          <span class="card-link">Bekijk koppeling →</span>
        </a>
        <a href="/producten/billing-module" class="bm-eco-card">
          <span class="bm-eco-ico"><span class="bm-stripe-lg">Stripe</span></span>
          <h3>Stripe-betalingen</h3>
          <p class="text-muted">Automatische incasso via creditcard, SEPA en PayPal — veilig beheerd vanuit Salesforce.</p>
          <span class="card-link">Onderdeel van Pro →</span>
        </a>
        <a href="/producten/kvk-integratie" class="bm-eco-card">
          <span class="bm-eco-ico">🏢</span>
          <h3>Datasolver</h3>
          <p class="text-muted">Verrijk klantgegevens en valideer btw-nummers voor wettelijk correcte facturen.</p>
          <span class="card-link">Bekijk Datasolver →</span>
        </a>
      </div>
    </div>
  </section>

  <section class="section bg-off-white">
    <div class="container">
      <div class="section-header reveal">
        <span class="eyebrow">Functionaliteiten</span>
        <h2>Uw complete facturatie-engine in Salesforce</h2>
        <p>Van eerste factuur tot terugkerende omzet — alles op één plek, automatisch.</p>
      </div>
      <div class="grid-3">
        {features.map((f, i) => (
          <div class="card pp-feature reveal" style={`--reveal-delay:${(i % 3) * 0.08}s`}>
            <div class="pp-feature-ico">{f.icon}</div>
            <h3>{f.title}</h3>
            <p class="text-muted">{f.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-dark pp-how">
    <div class="pp-how-glow" aria-hidden="true"></div>
    <div class="container" style="position:relative;z-index:1;">
      <div class="section-header reveal">
        <span class="eyebrow">Zo werkt het</span>
        <h2 class="text-white">Van deal tot betaling — automatisch</h2>
      </div>
      <div class="pp-steps">
        {steps.map((s, i) => (
          <div class="pp-step reveal" style={`--reveal-delay:${i * 0.1}s`}>
            <div class="pp-step-n">{s.n}</div>
            <h3 class="text-white">{s.title}</h3>
            <p style="color:rgba(255,255,255,0.72)">{s.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header reveal">
        <span class="eyebrow">Prijzen</span>
        <h2>Kies het plan dat bij u past</h2>
        <p>Begin klein en groei mee — upgraden kan altijd.</p>
      </div>
      <div class="pp-pricing">
        {plans.map(p => (
          <div class={`pp-plan reveal ${p.popular ? 'popular' : ''}`}>
            {p.popular && <span class="pp-plan-flag">Populairste keuze</span>}
            <span class="pp-plan-name">{p.name}</span>
            <div class="pp-plan-price">
              {p.price ? <Fragment><span class="cur">€</span>{p.price}<span class="per">/mnd</span></Fragment> : <Fragment>Op maat</Fragment>}
            </div>
            <span class="pp-plan-sub">{p.sub}</span>
            <ul class="list-check">{p.features.map(f => <li>{f}</li>)}</ul>
            <a href="#demo" class={`btn ${p.popular ? 'btn-primary' : 'btn-outline-dark'}`}>Kies {p.name}</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-off-white">
    <div class="container">
      <div class="section-header reveal">
        <span class="eyebrow">Klanten aan het woord</span>
        <h2>Vertrouwd door financiële teams</h2>
      </div>
      <div class="pp-quotes">
        {quotes.map(q => (
          <div class="pp-quote reveal">
            <p>“{q.t}”</p>
            <div class="pp-quote-by">
              <span class="pp-quote-av">{q.n.split(' ').map(w => w[0]).slice(0,2).join('')}</span>
              <div><strong>{q.n}</strong><small>{q.r}</small></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:820px;">
      <div class="section-header reveal"><span class="eyebrow">Veelgestelde vragen</span><h2>Goed om te weten</h2></div>
      <div class="pp-faq-list">
        {faqs.map(f => (
          <details class="pp-faq reveal"><summary>{f.q}<span class="pp-faq-plus">+</span></summary><p set:html={f.a} /></details>
        ))}
      </div>
    </div>
    <script type="application/ld+json" set:html={faqJsonLd} is:inline />
  </section>

  <section class="pp-cta bg-dark">
    <div class="pp-cta-glow" aria-hidden="true"></div>
    <div class="container pp-cta-inner reveal">
      <div><h2>Klaar om uw facturatie te automatiseren?</h2><p>Vraag een demo aan of start een gratis proef.</p></div>
      <div class="pp-cta-actions">
        <a href="#demo" class="btn btn-primary">Vraag een demo aan</a>
        <a href="/contact" class="btn btn-outline">Stel een vraag</a>
      </div>
    </div>
  </section>

  <FormModal id="demo" title="Vraag een demo aan — Billing Platform" formUrl={pardotForms.demoBilling} />

</Layout>

<style>
/* ecosystem cards */
.bm-eco { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
@media (max-width: 820px) { .bm-eco { grid-template-columns: 1fr; } }
.bm-eco-card { display: flex; flex-direction: column; background: var(--color-white); border: 1px solid var(--color-light); border-radius: var(--radius-lg); padding: 1.75rem; box-shadow: var(--shadow); transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition); }
.bm-eco-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); border-color: rgba(109,183,87,0.4); }
.bm-eco-ico { font-size: 2rem; margin-bottom: 0.85rem; display: flex; align-items: center; height: 32px; }
.bm-eco-ico img { height: 26px; width: auto; }
.bm-stripe-lg { background: #635bff; color: #fff; font-weight: 700; font-size: 0.85rem; padding: 0.25rem 0.6rem; border-radius: 6px; }
.bm-eco-card h3 { font-size: 1.1rem; margin-bottom: 0.5rem; }
.bm-eco-card .card-link { margin-top: auto; padding-top: 1.1rem; color: var(--color-green); font-weight: 600; font-size: 0.9rem; }

.pp-hero-visual { position: relative; }
.bm-invoice { background: #fff; border-radius: var(--radius-lg); box-shadow: 0 30px 70px rgba(0,0,0,0.45); padding: 1.75rem; animation: float-y 7s ease-in-out infinite; }
.bm-inv-head { display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 1px solid var(--color-light); padding-bottom: 1rem; margin-bottom: 1rem; }
.bm-inv-label { display: block; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-text-muted); }
.bm-inv-no { font-weight: 800; color: var(--color-text); font-size: 1.1rem; }
.bm-inv-status { background: rgba(109,183,87,0.14); color: var(--color-green-dark); font-weight: 700; font-size: 0.75rem; padding: 0.3rem 0.7rem; border-radius: 999px; }
.bm-inv-rows { display: flex; flex-direction: column; gap: 0.6rem; }
.bm-row { display: flex; justify-content: space-between; font-size: 0.85rem; color: var(--color-text); }
.bm-row span:first-child { color: var(--color-text-muted); }
.bm-inv-total { display: flex; justify-content: space-between; font-weight: 800; color: var(--color-text); font-size: 1.05rem; border-top: 1px solid var(--color-light); margin-top: 0.85rem; padding-top: 0.85rem; }
.bm-inv-pay { margin-top: 0.85rem; font-size: 0.78rem; color: var(--color-text-muted); display: flex; align-items: center; gap: 0.4rem; }
.bm-stripe { background: #635bff; color: #fff; font-weight: 700; font-size: 0.7rem; padding: 0.15rem 0.5rem; border-radius: 5px; }
.bm-mrr { position: absolute; bottom: -28px; right: -18px; background: var(--color-dark-2); border: 1px solid rgba(255,255,255,0.12); border-radius: 14px; padding: 1rem 1.25rem; box-shadow: 0 16px 36px rgba(0,0,0,0.35); animation: float-y 6s ease-in-out infinite 0.5s; }
.bm-mrr-label { font-size: 0.7rem; color: rgba(255,255,255,0.6); text-transform: uppercase; letter-spacing: 0.08em; }
.bm-mrr-val { display: block; font-size: 1.3rem; font-weight: 800; color: var(--color-green-soft); margin: 0.1rem 0 0.5rem; }
.bm-mrr-bars { display: flex; align-items: flex-end; gap: 4px; height: 34px; }
.bm-mrr-bars i { width: 9px; height: var(--h); background: linear-gradient(180deg, #b9e0a8, var(--color-green)); border-radius: 2px; transform-origin: bottom; animation: grow-bar 1s cubic-bezier(0.16,1,0.3,1) backwards; }
.bm-mrr-bars i:nth-child(2){animation-delay:.1s} .bm-mrr-bars i:nth-child(3){animation-delay:.2s} .bm-mrr-bars i:nth-child(4){animation-delay:.3s} .bm-mrr-bars i:nth-child(5){animation-delay:.4s}
@keyframes grow-bar { from { transform: scaleY(0); opacity: 0; } to { transform: scaleY(1); opacity: 1; } }
@media (max-width: 820px) { .bm-mrr { right: 0; } }
</style>
