---
import Layout from '../../layouts/Layout.astro';

const products = [
  {
    logo: '/images/logos/billing-platform.svg',
    title: 'Billing Platform',
    badge: 'Managed App',
    href: '/producten/billing-module',
    description: 'Facturatie direct vanuit Salesforce, geautomatiseerd, nauwkeurig en naadloos gekoppeld aan uw boekhouding.',
    features: ['Automatische factuurcreatie', 'Koppeling met boekhoudpakketten', 'Terugkerende facturatie', 'Rapportages & dashboards'],
  },
  {
    logo: '/images/logos/ai-prompt-builder.svg',
    title: 'AI Prompt Builder',
    badge: 'Managed App',
    href: '/producten/ai-prompt-builder',
    description: 'Integreer OpenAI, Anthropic, Gemini of uw eigen LLM rechtstreeks in Salesforce Flows, zonder code.',
    features: ['AI direct als invocable action', 'Dynamische prompt templates', 'Meerdere AI-modellen', 'Werkt in alle Flow-types'],
  },
  {
    logo: '/images/logos/datasolver.svg',
    title: 'Datasolver',
    badge: 'AppExchange',
    href: '/producten/kvk-integratie',
    description: 'Automatisch bedrijfsgegevens ophalen en valideren vanuit de Kamer van Koophandel, VIES en Peppol in Salesforce.',
    features: ['KvK-bedrijfsgegevens ophalen', 'VIES BTW-nummers valideren', 'Peppol ID opzoeken', 'Bulk-update mogelijkheden'],
  },
  {
    logo: '/images/logos/signflow.svg',
    title: 'SignFlow',
    badge: 'Managed App',
    href: '/producten/signflow',
    description: 'Laat documenten digitaal ondertekenen rechtstreeks vanuit Salesforce: van contract tot getekende PDF op het record.',
    features: ['Ondertekenen zonder Salesforce-login', 'AI-documentgeneratie of eigen PDF', 'Ondertekenvolgorde en observers', 'Getekend document automatisch op het record'],
  },
  {
    logo: '/images/logos/influx-exact-connector.svg',
    title: 'Influx Exact Connector',
    badge: 'Exact Online App Store',
    href: '/producten/exact-online',
    description: 'Realtime financiële data en bidirectionele synchronisatie tussen Salesforce en Exact Online.',
    features: ['Realtime synchronisatie', 'Facturen & betalingen', 'Klantdata koppeling', 'Financieel dashboard'],
  },
  {
    logo: '/images/logos/salespoint.svg',
    title: 'SalesPoint',
    badge: 'AppExchange',
    href: '/producten/sharepoint',
    description: 'Documenten en bestanden direct beheren vanuit Salesforce met een naadloze koppeling naar SharePoint.',
    features: ['Documentbeheer vanuit Salesforce', 'Automatisch opslaan', 'Versiegeschiedenis', 'Teams integratie'],
  },
];
---

<Layout title="Producten" description="Ontdek Resolve IT's Salesforce-producten: Billing Platform, AI Prompt Builder, Datasolver, Influx Exact Connector en SalesPoint.">

  <div class="page-hero">
    <div class="container">
      <span class="eyebrow">Producten</span>
      <h1>Slimme uitbreidingen voor Salesforce</h1>
      <p>Onze eigen producten op de Salesforce AppExchange: bewezen, direct inzetbaar en volledig ondersteund.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="products-grid">
        {products.map(p => (
          <a href={p.href} class="product-card card">
            <div class="product-header">
              <div class="product-icon">
                {p.logo ? <img src={p.logo} alt={p.title} width="48" height="48" /> : p.icon}
              </div>
              <span class="badge">{p.badge}</span>
            </div>
            <h2>{p.title}</h2>
            <p class="text-muted">{p.description}</p>
            <ul class="list-check">
              {p.features.map(f => <li>{f}</li>)}
            </ul>
            <span class="card-link">Meer informatie →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="integration-section section bg-off-white">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Populaire integraties</span>
        <h2>Koppel Salesforce aan uw favoriete tools</h2>
        <p>Naast onze eigen producten bouwen we ook maatwerk integraties met vrijwel elk systeem.</p>
      </div>
      <div class="integrations-grid">
        {['Stripe', 'OneDrive', 'Google Drive', 'Exact Online', 'Aircall', 'SAP', 'DocuSign', 'ChatGPT', 'Microsoft Teams', 'SharePoint', 'HubSpot', 'Slack'].map(tool => (
          <div class="integration-chip">{tool}</div>
        ))}
      </div>
      <div style="text-align:center;margin-top:2.5rem;">
        <a href="/diensten/development" class="btn btn-outline-dark">Meer over integraties</a>
      </div>
    </div>
  </section>

</Layout>

<style>
.products-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
}
@media (max-width: 960px) { .products-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 560px) { .products-grid { grid-template-columns: 1fr; } }

.product-card { display: flex; flex-direction: column; gap: 1rem; color: var(--color-text); transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition); }
.product-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); border-color: rgba(109,183,87,0.4); }
.product-header { display: flex; align-items: center; justify-content: space-between; }
.product-icon { font-size: 2rem; display: flex; align-items: center; min-height: 44px; }
.product-icon img { height: 34px; width: auto; max-width: 160px; object-fit: contain; display: block; }
.product-card h2 { font-size: 1.4rem; }
.product-card .text-muted { flex: 1; }
.product-card .card-link { margin-top: auto; padding-top: 0.5rem; color: var(--color-green); font-weight: 600; font-size: 0.9rem; }

.integrations-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  justify-content: center;
}
.integration-chip {
  background: var(--color-white);
  border: 1px solid var(--color-light-gray);
  border-radius: 999px;
  padding: 0.5rem 1.25rem;
  font-weight: 600;
  font-size: 0.875rem;
  color: var(--color-text);
  box-shadow: var(--shadow);
  transition: all var(--transition);
}
.integration-chip:hover {
  border-color: var(--color-accent);
  color: var(--color-accent);
  transform: translateY(-2px);
}
</style>
