---
import Layout from '../../../layouts/Layout.astro';

const salesforceSteps = [
  { t: 'Permission sets toewijzen', d: 'Wijs de juiste Permission Set(s) toe aan uw gebruikers. Wijs minimaal <strong>SharePoint Admin Access</strong> toe aan uw eigen gebruiker, zodat u de volgende stappen kunt uitvoeren.', imgs: ['/images/salespoint/image1.png'] },
  { t: 'Open de SharePoint-app', d: 'Ga naar de <strong>App Launcher</strong> en zoek op <strong>SharePoint App</strong>. Open de app — standaard opent de homepagina van de app.', imgs: ['/images/salespoint/image2.png'] },
  { t: 'Start het verlenen van toegang', d: 'Klik op de homepagina op het <strong>“Click me”</strong>-vlak aan de rechterkant. Er opent een nieuw tabblad waarin u toegang verleent aan de SharePoint-app.', imgs: ['/images/salespoint/image3.png'] },
  { t: 'Accepteer het toestemmingsverzoek', d: 'Accepteer in het nieuwe tabblad het toestemmingsverzoek van de app. U wordt daarna doorgestuurd naar de Salesforce-loginpagina.', imgs: ['/images/salespoint/image4.png'] },
  { t: 'Gebruik de juiste login-URL', d: 'Standaard wordt u doorgestuurd naar <code>login.salesforce.com</code>. Heeft u de app in een <strong>Sandbox</strong> geïnstalleerd, vervang dit dan door <code>test.salesforce.com</code>.', imgs: ['/images/salespoint/image5.png'] },
  { t: 'Inloggen & bevestigen', d: 'Log in met uw Salesforce-org. Er verschijnt een <strong>“Connection successful”</strong>-melding. Sluit deze — u keert terug naar de homepagina van de app (nu met een andere afbeelding). Klik op <strong>Next</strong>.', imgs: ['/images/salespoint/image6.png', '/images/salespoint/image8.png'] },
  { t: 'Maak een nieuwe verbinding', d: 'Kies <strong>Create a new connection</strong> en geef de gekoppelde SharePoint-site een duidelijke, generieke naam. Klik op <strong>Next</strong>.', imgs: ['/images/salespoint/image9.png'] },
  { t: 'Kies de hoofdmap', d: 'Selecteer de <strong>Site ID</strong> — of een map daarbinnen — als de hoofdmap waar de dynamische mappen worden aangemaakt (bijv. site “Salesforce Demo”, map “Test Folder”). Klik op <strong>Next</strong>.', imgs: ['/images/salespoint/image10.png'] },
  { t: 'Profielen, bestandstypen & verwijderrechten instellen', d: 'Stel op het laatste scherm drie dingen in: de <strong>profielen</strong> die toegang krijgen tot de app, de <strong>toegestane bestandsformaten</strong> (bijv. pdf, docx) en de <strong>gebruikers</strong> die SharePoint-bestanden vanuit Salesforce mogen verwijderen.', imgs: ['/images/salespoint/image11.png', '/images/salespoint/image12.png'] },
];

const trustedUrl = [
  ['API Name', 'Een naam zonder spaties of speciale tekens, bijv. bedrijfsnaam_Sharepoint'],
  ['URL', 'https://uwdomein.sharepoint.com (uw eigen SharePoint-domein)'],
  ['Active', 'Aangevinkt'],
  ['CSP Context', 'All'],
  ['connect-src (scripts)', 'Aangevinkt'],
  ['font-src (fonts)', 'Aangevinkt'],
  ['frame-src (iframe-inhoud)', 'Aangevinkt'],
  ['img-src (afbeeldingen)', 'Aangevinkt'],
  ['media-src (audio & video)', 'Aangevinkt'],
  ['style-src (stylesheets)', 'Aangevinkt'],
];

const lightningParams = [
  'API-naam van het veld waarin het <strong>SharePoint Folder ID</strong> wordt opgeslagen.',
  'API-naam van het veld waarin het <strong>Pinned Folder ID</strong> wordt opgeslagen.',
  'API-naam van het <strong>object</strong> waarvoor de component werkt.',
  '<em>(Optioneel)</em> API-naam van het <strong>bovenliggende object</strong> — alleen als u de record wilt koppelen aan een ander object in de mappenstructuur.',
  '<em>(Optioneel)</em> API-naam van het veld waarin het SharePoint ID op het <strong>bovenliggende object</strong> staat.',
  'API-naam van het veld dat de <strong>mapnaam</strong> op SharePoint bepaalt (standaard = recordnaam).',
  '<em>(Optioneel)</em> Een maximale <strong>hoogte</strong> voor de Lightning-component.',
  'Selecteer met welke <strong>SharePoint-site</strong> u verbindt — de site die u in de Salesforce-installatiestappen hebt aangemaakt.',
];
---
<Layout title="SalesPoint — Installatiehandleiding" description="Stapsgewijze installatie- en configuratiehandleiding voor SalesPoint: koppel uw SharePoint-site aan Salesforce en voeg de component toe aan uw Lightning-pagina's." noindex={true}>

  <section class="ig-hero">
    <div class="ig-aurora" aria-hidden="true"><span></span><span></span></div>
    <div class="container ig-hero-inner">
      <span class="pp-badge"><span class="pp-badge-dot"></span> SalesPoint · Installatiehandleiding</span>
      <h1>Stel <span class="gradient-text">SalesPoint</span> in binnen Salesforce</h1>
      <p>Uw SharePoint- &amp; Salesforce-integratie is bijna klaar — nog één korte installatie te gaan. Deze handleiding leidt u door het koppelen van uw SharePoint-site aan uw Salesforce-org en het toevoegen van de component aan uw Lightning-pagina's.</p>
    </div>
  </section>

  <section class="section">
    <div class="container ig-body">

      <!-- DEEL 1 -->
      <div class="ig-part">
        <span class="ig-part-tag">Deel 1</span>
        <h2>Salesforce-installatie</h2>
        <p class="text-muted">Koppel uw SharePoint-site aan uw Salesforce-org.</p>
      </div>

      <ol class="ig-steps">
        {salesforceSteps.map((s, i) => (
          <li class="ig-step">
            <span class="ig-num">{i + 1}</span>
            <div class="ig-step-body">
              <h3>{s.t}</h3>
              <p set:html={s.d} />
              {s.imgs && s.imgs.map((src) => (
                <figure class="ig-shot"><img src={src} alt={s.t} loading="lazy" /></figure>
              ))}
            </div>
          </li>
        ))}
      </ol>

      <!-- Trusted URL -->
      <div class="ig-sub">
        <h3>Trusted URL-configuratie</h3>
        <p class="text-muted">Ga naar <strong>Setup</strong> → zoek op <strong>Trusted URL</strong> → <strong>Trusted URL → New Trusted URL</strong>, vul vervolgens de onderstaande velden in en klik op <strong>Save</strong>:</p>
        <div class="ig-table-wrap">
          <table class="ig-table">
            <thead><tr><th>Veld</th><th>Waarde</th></tr></thead>
            <tbody>
              {trustedUrl.map(([f, v]) => <tr><td>{f}</td><td>{v}</td></tr>)}
            </tbody>
          </table>
        </div>
        <p class="ig-tip">💡 Tip: uw SharePoint-domein is de URL waarmee u SharePoint opent, bijv. <code>https://resolveit.sharepoint.com</code>.</p>
      </div>

      <!-- DEEL 2 -->
      <div class="ig-part">
        <span class="ig-part-tag">Deel 2</span>
        <h2>Lightning-pagina configureren</h2>
        <p class="text-muted">Voeg de SharePoint-component toe aan uw objectpagina's.</p>
      </div>

      <div class="ig-note">
        <strong>Hoe mapkoppeling werkt:</strong> wanneer u een object aan SharePoint koppelt, controleert het eerst of er op de aangewezen locatie al een map bestaat met dezelfde naam als de record. Bestaat die, dan wordt deze automatisch gekoppeld (zodat er geen dubbele mappen ontstaan); zo niet, dan wordt er een nieuwe map aangemaakt.
      </div>

      <ol class="ig-steps">
        <li class="ig-step">
          <span class="ig-num">1</span>
          <div class="ig-step-body">
            <h3>Maak twee tekstvelden per object</h3>
            <p>Maak op elk object dat u met SharePoint wilt koppelen <strong>twee tekstvelden</strong> aan: één om het <strong>SharePoint Folder ID</strong> op te slaan en één voor het <strong>Pinned Folder ID</strong>.</p>
            <figure class="ig-shot"><img src="/images/salespoint/lightning1.png" alt="SharePoint Folder Id-veld in Salesforce" loading="lazy" /></figure>
          </div>
        </li>
        <li class="ig-step">
          <span class="ig-num">2</span>
          <div class="ig-step-body">
            <h3>Voeg de component toe aan de Lightning-pagina</h3>
            <p>Open de Lightning App Builder en <strong>sleep</strong> de SharePoint-component naar een willekeurige Lightning-pagina.</p>
            <figure class="ig-shot"><img src="/images/salespoint/lightning2.png" alt="SharePoint-component op de Lightning-pagina" loading="lazy" /></figure>
          </div>
        </li>
        <li class="ig-step">
          <span class="ig-num">3</span>
          <div class="ig-step-body">
            <h3>Configureer de component</h3>
            <p>De instellingen kunnen per object verschillen. Vul in:</p>
            <ol class="ig-config">
              {lightningParams.map((p) => <li set:html={p} />)}
            </ol>
            <figure class="ig-shot ig-shot-narrow"><img src="/images/salespoint/lightning3.png" alt="Configuratiepaneel van de SharePoint-component" loading="lazy" /></figure>
            <p class="ig-tip" style="margin-top:1rem;">Het <strong>Salesforce Files</strong>-vinkje: indien aangevinkt worden bestanden die als Salesforce Files worden aangemaakt door (externe) gebruikers of apps automatisch ook naar SharePoint gekopieerd.</p>
          </div>
        </li>
        <li class="ig-step">
          <span class="ig-num">4</span>
          <div class="ig-step-body"><h3>Opslaan &amp; activeren</h3><p>Sla de Lightning-pagina op en activeer deze. SalesPoint is nu actief op dat object.</p></div>
        </li>
      </ol>

      <div class="ig-cta">
        <h3>Hulp nodig?</h3>
        <p class="text-muted">Onze consultants helpen u graag met de installatie of een begeleide onboarding.</p>
        <div class="ig-cta-actions">
          <a href="/contact" class="btn btn-primary">Neem contact op</a>
          <a href="/producten/sharepoint" class="btn btn-outline-dark">Terug naar SalesPoint</a>
        </div>
      </div>

    </div>
  </section>
</Layout>

<style>
.ig-hero { background: var(--color-dark); color: #fff; padding: 5.5rem 0 4rem; position: relative; overflow: hidden; }
.ig-aurora { position: absolute; inset: 0; z-index: 0; }
.ig-aurora span { position: absolute; border-radius: 50%; filter: blur(80px); }
.ig-aurora span:nth-child(1) { width: 440px; height: 440px; background: rgba(3,108,112,0.45); top: -150px; left: -80px; animation: drift 20s ease-in-out infinite; }
.ig-aurora span:nth-child(2) { width: 380px; height: 380px; background: rgba(109,183,87,0.4); bottom: -150px; right: -60px; animation: drift 24s ease-in-out infinite reverse; }
.ig-hero-inner { position: relative; z-index: 1; max-width: 760px; }
.ig-hero-inner h1 { color: #fff; font-size: clamp(2rem, 5vw, 3rem); margin-bottom: 1rem; }
.ig-hero-inner p { color: rgba(255,255,255,0.82); font-size: 1.12rem; }

.ig-body { max-width: 820px; }
.ig-part { margin: 3rem 0 1.5rem; }
.ig-part:first-child { margin-top: 0; }
.ig-part-tag { display: inline-block; background: rgba(109,183,87,0.14); color: var(--color-green-dark); font-weight: 700; font-size: 0.78rem; padding: 0.25rem 0.8rem; border-radius: 999px; margin-bottom: 0.75rem; }
.ig-part h2 { font-size: 1.6rem; }

.ig-steps { list-style: none; display: flex; flex-direction: column; gap: 1.5rem; padding: 0; }
.ig-step { display: flex; gap: 1rem; align-items: flex-start; }
.ig-step-body { flex: 1; min-width: 0; }
.ig-num { flex-shrink: 0; width: 36px; height: 36px; border-radius: 10px; background: linear-gradient(135deg, var(--color-green), var(--color-green-dark)); color: #fff; font-weight: 800; display: flex; align-items: center; justify-content: center; }
.ig-step h3 { font-size: 1.08rem; margin-bottom: 0.25rem; }
.ig-step p { color: var(--color-text-muted); }
.ig-step code, .ig-config code, .ig-tip code { background: var(--color-off-white); border: 1px solid var(--color-light); border-radius: 5px; padding: 0.1rem 0.4rem; font-size: 0.88em; color: var(--color-text); }

/* Screenshot frame — centered, padded, soft shadow for a uniform look */
.ig-shot {
  margin: 1.25rem auto 0;
  width: fit-content;
  max-width: 100%;
  background: #fff;
  border: 1px solid var(--color-light);
  border-radius: 14px;
  padding: 12px;
  box-shadow: var(--shadow-lg);
}
.ig-shot img { display: block; max-width: 100%; height: auto; border-radius: 6px; }
.ig-shot-narrow { max-width: 360px; }

.ig-sub { margin: 2.5rem 0; padding: 1.75rem; background: var(--color-off-white); border: 1px solid var(--color-light); border-radius: var(--radius-lg); }
.ig-sub h3 { margin-bottom: 0.6rem; }
.ig-table-wrap { overflow-x: auto; margin-top: 1rem; }
.ig-table { width: 100%; border-collapse: collapse; font-size: 0.92rem; }
.ig-table th, .ig-table td { text-align: left; padding: 0.6rem 0.85rem; border-bottom: 1px solid var(--color-light); vertical-align: top; }
.ig-table th { color: var(--color-text-muted); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; }
.ig-table td:first-child { font-weight: 600; white-space: nowrap; }
.ig-tip { margin-top: 1rem; font-size: 0.92rem; color: var(--color-text-muted); }

.ig-note { background: rgba(108,68,148,0.06); border-left: 4px solid var(--color-purple); border-radius: 0 var(--radius) var(--radius) 0; padding: 1.1rem 1.35rem; margin-bottom: 1.75rem; font-size: 0.96rem; color: var(--color-text); }

.ig-config { margin: 0.75rem 0 0 1.1rem; display: flex; flex-direction: column; gap: 0.5rem; color: var(--color-text-muted); }
.ig-config li { padding-left: 0.25rem; }

.ig-cta { margin-top: 3rem; padding: 2rem; border: 1px solid var(--color-light); border-radius: var(--radius-lg); text-align: center; }
.ig-cta h3 { margin-bottom: 0.4rem; }
.ig-cta-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-top: 1.25rem; }
</style>
