---
import Layout from '../../layouts/Layout.astro';
import SectorPage from '../../components/SectorPage.astro';
const icon = `<svg viewBox="0 0 24 24" fill="none"><path d="M12 3l9 4.5-9 4.5-9-4.5L12 3z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/><path d="M3 12l9 4.5 9-4.5" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/><path d="M3 16.5 12 21l9-4.5" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>`;
---
<Layout title="Backoffice Services: facturatie, contracten, projecten & data in Salesforce" description="Automatiseer uw volledige backoffice in Salesforce: facturatie, abonnementen, contracten, projectmanagement, urenregistratie, betalingen en data-verrijking, in één gekoppeld platform.">
  <SectorPage
    eyebrow="Focusgebied · Backoffice Services"
    title="Uw volledige backoffice, geautomatiseerd in Salesforce"
    intro="Geen branche, maar onze specialiteit. Wij verbinden de processen waar uw organisatie dagelijks op draait: facturatie, contracten, projecten, uren en data, in één platform. Minder overtypen, minder fouten, realtime grip op uw order-to-cash."
    icon={icon}
    dashboard={{
      title: 'Backoffice Control Center',
      kpis: [
        { label: 'Omzet YTD', value: '€1,24M', trend: '▲ 18%' },
        { label: 'Openstaand', value: '€86K', trend: '▼ 9 dagen DSO' },
      ],
      barLabel: 'Gefactureerd per maand',
      bars: [48, 56, 52, 67, 70, 90],
      ring: '94%',
      ringLabel: 'op tijd betaald',
      legend: [
        { label: 'Facturatie', value: '€142K', color: '#6db757' },
        { label: 'Abonnementen', value: '€61K', color: '#85b160' },
        { label: 'Projecten', value: '€39K', color: '#6c4494' },
      ],
    }}
    painLine="Uw backoffice draait op losse systemen die niet met elkaar praten"
    painPoints={[
      'Facturen, contracten, uren en CRM staan in aparte tools: gegevens overtypen is dagelijkse kost',
      'Maandafsluiting is een handmatig karwei met te veel kans op fouten',
      'Debiteuren lopen op omdat herinneringen blijven liggen',
      'Geen realtime zicht op omzet, marges en openstaande posten',
      'Contractverlengingen worden gemist door gebrek aan signalering',
      'Klantdata is vervuild, wat leidt tot foutieve facturen en btw-problemen',
    ]}
    capabilities={[
      { icon: '🧾', title: 'Facturatie & abonnementen', text: 'PDF-facturen op maat, terugkerende facturatie en MRR-inzicht via ons Billing Platform, automatisch vanuit Salesforce.' },
      { icon: '💳', title: 'Betalingen & debiteurenbeheer', text: 'Automatische incasso via Stripe en geautomatiseerde herinneringen die uw DSO verkorten.' },
      { icon: '📄', title: 'Contractbeheer', text: 'Contracten centraal beheren met automatische signalering van verlengingen en opzegtermijnen.' },
      { icon: '📐', title: 'Projecten & urenregistratie', text: 'Projecten gekoppeld aan sales en facturatie, met urenregistratie en automatische doorbelasting.' },
      { icon: '🏢', title: 'Data-verrijking & btw', text: 'Verrijk klantgegevens en valideer btw-nummers met Datasolver voor schone, wettelijk correcte data.' },
      { icon: '📒', title: 'Boekhoudkoppeling', text: 'Naadloze koppeling met Exact Online, zodat sales en finance met dezelfde, actuele cijfers werken.' },
    ]}
    metrics={[
      { num: '1 platform', label: 'voor uw hele backoffice' },
      { num: 'Lagere', label: 'DSO & minder debiteuren' },
      { num: 'Minder', label: 'handmatig overtypen' },
      { num: 'Sneller', label: 'van order tot cash' },
    ]}
    products={[
      { label: 'Billing Platform', href: '/producten/billing-module', featured: true },
      { label: 'Exact Online koppeling', href: '/producten/exact-online' },
      { label: 'Datasolver', href: '/producten/kvk-integratie' },
      { label: 'SharePoint', href: '/producten/sharepoint' },
    ]}
    caseHighlights={[
      { client: 'PayPlaza', result: '75% tijdsbesparing op repeterende processen', href: '/cases/payplaza' },
      { client: 'MYbusinessmedia', result: 'Tientallen jaren aan data gevalideerd en opgeschoond', quote: 'Facturen maken is nog nooit zo makkelijk geweest.', author: 'Marcel Geurtse · Controller, MYbusinessmedia', href: '/cases/mybusinessmedia' },
    ]}
  />
</Layout>
