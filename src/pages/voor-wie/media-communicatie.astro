---
import Layout from '../../layouts/Layout.astro';
import SectorPage from '../../components/SectorPage.astro';
const icon = `<svg viewBox="0 0 24 24" fill="none"><path d="M4 9v6l11 4V5L4 9z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/><path d="M18 8a5 5 0 0 1 0 8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>`;
---
<Layout title="Salesforce voor Media & Communicatie — advertenties, abonnees & content" description="Salesforce voor media- en communicatiebedrijven: advertentieverkoop, abonnementen, redactionele workflows en klantrelaties in één omgeving, met facturatie en verlengingen geautomatiseerd.">
  <SectorPage
    eyebrow="Voor wie? · Media & Communicatie"
    title="Advertenties, abonnees en content — uit één centrale waarheid"
    intro="Media draait op relaties: adverteerders, abonnees en lezers. Wij verbinden advertentieverkoop, abonnementenbeheer en redactie in Salesforce, met facturatie en verlengingen volledig geautomatiseerd — zodat u meer haalt uit elke relatie en uit elke euro herhaalomzet."
    icon={icon}
    dashboard={{
      title: 'Ad Sales & Subscriptions',
      kpis: [
        { label: 'Advertentieomzet', value: '€684K', trend: '▲ 9%' },
        { label: 'Actieve abonnees', value: '24.910', trend: '▲ 4%' },
      ],
      barLabel: 'Omzet per maand',
      bars: [50, 57, 54, 65, 69, 83],
      ring: '89%',
      ringLabel: 'renewal rate',
      legend: [
        { label: 'Advertenties', value: '€142K', color: '#6db757' },
        { label: 'Abonnementen', value: '€96K', color: '#85b160' },
        { label: 'Events', value: '€31K', color: '#6c4494' },
      ],
    }}
    painLine="Adverteerders, abonnees en redactie leven in gescheiden werelden"
    painPoints={[
      'Advertentiedeals, plaatsingen en facturatie zitten in losse tools',
      'Abonnees zijn versnipperd over titels en kanalen — geen totaalbeeld',
      'Sales en redactie werken langs elkaar heen zonder gedeeld klantbeeld',
      'Verlengingen en facturatie van abonnementen kosten te veel handwerk',
      'Lastig sturen op herhaalomzet, churn en campagnerendement',
      'Cross- en upsell over titels en kanalen blijft liggen',
    ]}
    capabilities={[
      { icon: '📣', title: 'Advertentie- & plaatsingbeheer', text: 'Beheer advertentiedeals, plaatsingen en pakketten in Salesforce — van offerte tot publicatie.' },
      { icon: '🔁', title: 'Abonnementenbeheer', text: 'Terugkerende facturatie, verlengingen en MRR-inzicht via ons Billing Platform.' },
      { icon: '👥', title: 'Eén klant- & abonneebeeld', text: 'Een 360°-beeld van adverteerders en abonnees over alle titels en kanalen heen.' },
      { icon: '✍️', title: 'Content- & redactieworkflows', text: 'Stroomlijn de samenwerking tussen sales en redactie met gedeelde workflows.' },
      { icon: '💳', title: 'Facturatie & incasso', text: 'Automatische facturatie en incasso van advertenties, abonnementen en events.' },
      { icon: '📊', title: 'Campagne- & omzetdashboards', text: 'Realtime inzicht in advertentieomzet, abonnees, churn en campagnerendement.' },
    ]}
    metrics={[
      { num: '1 beeld', label: 'van adverteerder & abonnee' },
      { num: 'Snellere', label: 'campagne-opvolging' },
      { num: 'Meer', label: 'herhaalomzet' },
      { num: 'Hogere', label: 'renewal rate' },
    ]}
    products={[
      { label: 'Billing Platform', href: '/producten/billing-module', featured: true },
      { label: 'Exact Online koppeling', href: '/producten/exact-online' },
      { label: 'Datasolver', href: '/producten/kvk-integratie' },
    ]}
  />
</Layout>
