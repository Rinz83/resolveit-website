---
import Layout from '../../layouts/Layout.astro';
import SectorPage from '../../components/SectorPage.astro';
const icon = `<svg viewBox="0 0 24 24" fill="none"><rect x="3" y="7" width="18" height="13" rx="2" stroke="currentColor" stroke-width="1.4"/><path d="M8.5 7V5.5A1.5 1.5 0 0 1 10 4h4a1.5 1.5 0 0 1 1.5 1.5V7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><path d="M3 12h18" stroke="currentColor" stroke-width="1.4"/></svg>`;
---
<Layout title="Salesforce voor Professional Services: projecten, uren & marges" description="Salesforce voor zakelijke dienstverleners: verbind sales, projecten, urenregistratie en facturatie. Realtime inzicht in bezetting, marges en projectrendement.">
  <SectorPage
    eyebrow="Voor wie? · Professional Services"
    title="Van verkocht project tot gefactureerde marge, in één keten"
    intro="Bij dienstverlening is uw marge uw mensen. Wij verbinden sales, delivery, urenregistratie en facturatie in Salesforce, zodat u realtime stuurt op bezetting, projectrendement en cashflow, in plaats van het achteraf te ontdekken."
    icon={icon}
    dashboard={{
      title: 'Projects & Margin Dashboard',
      kpis: [
        { label: 'Facturabiliteit', value: '78%', trend: '▲ 4%' },
        { label: 'Projectmarge', value: '32%', trend: '▲ 3%' },
      ],
      barLabel: 'Omzet per maand',
      bars: [50, 58, 55, 64, 71, 86],
      ring: '91%',
      ringLabel: 'on-time delivery',
      legend: [
        { label: 'Declarabel', value: '1.840 u', color: '#6db757' },
        { label: 'Non-billable', value: '420 u', color: '#85b160' },
        { label: 'Onderhanden', value: '€58K', color: '#6c4494' },
      ],
    }}
    painLine="Wat u verkoopt en wat u levert, leven in verschillende werelden"
    painPoints={[
      'Sales belooft, maar delivery en planning zien dat pas later: capaciteit knelt',
      'Uren worden laat of onvolledig geschreven, waardoor facturatie vertraagt',
      'Pas bij de eindafrekening blijkt of een project winstgevend was',
      'Bezetting en pipeline zijn lastig te combineren tot een betrouwbare forecast',
      'Facturen handmatig samenstellen uit urenstaten kost dagen per maand',
      'Klanttevredenheid en nazorg verdwijnen uit beeld na oplevering',
    ]}
    capabilities={[
      { icon: '📋', title: 'Project & resource planning', text: 'Projecten gekoppeld aan opportunities, met capaciteits- en bezettingsplanning over uw hele team.' },
      { icon: '⏱️', title: 'Urenregistratie', text: 'Eenvoudig uren schrijven met automatische doorbelasting naar facturen: declarabel en non-billable inzichtelijk.' },
      { icon: '🧾', title: 'Geautomatiseerde facturatie', text: 'Facturen op basis van uren, fixed fee of contract via ons Billing Platform, zonder overtypen.' },
      { icon: '📊', title: 'Marge- & bezettingsdashboards', text: 'Realtime inzicht in facturabiliteit, projectmarge, onderhanden werk en forecast.' },
      { icon: '🔮', title: 'Betrouwbare forecast', text: 'Combineer pipeline en capaciteit tot een forecast waar u op kunt plannen en aannemen.' },
      { icon: '🤝', title: 'Klanttevredenheid & nazorg', text: 'Houd grip op tevredenheid, uitbreidingskansen en herhaalopdrachten na oplevering.' },
    ]}
    metrics={[
      { num: '1 keten', label: 'van sales tot factuur' },
      { num: 'Hogere', label: 'facturabiliteit' },
      { num: 'Realtime', label: 'inzicht in marges' },
      { num: 'Snellere', label: 'facturatie & cashflow' },
    ]}
    products={[
      { label: 'Billing Platform', href: '/producten/billing-module', featured: true },
      { label: 'Exact Online koppeling', href: '/producten/exact-online' },
      { label: 'SharePoint', href: '/producten/sharepoint' },
    ]}
    caseHighlights={[
      { client: 'MULTA Casting', result: 'Sneller casten en selecteren', quote: 'Elke productie begon weer met chaos in mappen en mailboxen. Nu hebben we rust en overzicht.', author: 'Oprichter, MULTA Casting', href: '/cases/multa-casting' },
      { client: 'MarketResponse', result: '1 systeem voor alle entiteiten, administraties en betaalstromen', href: '/cases/marketresponse' },
    ]}
  />
</Layout>
