---
import Layout from '../../layouts/Layout.astro';
import { pardotForms } from '../../i18n/ui.js';

const learnings = [
  { icon: '🧭', text: 'De 5 oorzaken waarom Salesforce-implementaties stranden (en geen daarvan is technisch)' },
  { icon: '⚖️', text: 'Zelf doen, freelancer, groot bureau of specialist: welke route past bij uw organisatie' },
  { icon: '❓', text: 'De 12 vragen die u elke implementatiepartner moet stellen, met het goede antwoord erbij' },
  { icon: '📐', text: 'Hoe een professionele implementatie is opgebouwd, van analyse tot na de livegang' },
  { icon: '👥', text: 'Waarom adoptie het verschil maakt en hoe u partners daarop onderscheidt' },
  { icon: '💶', text: 'Kosten vergelijken voorbij het uurtarief: de vier factoren die er echt toe doen' },
];

const chapters = [
  'Waarom deze gids',
  'Waarom Salesforce-implementaties stranden',
  'Zelf doen, freelancer, groot bureau of specialist?',
  'De 12 vragen die u elke partner moet stellen',
  'Van inzicht naar impact: hoe een professionele implementatie eruitziet',
  'De vergeten helft: adoptie',
  'Kosten begrijpen: verder kijken dan het uurtarief',
  'De partnerkeuze-checklist',
  'Over Resolve IT',
];

const sampleQuestions = [
  { q: '"Hoe snel zie ik het eerste werkende resultaat?"', a: 'Het goede antwoord wordt uitgedrukt in weken, niet in maanden. Wie pas aan het einde iets laat zien, vraagt u feitelijk om maandenlang blind te vertrouwen.' },
  { q: '"Wat verwacht u van ons?"', a: 'Wantrouw het antwoord "niets, wij ontzorgen volledig". Een implementatie zonder uw betrokkenheid levert een systeem op dat niet bij u past.' },
  { q: '"Hoe voorkomen we dat we volledig van u afhankelijk worden?"', a: 'Een zelfverzekerde partner vindt dit een prettige vraag. Een partner die zichzelf onmisbaar maakt via ondoorgrondelijk maatwerk, heeft een verdienmodel dat tegen u werkt.' },
];
---

<Layout
  title="Gratis whitepaper: de juiste Salesforce-implementatiepartner kiezen"
  description="De complete gids voor het kiezen van een Salesforce-implementatiepartner of Salesforce-consultant. Met de 12 vragen die u elke partner moet stellen en een direct bruikbare checklist."
  breadcrumbs={[{ name: 'Home', item: '/' }, { name: 'Whitepaper', item: '/whitepaper/salesforce-implementatiepartner' }]}
>

  <!-- HERO -->
  <section class="wp-hero">
    <div class="wp-aurora" aria-hidden="true"><span></span><span></span></div>
    <div class="container wp-hero-inner">
      <div class="wp-hero-copy">
        <span class="pp-badge"><span class="pp-badge-dot"></span> Gratis whitepaper</span>
        <h1>De juiste Salesforce-implementatiepartner <span class="gradient-text">kiezen</span></h1>
        <p>De complete gids voor organisaties die Salesforce willen laten werken, niet alleen laten draaien. Waarom implementaties stranden, welke typen partners er zijn en hoe u door mooie salesverhalen heen prikt.</p>
        <div class="wp-hero-actions">
          <a href="#download" class="btn btn-primary">Download de whitepaper</a>
          <span class="wp-hero-note">Gratis · ± 15 minuten leestijd</span>
        </div>
      </div>
      <div class="wp-hero-doc" aria-hidden="true">
        <div class="wp-doc-card">
          <span class="wp-doc-badge">Whitepaper</span>
          <span class="wp-doc-title">De juiste Salesforce-implementatiepartner kiezen</span>
          <span class="wp-doc-sub">Met de 12 vragen die u elke partner moet stellen</span>
          <div class="wp-doc-lines"><span></span><span></span><span></span><span style="width:60%"></span></div>
          <span class="wp-doc-brand">Resolve IT</span>
        </div>
      </div>
    </div>
  </section>

  <!-- WAT U LEERT -->
  <section class="section">
    <div class="container">
      <div class="section-header reveal">
        <span class="eyebrow">Wat u leert</span>
        <h2>Scherper kiezen in elk selectiegesprek</h2>
        <p>Het verschil tussen een Salesforce-omgeving die uw groei aanjaagt en een dure database waar uw team omheen werkt, wordt bepaald door de implementatie. Deze gids helpt u de partner te vinden die dat verschil maakt.</p>
      </div>
      <div class="wp-learn-grid">
        {learnings.map((l, i) => (
          <div class="wp-learn-card reveal" style={`--reveal-delay:${(i % 3) * 0.07}s`}>
            <span class="wp-learn-ico">{l.icon}</span>
            <p>{l.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- INHOUD + VOORPROEFJE -->
  <section class="section bg-off-white">
    <div class="container wp-split">
      <div class="reveal">
        <span class="eyebrow">Inhoud</span>
        <h2>Negen hoofdstukken, direct toepasbaar</h2>
        <ol class="wp-toc">
          {chapters.map(c => <li>{c}</li>)}
        </ol>
      </div>
      <div class="reveal">
        <span class="eyebrow">Voorproefje</span>
        <h2>Drie van de twaalf vragen</h2>
        <div class="wp-samples">
          {sampleQuestions.map(s => (
            <div class="wp-sample">
              <h3>{s.q}</h3>
              <p class="text-muted">{s.a}</p>
            </div>
          ))}
        </div>
        <a href="#download" class="btn btn-primary" style="margin-top:1.5rem;">Lees alle 12 vragen</a>
      </div>
    </div>
  </section>

  <!-- AUTORITEIT -->
  <section class="section">
    <div class="container wp-author">
      <div class="reveal">
        <span class="eyebrow">Over de auteur</span>
        <h2>Geschreven vanuit honderden implementaties</h2>
        <p class="text-muted">Deze gids is geschreven door de consultants van Resolve IT, een Nederlandse Salesforce-partner opgericht in 2019. De patronen, vragen en valkuilen komen rechtstreeks uit de praktijk van meer dan 300 afgeronde projecten.</p>
        <p class="text-muted">We zijn niet neutraal, en dat pretenderen we ook niet. Maar de criteria in de gids gelden voor elke partner die u overweegt, ons incluis. Gebruik ze gerust tegen ons.</p>
      </div>
      <div class="wp-stats reveal">
        <div class="wp-stat"><span class="wp-stat-num">2019</span><span class="wp-stat-lbl">Opgericht</span></div>
        <div class="wp-stat"><span class="wp-stat-num">300+</span><span class="wp-stat-lbl">Afgeronde projecten</span></div>
        <div class="wp-stat"><span class="wp-stat-num">10+</span><span class="wp-stat-lbl">Gecertificeerde experts</span></div>
        <div class="wp-stat"><span class="wp-stat-num">5★</span><span class="wp-stat-lbl">AppExchange rating</span></div>
      </div>
    </div>
  </section>

  <!-- DOWNLOAD FORM -->
  <section class="wp-download bg-dark" id="download">
    <div class="wp-dl-glow" aria-hidden="true"></div>
    <div class="container wp-dl-inner">
      <div class="wp-dl-copy reveal">
        <span class="pp-badge"><span class="pp-badge-dot"></span> Download</span>
        <h2>Ontvang de whitepaper direct in uw mailbox</h2>
        <p>Vul het formulier in en u ontvangt de whitepaper als PDF, inclusief de partnerkeuze-checklist die u direct kunt gebruiken in uw selectiegesprekken.</p>
        <ul class="list-check wp-dl-list">
          <li>De 12 vragen met het goede antwoord erbij</li>
          <li>De partnerkeuze-checklist als bijlage</li>
          <li>Gratis, geen verplichtingen</li>
        </ul>
      </div>
      <div class="wp-dl-form reveal">
        <iframe class="pardot-form" src={pardotForms.whitepaperPartnerkeuze} title="Download de whitepaper" loading="lazy" scrolling="no" style="height:560px"></iframe>
      </div>
    </div>
  </section>

</Layout>

<style>
/* HERO */
.wp-hero { background: var(--color-dark); color: #fff; padding: 6rem 0 5rem; position: relative; overflow: hidden; }
.wp-aurora { position: absolute; inset: 0; z-index: 0; }
.wp-aurora span { position: absolute; border-radius: 50%; filter: blur(80px); }
.wp-aurora span:nth-child(1) { width: 460px; height: 460px; background: rgba(109,183,87,0.35); top: -150px; left: -100px; animation: drift 20s ease-in-out infinite; }
.wp-aurora span:nth-child(2) { width: 400px; height: 400px; background: rgba(108,68,148,0.35); bottom: -150px; right: -80px; animation: drift 24s ease-in-out infinite reverse; }
.wp-hero-inner { position: relative; z-index: 1; display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 4rem; align-items: center; }
.wp-hero-copy .pp-badge { margin-bottom: 1.5rem; display: inline-flex; }
.wp-hero-copy h1 { color: #fff; font-size: clamp(2.2rem, 5vw, 3.3rem); margin-bottom: 1.25rem; }
.wp-hero-copy p { color: rgba(255,255,255,0.8); font-size: 1.12rem; margin-bottom: 2rem; max-width: 540px; }
.wp-hero-actions { display: flex; align-items: center; gap: 1.25rem; flex-wrap: wrap; }
.wp-hero-note { font-size: 0.85rem; color: rgba(255,255,255,0.6); }

/* Document mock */
.wp-hero-doc { display: flex; justify-content: center; }
.wp-doc-card {
  background: linear-gradient(160deg, #fff, #f0f4ee);
  border-radius: 14px;
  width: min(300px, 80%);
  aspect-ratio: 1 / 1.35;
  padding: 1.75rem 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  box-shadow: 0 30px 70px rgba(0,0,0,0.45), 0 0 0 1px rgba(255,255,255,0.08);
  transform: rotate(2.5deg);
}
.wp-doc-badge { align-self: flex-start; font-size: 0.62rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-green-dark); border: 1px solid rgba(90,158,70,0.4); border-radius: 999px; padding: 0.2rem 0.6rem; }
.wp-doc-title { font-weight: 800; font-size: 1.05rem; line-height: 1.3; color: var(--color-text); }
.wp-doc-sub { font-size: 0.75rem; color: var(--color-text-muted); }
.wp-doc-lines { display: flex; flex-direction: column; gap: 0.45rem; margin-top: auto; }
.wp-doc-lines span { display: block; height: 6px; border-radius: 3px; background: rgba(34,41,31,0.1); }
.wp-doc-brand { font-size: 0.75rem; font-weight: 700; color: var(--color-green-dark); margin-top: 0.75rem; }
@media (max-width: 820px) { .wp-hero-inner { grid-template-columns: 1fr; gap: 3rem; } .wp-hero { padding: 4.5rem 0; } .wp-hero-doc { display: none; } }

/* WAT U LEERT */
.wp-learn-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
@media (max-width: 900px) { .wp-learn-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 560px) { .wp-learn-grid { grid-template-columns: 1fr; } }
.wp-learn-card {
  background: var(--color-white);
  border: 1px solid var(--color-light);
  border-radius: var(--radius-lg);
  padding: 1.5rem;
  display: flex;
  gap: 1rem;
  align-items: flex-start;
  transition: transform var(--transition), box-shadow var(--transition);
}
.wp-learn-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-lg); }
.wp-learn-ico { font-size: 1.5rem; flex-shrink: 0; }
.wp-learn-card p { font-size: 0.95rem; color: var(--color-text); margin: 0; }

/* INHOUD + VOORPROEFJE */
.wp-split { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; }
@media (max-width: 820px) { .wp-split { grid-template-columns: 1fr; gap: 3rem; } }
.wp-toc { margin: 1.5rem 0 0; padding: 0 0 0 1.5rem; display: flex; flex-direction: column; gap: 0.6rem; font-weight: 600; }
.wp-toc li::marker { color: var(--color-green-dark); font-weight: 800; }
.wp-samples { display: flex; flex-direction: column; gap: 1rem; margin-top: 1.5rem; }
.wp-sample { background: var(--color-white); border: 1px solid var(--color-light); border-radius: var(--radius); padding: 1.25rem 1.5rem; box-shadow: var(--shadow); }
.wp-sample h3 { font-size: 1rem; margin-bottom: 0.4rem; color: var(--color-green-dark); }
.wp-sample p { font-size: 0.9rem; margin: 0; }

/* AUTORITEIT */
.wp-author { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 4rem; align-items: center; }
@media (max-width: 820px) { .wp-author { grid-template-columns: 1fr; gap: 2.5rem; } }
.wp-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
.wp-stat { background: var(--color-off-white); border: 1px solid var(--color-light); border-radius: var(--radius-lg); padding: 1.5rem; text-align: center; }
.wp-stat-num { display: block; font-size: 1.9rem; font-weight: 800; color: var(--color-green-dark); }
.wp-stat-lbl { font-size: 0.82rem; color: var(--color-text-muted); }

/* DOWNLOAD */
.wp-download { padding: 5rem 0; position: relative; overflow: hidden; scroll-margin-top: 2rem; }
.wp-dl-glow { position: absolute; top: -40%; left: -10%; width: 500px; height: 500px; background: radial-gradient(circle, rgba(109,183,87,0.22), transparent 60%); animation: drift 18s ease-in-out infinite; }
.wp-dl-inner { position: relative; z-index: 1; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
@media (max-width: 820px) { .wp-dl-inner { grid-template-columns: 1fr; gap: 2.5rem; } }
.wp-dl-copy .pp-badge { margin-bottom: 1.25rem; display: inline-flex; }
.wp-dl-copy h2 { color: #fff; margin-bottom: 1rem; }
.wp-dl-copy p { color: rgba(255,255,255,0.78); margin-bottom: 1.5rem; }
.wp-dl-list li { color: rgba(255,255,255,0.85); }
.wp-dl-form { background: #fff; border-radius: 16px; padding: 1.5rem; box-shadow: 0 30px 70px rgba(0,0,0,0.4); }
.wp-dl-form iframe { width: 100%; border: 0; display: block; }
</style>
